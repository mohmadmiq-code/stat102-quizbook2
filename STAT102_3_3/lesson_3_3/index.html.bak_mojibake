const TEMPLATES = [
  {id:"33_sd_raw", title:"ط§ظ„طھط¨ط§ظٹظ† ظˆط§ظ„ط§ظ†ط­ط±ط§ظپ ط§ظ„ظ…ط¹ظٹط§ط±ظٹ ظ„ط¨ظٹط§ظ†ط§طھ ط®ط§ظ…", icon:"S", gen:dispSdRawGen},
  {id:"33_sd_freq", title:"ط§ظ„طھط¨ط§ظٹظ† ظˆط§ظ„ط§ظ†ط­ط±ط§ظپ ط§ظ„ظ…ط¹ظٹط§ط±ظٹ ظ„ط¬ط¯ظˆظ„ طھظƒط±ط§ط±ظٹ", icon:"خ£", gen:dispSdFreqGen},
  {id:"33_sd_group", title:"ط§ظ„ط§ظ†ط­ط±ط§ظپ ط§ظ„ظ…ط¹ظٹط§ط±ظٹ ظ„ط¬ط¯ظˆظ„ طھظˆط²ظٹط¹ طھظƒط±ط§ط±ظٹ", icon:"â–¤", gen:dispSdGroupGen},
  {id:"33_range_raw", title:"ط§ظ„ظ…ط¯ظ‰ ظ„ط¨ظٹط§ظ†ط§طھ ط®ط§ظ…", icon:"R", gen:dispRangeRawGen},
  {id:"33_range_group", title:"ط§ظ„ظ…ط¯ظ‰ ظ„ط¬ط¯ظˆظ„ طھظˆط²ظٹط¹ طھظƒط±ط§ط±ظٹ", icon:"â‡”", gen:dispRangeGroupGen},
  {id:"33_iqr", title:"ط§ظ„ظ…ط¯ظ‰ ط§ظ„ط±ط¨ظٹط¹ظٹ", icon:"Q", gen:dispIqrGen},
  {id:"33_choose", title:"ط§ط®طھظٹط§ط± ظ…ظ‚ظٹط§ط³ ط§ظ„طھط´طھطھ ط§ظ„ط£ظ†ط³ط¨", icon:"âک…", gen:dispChooseGen},
  {id:"33_mcq", title:"ط³ط¤ط§ظ„ ظ†ط¸ط±ظٹ", icon:"طں", gen:dispMcqGen}
];
function shuffleInPlace(arr, r){
  for(let i=arr.length-1;i>0;i--){
    const j = Math.floor(r()*(i+1));
    const tmp = arr[i];
    arr[i] = arr[j];
    arr[j] = tmp;
  }
  return arr;
}
function ensureOrder(){
  const ids = TEMPLATES.map(t=>t.id);
  const ok = Array.isArray(state.order) && state.order.length === ids.length && ids.every(id=>state.order.includes(id));
  if(!ok){
    const r = seededRand("order|"+Date.now()+"|"+Math.random());
    state.order = shuffleInPlace([...ids], r);
    saveState();
  }
  return state.order;
}

function buildBank(){
  const order = ensureOrder();
  return order.map(id=>{
    const t = TEMPLATES.find(x=>x.id===id);
    const v = getVariant(t.id);
    const g = t.gen(v);
    return { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
  });
}
let BANK = buildBank();
if(BANK.length===0){ console.error('BANK is empty'); }


function markDirty(qid){ state.dirty[qid]=true; saveState(); renderSidebar(); }
function renderSidebar(){
  const list=document.getElementById("qList");
  list.innerHTML="";
  const filter = state.sidebarFilter || "all";
  const toShow = BANK.map((q,i)=>({q,i})).filter(({q,i})=>{
    if(filter==="incomplete") return !isQuestionDone(q);
    return true;
  });
  toShow.forEach(({q,i})=>{
    const st = getQuestionStatus(q);
    let dotClass = "";
    if(st==="completed_correct") dotClass = "done";
    else if(st==="completed_wrong") dotClass = "bad";
    else if(st==="in_progress") dotClass = "progress";
    let badge;
    if(st==="completed_correct") badge = el("span",{class:"badge good"},["ظ…ظƒطھظ…ظ„"]);
    else if(st==="completed_wrong") badge = el("span",{class:"badge bad"},["ظ…ظƒطھظ…ظ„"]);
    else badge = el("span",{class:"badge warn"},["ط؛ظٹط± ظ…ظƒطھظ…ظ„"]);
    const unsaved = state.dirty[q.id];
    const item=el("div",{class:"qItem"+(state.currentIndex===i?" active":""), onclick:()=>{state.currentIndex=i;saveState();renderAll();}},[
      el("div",{class:"left"},[
        unsaved ? el("div",{class:"unsaved-dot", title:"ط¥ط¬ط§ط¨ط© ط؛ظٹط± ظ…ط­ظپظˆط¸ط©"},[]) : null,
        el("div",{class:"dot "+dotClass}),
        el("div",{},[
          el("div",{class:"name"},[`ط³ط¤ط§ظ„ ${i+1}: ${q.title}`]),
          el("div",{style:"margin-top:6px"},[badge])
        ])
      ]),
      el("div",{class:"icon"},[q.icon])
    ].filter(Boolean));
    list.appendChild(item);
  });
  ["filterAllBtn","filterIncompleteBtn"].forEach(id=>{
    const btn=document.getElementById(id);
    if(btn) btn.className = "btn small" + ((btn.getAttribute("data-filter")===filter) ? " primary" : "");
  });
  typesetMath(list);
}

function setProgress(){
  let completed=0;
  BANK.forEach(q=>{ if(isQuestionDone(q)) completed++; });

    const qCountEl = document.getElementById("qCount");
  const qNoEl = document.getElementById("qNo");
  if(qCountEl) qCountEl.textContent = BANK.length;
  if(qNoEl) qNoEl.textContent = (state.currentIndex+1);
  const visibleCompleted = window.__examRunning ? completed : 0;
  document.getElementById("progressText").textContent = `طھظ… ط­ظ„ ${visibleCompleted} ط³ط¤ط§ظ„`;
  document.getElementById("progressBar").style.width = `${BANK.length ? (visibleCompleted/BANK.length)*100 : 0}%`;

  const pill = document.getElementById("statusPill");
  const doneAll = (completed===BANK.length);
  pill.textContent = doneAll ? "ظ…ظƒطھظ…ظ„" : "ط؛ظٹط± ظ…ظƒطھظ…ظ„";
  pill.className = "pill" + (doneAll ? "" : " warn");

  const showBtn = document.getElementById("showResultsBtn");
  const nextBtnSide = document.getElementById("nextBtnSide");
  showBtn.disabled = !doneAll || !window.__examRunning;
  if(nextBtnSide) nextBtnSide.disabled = !window.__examRunning;
  return {completed, doneAll};
}

function renderMain(){
  BANK = buildBank();
  const i=state.currentIndex;
  const q=BANK[i];
  const wrap=document.getElementById("mainContent");
  wrap.innerHTML="";

  const p = setProgress();

  const titleRow=el("div",{class:"qtitleRow"},[
    el("div",{class:"qtitle"},[
      el("div",{class:"qnum"},[String(i+1)]),
      el("div",{},[q.title])
    ]),
    el("div",{class:"qmeta"},[
      el("button",{class:"btn small", disabled: !window.__examRunning, onclick:()=>swapQuestion(q.id)},["طھط¨ط¯ظٹظ„ ط§ظ„ط³ط¤ط§ظ„"]),
      el("button",{class:"btn small", disabled: !p.doneAll || !window.__examRunning, onclick:()=>tryShowResults()},["ط¥ط¸ظ‡ط§ط± ط§ظ„ظ†طھظٹط¬ط©"]),
      el("button",{class:"btn small", disabled: !window.__examRunning, onclick:()=>prev()},["ط§ظ„ط³ط§ط¨ظ‚"]),
      el("button",{class:"btn primary small", disabled: !window.__examRunning, onclick:()=>next()},["ط§ظ„طھط§ظ„ظٹ"])
    ])
  ]);

  const branches=el("div",{class:"branches"},[]);
  q.branches.forEach((b,bi)=>{
    const rawLvl = (b.level ?? b.difficulty ?? b.name ?? "");
    let lvl = (rawLvl===undefined||rawLvl===null) ? "" : String(rawLvl);
    if(lvl.trim().toLowerCase()==="undefined") lvl="";
    const tagClass=(lvl==="ط³ظ‡ظ„")?"easy":(lvl==="ظ…طھظˆط³ط·"?"med":(lvl==="طµط¹ط¨"?"hard":""));
    const branchCard=el("div",{class:"branch"},[]);
    const head=el("div",{class:"branchHead"},[
      ...(lvl ? [el("span",{class:`btag ${tagClass||"easy"}`},[lvl])] : [])
    ]);
    const body=el("div",{class:"branchBody"},[]);
    if(b.promptHtml){
      body.innerHTML = b.promptHtml;
    }else{
      body.innerHTML = escapeHtml(b.prompt).replace(/\n/g,"<br/>");
    }

    const parts=el("div",{class:"parts"},[]);
    (b.parts||[]).forEach(pp=>{
      if(pp.inline) return;
      const row=el("div",{class:"part"},[]);
      const label=pp.labelHtml ? el("div",{class:"label", html: pp.labelHtml},[]) : el("div",{class:"label"},[pp.label]);
      const inputWrap=el("div",{class:"inputWrap"},[]);
      const stored = (state.answers[q.id] && state.answers[q.id][bi]) ? state.answers[q.id][bi][pp.key] : "";

      let input;
      if(pp.type==="mcq"){
        input=el("select",{},[
          el("option",{value:""},["ط§ط®طھط±..."]),
          ...(pp.options||[]).map(op=>el("option",{value:op},[op]))
        ]);
        input.setAttribute("data-qid", q.id);
        input.setAttribute("data-bi", String(bi));
        input.setAttribute("data-key", pp.key);
        input.value = stored ?? "";
        input.onchange=()=>{ markDirty(q.id); };
      }else if(pp.type==="text"){
        input=el("textarea",{placeholder:pp.placeholder||""},[]);
        input.setAttribute("data-qid", q.id);
        input.setAttribute("data-bi", String(bi));
        input.setAttribute("data-key", pp.key);
        input.value = stored ?? "";
        input.oninput=()=>{ markDirty(q.id); };
      }else{
        input=el("input",{type:"number", step:pp.step||"1", placeholder:pp.placeholder||""},[]);
        input.setAttribute("data-qid", q.id);
        input.setAttribute("data-bi", String(bi));
        input.setAttribute("data-key", pp.key);
        input.value = stored ?? "";
        input.oninput=()=>{ markDirty(q.id); };
      }

      inputWrap.appendChild(input);
      // ظ…ط³ط­ ط§ظ„طھظ„ظˆظٹظ† ط¹ظ†ط¯ ط§ظ„طھط¹ط¯ظٹظ„ (ط§ظ„طھظ‚ظٹظٹظ… ظٹطھظ… ط¹ظ†ط¯ ط§ظ„ط¶ط؛ط· ط¹ظ„ظ‰ ط²ط± "ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط©")
      input.addEventListener("input", ()=>_clearMarks(input));
      input.addEventListener("change", ()=>_clearMarks(input));

      // ظ‚ظپظ„ ط§ظ„ط­ظ‚ظˆظ„ ط¨ط¹ط¯ ط§ظ„ط­ظپط¸ ط§ظ„ظ†ظ‡ط§ط¦ظٹ (طµط­ظٹط­ ط£ظˆ ط¨ط¹ط¯ ط¥ط¸ظ‡ط§ط± ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©)
      if(_isBranchLocked(q.id, bi)){
        input.disabled = true;
      }

      // ط¥ط±ط´ط§ط¯ ط§ظ„طھظ‚ط±ظٹط¨ ظ„ظ„ظ‚ظٹظ… ط§ظ„ظ†ط³ط¨ظٹط©/ط§ظ„ظ…ط¦ظˆظٹط©
      const lbl = (pp.label||"");
      if(pp.type==="number" && (lbl.includes("ظ†ط³ط¨ظٹ") || lbl.includes("ظ…ط¦ظˆظٹط©"))){
        const txt = lbl.includes("ظ…ط¦ظˆظٹط©") ? "ظ‚ط±ظ‘ط¨ ط¥ظ„ظ‰ ظ…ظ†ط²ظ„طھظٹظ† ط¹ط´ط±ظٹطھظٹظ† (ط¨ط¯ظˆظ† ط¹ظ„ط§ظ…ط© %)." : "ظ‚ط±ظ‘ط¨ ط¥ظ„ظ‰ ظ…ظ†ط²ظ„طھظٹظ† ط¹ط´ط±ظٹطھظٹظ†.";
        inputWrap.appendChild(el("div",{class:"hint"},[txt]));
      }
      row.appendChild(label);
      row.appendChild(inputWrap);
      parts.appendChild(row);
    });

    const locked = _isBranchLocked(q.id, bi);
    const saveBtn = el("button",{class:"btn primary small"},[locked?"ظ…ط­ظپظˆط¸":"ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط©"]);
    saveBtn.disabled = locked;
    saveBtn.onclick = ()=>saveBranchAnswer(q, b, bi, branchCard, saveBtn);

    const btns=el("div",{class:"branchBtns"},[
      saveBtn,
      el("button",{class:"btn small ai-help-btn", onclick:()=>showHelp(q, b), title:"ظ…ط³ط§ط¹ط¯ ط°ظƒط§ط، ط§طµط·ظ†ط§ط¹ظٹ"},[
        el("span",{class:"ai-help-glyph","aria-hidden":"true"},["âœ¦"]),
        "ظ…ط³ط§ط¹ط¯ط©"
      ])
    ]);

    branchCard.appendChild(head);
    branchCard.appendChild(body);
    if((b.parts||[]).length>0) branchCard.appendChild(parts);
    branchCard.appendChild(btns);
    bindInlineInputs(branchCard, q.id, bi);
    branches.appendChild(branchCard);
  });

  wrap.appendChild(titleRow);
  wrap.appendChild(branches);
  typesetMath(wrap);

}

function showExplain(q, b){
  const lvl = (b.level || b.difficulty || b.name || "").toString();
  const list = (Array.isArray(b.explain) ? b.explain : []).map(s=>`<li>${escapeHtml(s)}</li>`).join("");
  const html = `
    <div style="font-weight:900;margin-bottom:8px">${escapeHtml(q.title)} â€” (${escapeHtml(lvl)})</div>
    ${list ? `<ul style="margin:0;padding-right:18px">${list}</ul>` : ``}
  `;
  openModal("ط´ط±ط­ ط§ظ„ط³ط¤ط§ظ„", html);
}

function showMethod(q, b){
  const items = (b.method||["ط§طھط¨ط¹ ط§ظ„ط®ط·ظˆط§طھ ط§ظ„ظ…ظ†ط§ط³ط¨ط© ظ„ظ„ط­ظ„."]).map(s=>`<li><div class="methodLine">${s}</div></li>`).join("");
  const rawLvl = (b.level ?? b.difficulty ?? b.name ?? "");
  let lvl = (rawLvl===undefined||rawLvl===null) ? "" : String(rawLvl);
  if(lvl.trim().toLowerCase()==="undefined") lvl="";
  const head = lvl ? `${escapeHtml(q.title)} â€” <span class="badge small">${escapeHtml(lvl)}</span>` : `${escapeHtml(q.title)}`;
  const html = `
    <div class="methodHead">${head}</div>
    <ul class="methodList">${items}</ul>
  `;
  openModal("ط·ط±ظٹظ‚ط© ط§ظ„ط­ظ„", html);
}

function showHelp(q, b){
  /* prefer the non-revealing AI help panel */
  if(typeof window.__openUnifiedAiHelp === "function") return window.__openUnifiedAiHelp(q, b);
  const title = escapeHtml(q.title||"");
  const levelRaw = (b.level ?? b.difficulty ?? b.name ?? "");
  let level = (levelRaw===undefined||levelRaw===null) ? "" : String(levelRaw);
  if(level.trim().toLowerCase()==="undefined") level="";
  const explainHtml = (b.explain && b.explain.length)
    ? `<ul style="margin:0;padding-right:18px;line-height:2">${b.explain.map(s=>`<li>${escapeHtml(s)}</li>`).join("")}</ul>`
    : "<div style='color:var(--muted);font-weight:700'>ط§ط¨ط¯ط£ ط¨طھط­ط¯ظٹط¯ ط§ظ„ظ…ط¹ط·ظٹط§طھ ط«ظ… ظ†ظˆط¹ ط§ظ„ظ…ط·ظ„ظˆط¨ ظ‚ط¨ظ„ ط§ظ„طھط¹ظˆظٹط¶.</div>";
  const formulaHtml = (b.formula && b.formula.length)
    ? `<div style="font-weight:900;margin:12px 0 6px">ط§ظ„ظ‚ط§ظ†ظˆظ†/ظ…ظ„ط§ط­ط¸ط§طھ</div><ul style="margin:0;padding-right:18px;line-height:2">${b.formula.map(s=>`<li>${escapeHtml(s)}</li>`).join("")}</ul>`
    : "<div style='color:var(--muted);font-weight:700'>ط§ظƒطھط¨ ط§ظ„ظ‚ط§ظ†ظˆظ† ط§ظ„ظ…ظ†ط§ط³ط¨ ط«ظ… ط¹ظˆظ‘ط¶ ط®ط·ظˆط© ط®ط·ظˆط©.</div>";
  openModal("ظ…ط³ط§ط¹ط¯ط©", `
    <div style="font-weight:900;font-size:16px;color:var(--ink);margin-bottom:12px">${title}${level?` <span style="font-size:13px;color:var(--muted)">â€” (${escapeHtml(level)})</span>`:""}</div>
    <div style="background:var(--brand-light);border:1px solid rgba(3,105,161,.22);border-radius:14px;padding:14px 16px;margin-bottom:10px">
      <div style="font-weight:900;color:var(--brand2);margin-bottom:8px">ط§ظ„ظپظƒط±ط©</div>
      ${explainHtml}
    </div>
    <div style="background:#f8fafc;border:1px solid var(--line);border-radius:14px;padding:14px 16px">
      <div style="font-weight:900;color:var(--brand2);margin-bottom:8px">ط§ظ„ظ‚ط§ظ†ظˆظ†</div>
      ${formulaHtml}
    </div>
  `);
}

function _checkPart(part, studentRaw, correct){
  const raw = (studentRaw ?? "").toString().trim();
  if(raw==="") return {ok:false, empty:true};
  if(part.type==="mcq" || part.type==="text"){
    return {ok: normalizeText(raw) === normalizeText(correct), empty:false};
  }
  return {ok: nearlyEqual(Number(raw), Number(correct), 1e-2), empty:false};
}

function _lockBranchInputs(branchCard, qid, bi){
  const nodes = branchCard.querySelectorAll(`[data-qid="${qid}"][data-bi="${bi}"][data-key]`);
  nodes.forEach(n=>{ n.disabled = true; });
}

function _showCorrectModal(q, b, wrongItems){
  const title = escapeHtml(q.title||"");
  const rawLvl = (b.level ?? b.difficulty ?? b.name ?? "");
  let lvl = (rawLvl===undefined||rawLvl===null) ? "" : String(rawLvl);
  if(lvl.trim().toLowerCase()==="undefined") lvl="";

  const methodItems = (b.method && b.method.length)
    ? `<div style="margin:10px 0 6px;font-weight:900">ط·ط±ظٹظ‚ط© ط§ظ„ط­ظ„</div>
       <ul style="margin:0;padding-right:18px">${b.method.map(s=>`<li>${escapeHtml(s)}</li>`).join("")}</ul>`
    : "";

  const list = wrongItems.map(it=>{
    const label = it.labelHtml ? it.labelHtml : escapeHtml(it.label||it.key);
    const val = (typeof it.correct === "number") ? formatNumber(it.correct) : escapeHtml(it.correct);
    return `<li style="margin:8px 0"><div style="font-weight:900">${label}</div><div style="margin-top:4px;color:#0b2b4c;font-weight:900">${val}</div></li>`;
  }).join("");

  const html = `
    <div style="font-weight:900;margin-bottom:6px">${title}${lvl?` â€” (${escapeHtml(lvl)})`:""}</div>
    ${methodItems}
    <div style="margin:10px 0 6px;font-weight:900">ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©</div>
    <ul style="margin:0;padding-right:18px">${list}</ul>
    <div style="margin-top:10px;color:#5b6b7a;font-weight:800">طھظ… ط¥ط¸ظ‡ط§ط± ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©. ظ„طھط¬ظ†ظ‘ط¨ ط­ظپط¸ ط§ظ„ط­ظ„طŒ ظٹظ…ظƒظ†ظƒ طھظˆظ„ظٹط¯ ظ†ط³ط®ط© ط¬ط¯ظٹط¯ط©.</div>
    <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn primary" id="regenAfterShowAnswerBtn">طھظˆظ„ظٹط¯ ط³ط¤ط§ظ„ ط¬ط¯ظٹط¯</button>
      <button class="btn small" onclick="closeModal()">ظ„ط§ط­ظ‚ظ‹ط§</button>
    </div>
  `;
  openModal("ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©", html);
  const regenBtn = document.getElementById("regenAfterShowAnswerBtn");
  if(regenBtn) regenBtn.onclick = ()=>{ closeModal(); swapQuestion(q.id); };
}

function _promptShowCorrectModal(q, b, wrongItems){
  openModal("ط§ظ†طھظ‡طھ ط§ظ„ظ…ط­ط§ظˆظ„ط§طھ", `
    <div style="font-weight:900;margin-bottom:10px">ط§ظ†طھظ‡طھ ظ…ط­ط§ظˆظ„ط§طھ ظ‡ط°ط§ ط§ظ„ط³ط¤ط§ظ„.</div>
    <div style="color:var(--muted);font-weight:700;margin-bottom:14px">ظٹظ…ظƒظ†ظƒ ط§ظ„ط¢ظ† ط¹ط±ط¶ ط§ظ„ط­ظ„ ط§ظ„ظƒط§ظ…ظ„ ط¨ط§ظ„ط¶ط؛ط· ط¹ظ„ظ‰ ط§ظ„ط²ط± ط§ظ„طھط§ظ„ظٹ.</div>
    <button class="btn primary" id="showAnswerAfterAttemptsBtn">ط¥ط¸ظ‡ط§ط± ط§ظ„ط¥ط¬ط§ط¨ط©</button>
  `);
  const btn = document.getElementById("showAnswerAfterAttemptsBtn");
  if(btn) btn.onclick = ()=>_showCorrectModal(q, b, wrongItems);
}

function saveBranchAnswer(q, b, bi, branchCard, saveBtn){
  const qid = q.id;
  if(_isBranchLocked(qid, bi)) return;

  const parts = (b.parts||[]);
  const results = [];
  let hasEmpty = false;

  parts.forEach(p=>{
    const key = p.key;
    const inp = branchCard.querySelector(`[data-qid="${qid}"][data-bi="${bi}"][data-key="${key}"]`);
    if(!inp) return;
    const student = (inp.value ?? "").toString();
    const correct = b.answers ? b.answers[key] : undefined;
    const chk = _checkPart(p, student, correct);
    if(chk.empty) hasEmpty = true;
    results.push({key, part:p, inp, correct, ...chk});
  });

  if(hasEmpty){
    openModal("طھظ†ط¨ظٹظ‡", `<div style="font-weight:900">ط£ظƒظ…ظ„ ط¥ط¯ط®ط§ظ„ ط§ظ„ط¥ط¬ط§ط¨ط© ط«ظ… ط§ط¶ط؛ط· ط²ط± ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط©.</div>`);
    return;
  }

  // طھط®ط²ظٹظ† ط§ظ„ط¥ط¬ط§ط¨ط© ط¹ظ†ط¯ ط§ظ„ط¶ط؛ط· ط¹ظ„ظ‰ ط²ط± ط§ظ„ط­ظپط¸ ظپظ‚ط· (ط§ظ„ط§ظ†طھظ‚ط§ظ„ ظ„ط§ ظٹط³ط¨ط¨ طھط®ط²ظٹظ†ظ‹ط§)
  if(!state.answers[qid]) state.answers[qid] = {};
  if(!state.answers[qid][bi]) state.answers[qid][bi] = {};
  results.forEach(r=>{
    state.answers[qid][bi][r.key] = (r.inp && r.inp.value!=null) ? r.inp.value : "";
  });
  delete state.dirty[qid];
  saveState();

  const wrong = results.filter(r=>!r.ok);
  const right = results.filter(r=>r.ok);

  right.forEach(r=>_mark(r.inp, "right"));

  if(wrong.length===0){
    _clearSaveAttempt(qid, bi);
    _setOutcome(qid, bi, "correct");
    _setBranchLocked(qid, bi, true);
    _lockBranchInputs(branchCard, qid, String(bi));
    if(saveBtn) saveBtn.disabled = true;
    setProgress();
    renderSidebar();
    return;
  }

  const n = _incSaveAttempt(qid, bi);
  if(n<=1){
    wrong.forEach(r=>_mark(r.inp, "wrong1"));
    _setOutcome(qid, bi, null);
    showHelp(q, b);
  }else{
    wrong.forEach(r=>_mark(r.inp, "wrong2"));
    const wrongItems = wrong.map(r=>({
      key:r.key,
      label: r.part.label,
      labelHtml: r.part.labelHtml,
      correct: r.correct
    }));
    _setOutcome(qid, bi, "wrong");
    _setBranchLocked(qid, bi, true);
    _lockBranchInputs(branchCard, qid, String(bi));
    if(saveBtn) saveBtn.disabled = true;
    _promptShowCorrectModal(q, b, wrongItems);
  }

  setProgress();
  renderSidebar();
}


function swapQuestion(qid){
  bumpVariant(qid);
  clearAnswersForQuestion(qid);
  const t = TEMPLATES.find(x=>x.id===qid);
  if(t){
    const v = getVariant(t.id);
    const g = t.gen(v);
    const ni = BANK.findIndex(q=>q.id===qid);
    const obj = { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
    if(ni>=0) BANK[ni]=obj;
  }
  saveState();
  renderAll();
}
function next(){ if(state.currentIndex < BANK.length-1){state.currentIndex++;saveState();renderAll();} else tryShowResults(); }
function prev(){ if(state.currentIndex>0){state.currentIndex--;saveState();renderAll();} }

function gradeAll(){
  state.grading = {};
  BANK.forEach((q)=>{
    const qid=q.id;
    state.grading[qid] = {};
    q.branches.forEach((b,bi)=>{
      state.grading[qid][bi] = {};
      (b.parts||[]).forEach(p=>{
        const student = (state.answers[qid] && state.answers[qid][bi]) ? state.answers[qid][bi][p.key] : "";
        const correct = b.answers[p.key];
        let ok=false;
        if(p.type==="mcq"){
          ok = normalizeText(student) === normalizeText(correct);
        }else if(p.type==="text"){
          ok = normalizeText(student) === normalizeText(correct);
        }else{
          ok = nearlyEqual(Number(student), Number(correct), 1e-2);
        }
        state.grading[qid][bi][p.key] = ok;
      });
    });
  });
  saveState();
}
function computeScore(){
  let correct=0,total=0;
  BANK.forEach(q=>{
    const qid=q.id;
    q.branches.forEach((b,bi)=>{
      const keys = collectPartKeys(q,b);
      keys.forEach(k=>{
        total++;
        const ok = state.grading[qid] && state.grading[qid][bi] ? state.grading[qid][bi][k] : false;
        if(ok) correct++;
      });
    });
  });
  return {correct,total};
}

function tryShowResults(){
  syncAllInputs();
  const p = setProgress();
  if(!p.doneAll){
    if(!confirm("ظ‡ظ†ط§ظƒ ط£ط³ط¦ظ„ط© ظ„ظ… طھظڈط¬ط¨ ط¹ظ†ظ‡ط§. ظ‡ظ„ طھط±ظٹط¯ ط§ظ„ظ…طھط§ط¨ط¹ط©طں")) return;
  }
  showResults();
}
window.__goToQ = function(idx){
  closeModal();
  state.currentIndex = idx;
  saveState();
  renderAll();
}


function syncAllInlineInputs(){ /* ظ„ط§ ظٹطھظ… طھط®ط²ظٹظ† ط§ظ„ط¥ط¬ط§ط¨ط§طھ ط¥ظ„ط§ ط¹ط¨ط± ط²ط± ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط© */ }

function syncAllInputs(){ /* ظ„ط§ ظٹطھظ… طھط®ط²ظٹظ† ط§ظ„ط¥ط¬ط§ط¨ط§طھ ط¥ظ„ط§ ط¹ط¨ط± ط²ط± ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط© */ }


function showResults(){
  syncAllInlineInputs();
  BANK = buildBank();
  gradeAll();
  const s = computeScore();
  const pct = Math.round((s.correct/s.total)*1000)/10;

  const correctPct = s.total ? (s.correct/s.total)*100 : 0;
  const wrongPct = s.total ? ((s.total-s.correct)/s.total)*100 : 0;
  const header = `
    <div class="scoreCard">
      <div>
        <div class="scoreBig">ط§ظ„ظ†طھظٹط¬ط©: ${s.correct} ظ…ظ† ${s.total} â€” ${pct}%</div>
        <div class="score-bar-wrap" style="margin:10px 0"><div class="score-bar-correct" style="width:${correctPct}%"></div><div class="score-bar-wrong" style="width:${wrongPct}%"></div></div>
        <div class="scoreSub">طھظˆط¶ظٹط­: طھظ… طھطµط­ظٹط­ ظƒظ„ ط¬ط²ط، ط¨ط´ظƒظ„ ظ…ط³طھظ‚ظ„.</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn primary" onclick="window.print()">ط·ط¨ط§ط¹ط© ط§ظ„ظ†طھظٹط¬ط©</button>
        <button class="btn small" onclick="resetAll(); closeModal();">ط¥ط¹ط§ط¯ط© طھط¹ظٹظٹظ†</button>
      </div>
    </div>
  `;

  const qCards = BANK.map((q,i)=>{
    const qid = q.id;
    const st = getQuestionStatus(q);
    const isCorrect = (st === "completed_correct");
    let card = `
      <div class="resultCard">
        <div class="rt">
          <div style="font-weight:900">ط³ط¤ط§ظ„ ${i+1}: ${escapeHtml(q.title||"")}</div>
          <span class="tag ${isCorrect?"good":"bad"}">${isCorrect?"طµط­ظٹط­":"ط؛ظٹط± طµط­ظٹط­"}</span>
        </div>
    `;

    q.branches.forEach((b,bi)=>{
      const rawLvl = (b.level ?? b.difficulty ?? b.name ?? "");
      let lvl = (rawLvl===undefined||rawLvl===null) ? "" : String(rawLvl);
      if(lvl.trim().toLowerCase()==="undefined") lvl="";
      if(lvl.trim()!==""){
        card += `<div style="margin-top:10px;font-weight:900;color:#0f2a3b">(${escapeHtml(lvl)})</div>`;
      }

      (b.parts||[]).forEach(p=>{
        const student = (state.answers[qid] && state.answers[qid][bi]) ? state.answers[qid][bi][p.key] : "";
        const correctVal = b.answers[p.key];
        const need2 = (p.label||"").includes("ظ†ط³ط¨ظٹ") || (p.label||"").includes("ظ…ط¦ظˆظٹط©");

        let studentText = "â€”";
        if((student??"").toString().trim()!==""){
          if(p.type==="mcq" || p.type==="text"){
            studentText = escapeHtml(String(student));
          }else{
            studentText = need2 ? fmt2(student) : formatNumber(student);
          }
        }

        const correctText = (p.type==="mcq" || p.type==="text")
          ? escapeHtml(String(correctVal))
          : (need2 ? fmt2(correctVal) : formatNumber(correctVal));

        const ok = state.grading[qid] && state.grading[qid][bi] ? state.grading[qid][bi][p.key] : false;

        card += `
          <div class="partRow">
            <div><b>ط§ظ„ط¬ط²ط،:</b> ${escapeHtml(p.label||p.key||"")}</div>
            <div><b>ط¥ط¬ط§ط¨طھظƒ:</b> ${studentText}</div>
            <div><b>ط§ظ„طµط­ظٹط­:</b> ${correctText} <span class="tag ${ok?"good":"bad"}" style="margin-right:8px">${ok?"âœ“":"أ—"}</span></div>
          </div>
        `;
      });
    });

    card += `</div>`;
    return card;
  }).join("");

  const footer = `
    <div style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-start">
      <button class="btn primary" onclick="closeModal()">ط¥ط؛ظ„ط§ظ‚</button>
    </div>
  `;

  openModal("ط§ظ„ظ†طھظٹط¬ط©", `<div class="resultWrap">${header}${qCards}${footer}</div>`);
}


document.getElementById("nextBtnSide").onclick = next;
document.getElementById("showResultsBtn").onclick = tryShowResults;
document.getElementById("resetBtn").onclick = function(){ if(confirm("ظ‡ظ„ طھط±ظٹط¯ ط¥ط¹ط§ط¯ط© طھط¹ظٹظٹظ† ط§ظ„ط§ط®طھط¨ط§ط±طں ط³ظٹطھظ… ط­ط°ظپ ط¬ظ…ظٹط¹ ط§ظ„ط¥ط¬ط§ط¨ط§طھ.")) resetAll(); };
var _fsb=document.getElementById("fontSmallBtn"); if(_fsb) _fsb.onclick = ()=>{ state.fontSize = Math.max(-1, (state.fontSize||0)-1); saveState(); document.body.classList.remove("font-sm","font-lg"); if(state.fontSize===1) document.body.classList.add("font-lg"); else if(state.fontSize===-1) document.body.classList.add("font-sm"); };
var _fbb=document.getElementById("fontBigBtn"); if(_fbb) _fbb.onclick = ()=>{ state.fontSize = Math.min(1, (state.fontSize||0)+1); saveState(); document.body.classList.remove("font-sm","font-lg"); if(state.fontSize===1) document.body.classList.add("font-lg"); else if(state.fontSize===-1) document.body.classList.add("font-sm"); };
var _fsBtn=document.getElementById("fullscreenBtn"); if(_fsBtn) _fsBtn.onclick = function(){ if(!document.fullscreenElement){ document.documentElement.requestFullscreen().then(function(){ if(_fsBtn) _fsBtn.textContent = "\u062e\u0631\u0648\u062c"; }); } else { document.exitFullscreen(); if(_fsBtn) _fsBtn.textContent = "\u0645\u0644\u0621 \u0627\u0644\u0634\u0627\u0634\u0629"; } };
document.addEventListener("fullscreenchange", ()=>{ const btn = document.getElementById("fullscreenBtn"); if(btn) btn.textContent = document.fullscreenElement ? "ط®ط±ظˆط¬" : "ظ…ظ„ط، ط§ظ„ط´ط§ط´ط©"; });
["filterAllBtn","filterIncompleteBtn"].forEach(id=>{ const b = document.getElementById(id); if(b) b.onclick = ()=>{ state.sidebarFilter = b.getAttribute("data-filter"); saveState(); renderSidebar(); }; });
(function(){ const fs = state.fontSize; if(fs===1) document.body.classList.add("font-lg"); else if(fs===-1) document.body.classList.add("font-sm"); })();

function renderAll(){ renderMain(); renderSidebar(); setProgress(); }
window.addEventListener("load", ()=>{ window.__examRunning = isExamStarted(); renderAll(); if(window.__examRunning) startTimer(); else showIntroModal(); });/* Codex Adaptive Mastery Start */
(function(){
  const ADAPTIVE_STYLE_ID = "codex-adaptive-mastery-3_3";
  const MASTERY_VERSION = "chapter3_mastery_3_3_v2";
  const CORE_ORDER = ["33_sd_raw","33_range_raw","33_iqr"];
  const ALL_ORDER = ["33_sd_raw","33_sd_freq","33_sd_group","33_range_raw","33_range_group","33_iqr","33_choose","33_mcq"];
  const QUESTION_PROFILES = {"33_sd_raw":{"skills":["sd","variance","raw"],"remediation":["33_range_raw","33_mcq"],"advancement":["33_sd_freq"]},"33_sd_freq":{"skills":["sd","variance","frequency"],"remediation":["33_sd_raw"],"advancement":["33_sd_group"]},"33_sd_group":{"skills":["sd","grouped"],"remediation":["33_sd_freq"],"advancement":[]},"33_range_raw":{"skills":["range","raw"],"remediation":["33_mcq"],"advancement":["33_range_group"]},"33_range_group":{"skills":["range","grouped"],"remediation":["33_range_raw"],"advancement":[]},"33_iqr":{"skills":["iqr","quartile"],"remediation":["33_range_raw"],"advancement":["33_choose"]},"33_choose":{"skills":["measure-choice","dispersion"],"remediation":["33_sd_raw","33_iqr"],"advancement":[]},"33_mcq":{"skills":["concept","dispersion"],"remediation":["33_choose"],"advancement":[]}};
  const SUPPORT_LIMIT = 4;
  const READINESS_TO_ADVANCE = 0.74;
  const NEED_SUPPORT_BELOW = 0.62;
  const AI_ADAPTIVE_KEY = "stat102_3_3_ai_adaptive_v1";

  const originalBuildBank = buildBank;
  const originalRenderSidebar = renderSidebar;
  const originalRenderMain = renderMain;
  const originalSaveBranchAnswer = saveBranchAnswer;
  const originalNext = next;

  function injectAdaptiveStyles(){
    if(document.getElementById(ADAPTIVE_STYLE_ID)) return;
    const style = document.createElement("style");
    style.id = ADAPTIVE_STYLE_ID;
    style.textContent = `
      .side .head h3,
      .side .sidebar-filter,
      .side .qList{display:none !important;}
      #qCount[hidden]{display:none !important;}
      .side{display:grid;gap:14px;align-content:start;}
      .side .head{justify-content:space-between;}
      .branchBody{overflow-x:auto;-webkit-overflow-scrolling:touch;}
      .branchBody table.ftable,
      .branchBody table.niceTable{min-width:520px;max-width:none;}
      .branchBody table.ftable.wide,
      .branchBody table.niceTable.wide{min-width:680px;}
      table.ftable th, table.niceTable th{direction:rtl;}
      .modal .box{width:min(900px, calc(100vw - 40px)) !important;max-width:calc(100vw - 40px) !important;}
      @media (max-width: 720px){
        .wrap,.mainGrid,.layout,.pageGrid{grid-template-columns:1fr !important;max-width:100vw;overflow-x:hidden;}
        .aiResultsRail{order:-1;width:100%;max-width:100%;}
        .card,.main,.side,.aiModelsPanel{max-width:100%;}
        .qtitleRow,.mainhead,.part{align-items:stretch;}
        .part{flex-direction:column;}
        .part .inputWrap{width:100%;justify-content:stretch;}
        input[type="text"],input[type="number"],textarea,select{min-width:0;width:100%;max-width:100%;}
      }
      @media (max-width: 560px){
        .modal{align-items:flex-start !important;justify-content:flex-start !important;direction:ltr;padding:12px;overflow:auto;}
        .modal .box{direction:rtl;width:min(366px, calc(100vw - 24px)) !important;max-width:min(366px, calc(100vw - 24px)) !important;border-radius:16px;margin:10px 0;}
        .modal .box .mh{padding:14px;gap:10px;flex-direction:column-reverse;align-items:stretch;}
        .modal .box .mh b{text-align:center;}
        .modal .box .mh .btn{width:100%;justify-content:center;}
        .modal .box .mb{padding:16px 14px;max-height:none;overflow:visible;}
        .branchBody table.ftable,.branchBody table.niceTable{min-width:500px;}
      }
    `;
    document.head.appendChild(style);
  }

  function uniqueValid(ids){
    return (Array.isArray(ids) ? ids : []).filter((id, index, arr)=> id && ALL_ORDER.includes(id) && arr.indexOf(id) === index);
  }

  function topicKey(value){
    try{
      return String(value || "topic").toLowerCase().replace(/[^\p{L}\p{N}]+/gu, "_").replace(/^_+|_+$/g, "") || "topic";
    }catch(e){
      return String(value || "topic").toLowerCase().replace(/[^a-z0-9_]+/g, "_").replace(/^_+|_+$/g, "") || "topic";
    }
  }

  function loadAiState(){
    try{
      const raw = (typeof storageGet === "function") ? storageGet(AI_ADAPTIVE_KEY) : localStorage.getItem(AI_ADAPTIVE_KEY);
      if(!raw) return null;
      const parsed = JSON.parse(raw);
      return parsed && typeof parsed === "object" ? parsed : null;
    }catch(e){
      return null;
    }
  }

  function ensureSessionState(){
    const expected = uniqueValid(CORE_ORDER);
    const needsReset = state.masteryVersion !== MASTERY_VERSION || !Array.isArray(state.order) || !state.order.length;
    if(needsReset){
      state.order = expected.length ? expected.slice() : uniqueValid(ALL_ORDER).slice(0, 3);
      state.currentIndex = Math.min(state.currentIndex || 0, Math.max(0, state.order.length - 1));
      state.masteryVersion = MASTERY_VERSION;
      state.masterySupportCount = 0;
      saveState();
      return;
    }
    const cleaned = uniqueValid(state.order);
    if(cleaned.length !== state.order.length || cleaned.some((id, index)=> id !== state.order[index])){
      state.order = cleaned.length ? cleaned : expected.slice();
      state.currentIndex = Math.min(state.currentIndex || 0, Math.max(0, state.order.length - 1));
      saveState();
    }
    state.masterySupportCount = Number(state.masterySupportCount || 0);
  }

  function getActiveOrder(){
    ensureSessionState();
    const order = uniqueValid(state.order);
    if(order.length) return order;
    return uniqueValid(CORE_ORDER).length ? uniqueValid(CORE_ORDER) : uniqueValid(ALL_ORDER).slice(0, 3);
  }

  function buildQuestionsFromOrder(order){
    return uniqueValid(order).map((id)=>{
      const t = TEMPLATES.find((item)=> item.id === id);
      if(!t) return null;
      const variant = (typeof getVariant === "function") ? getVariant(t.id) : 0;
      const generated = t.gen(variant);
      return { id:t.id, title:t.title, icon:t.icon, branches:generated.branches };
    }).filter(Boolean);
  }

  function ensureAdaptiveBankReady(){
    const bank = buildQuestionsFromOrder(getActiveOrder());
    if(!bank.length) return originalBuildBank();
    if(state.currentIndex >= bank.length){
      state.currentIndex = Math.max(0, bank.length - 1);
      saveState();
    }
    return bank;
  }

  function getQuestionById(qid){
    return (BANK || []).find((item)=> item.id === qid) || buildQuestionsFromOrder([qid])[0] || null;
  }

  function profileFor(qid){
    return QUESTION_PROFILES[qid] || { skills:[], remediation:[], advancement:[] };
  }

  function getQuestionSignal(qid){
    const q = getQuestionById(qid);
    const profile = profileFor(qid);
    let attempts = 0;
    let status = "not_started";
    if(q){
      status = (typeof getQuestionStatus === "function") ? getQuestionStatus(q) : "not_started";
      (q.branches || []).forEach((branch, bi)=>{
        attempts += (typeof _getSaveAttempt === "function") ? (_getSaveAttempt(qid, bi) || 0) : 0;
      });
    }

    const correct = status === "completed_correct";
    const wrong = status === "completed_wrong";
    const baseReadiness = correct ? (attempts <= 1 ? 0.9 : 0.78) : (wrong ? 0.25 : (attempts ? 0.42 : 0.52));
    let readiness = baseReadiness;
    let struggle = wrong ? 0.82 : (attempts ? 0.5 : 0.25);

    const ai = loadAiState();
    const model = ai && ai.topics ? ai.topics[topicKey(qid)] : null;
    if(model){
      const modelScore = Number(model.ensemble ?? model.lastProb ?? model.mastery ?? readiness);
      const modelWeak = Number(model.nbWeak ?? (1 - modelScore));
      if(isFinite(modelScore)) readiness = Math.max(0.05, Math.min(0.98, (readiness * 0.55) + (modelScore * 0.45)));
      if(isFinite(modelWeak)) struggle = Math.max(0.02, Math.min(0.98, (struggle * 0.45) + (modelWeak * 0.55)));
    }

    return { qid, status, attempts, readiness, struggle, skills:profile.skills || [], mastered: correct && readiness >= READINESS_TO_ADVANCE };
  }

  function isDoneId(qid){
    const q = getQuestionById(qid);
    return q ? isQuestionDone(q) : false;
  }

  function overlapScore(a, b){
    const set = new Set(a || []);
    return (b || []).reduce((sum, item)=> sum + (set.has(item) ? 1 : 0), 0);
  }

  function candidateSupportIds(sourceId){
    const active = getActiveOrder();
    const used = new Set(active);
    const profile = profileFor(sourceId);
    const related = ALL_ORDER
      .filter((id)=> !used.has(id))
      .map((id)=>({ id, score:overlapScore(profile.skills || [], profileFor(id).skills || []) }))
      .filter((item)=> item.score > 0)
      .sort((a,b)=> b.score - a.score)
      .map((item)=> item.id);
    return uniqueValid([...(profile.remediation || []), ...related, ...(profile.advancement || []), ...ALL_ORDER]).filter((id)=> !used.has(id));
  }

  function appendSupportQuestion(sourceId){
    ensureSessionState();
    if(Number(state.masterySupportCount || 0) >= SUPPORT_LIMIT) return null;
    const nextId = candidateSupportIds(sourceId)[0];
    if(!nextId) return null;
    state.order = uniqueValid([ ...getActiveOrder(), nextId ]);
    state.masterySupportCount = Number(state.masterySupportCount || 0) + 1;
    saveState();
    return nextId;
  }

  function chooseNextAdaptiveId(currentId){
    BANK = ensureAdaptiveBankReady();
    const order = getActiveOrder();
    const currentIndex = order.indexOf(currentId);
    const afterCurrent = order.slice(Math.max(0, currentIndex + 1)).find((id)=> !isDoneId(id));
    if(afterCurrent) return afterCurrent;

    const beforeCurrent = order.slice(0, Math.max(0, currentIndex + 1)).find((id)=> !isDoneId(id));
    if(beforeCurrent) return beforeCurrent;

    const signals = order.map(getQuestionSignal);
    const weak = signals.filter((item)=> item.status !== "completed_correct" || item.readiness < NEED_SUPPORT_BELOW)
      .sort((a,b)=> (b.struggle - a.struggle) || (a.readiness - b.readiness))[0];
    if(weak){
      return appendSupportQuestion(weak.qid);
    }

    return null;
  }

  buildBank = function(){
    return ensureAdaptiveBankReady();
  };

  renderSidebar = function(){
    injectAdaptiveStyles();
    BANK = ensureAdaptiveBankReady();
    return originalRenderSidebar.apply(this, arguments);
  };

  renderMain = function(){
    injectAdaptiveStyles();
    BANK = ensureAdaptiveBankReady();
    return originalRenderMain.apply(this, arguments);
  };

  saveBranchAnswer = function(q, b, bi, branchCard, saveBtn){
    const qid = q && q.id;
    const beforeAttempts = qid && (typeof _getSaveAttempt === "function") ? (_getSaveAttempt(qid, bi) || 0) : 0;
    const beforeOutcome = qid && (typeof _getOutcome === "function") ? _getOutcome(qid, bi) : null;
    const result = originalSaveBranchAnswer.apply(this, arguments);
    try{
      if(!qid || !window.__examRunning) return result;
      const afterAttempts = (typeof _getSaveAttempt === "function") ? (_getSaveAttempt(qid, bi) || 0) : beforeAttempts;
      const afterOutcome = (typeof _getOutcome === "function") ? _getOutcome(qid, bi) : beforeOutcome;
      const changed = afterAttempts !== beforeAttempts || afterOutcome !== beforeOutcome;
      if(changed){
        const signal = getQuestionSignal(qid);
        if(afterOutcome !== "correct" && (afterAttempts > beforeAttempts || signal.status === "completed_wrong" || signal.readiness < NEED_SUPPORT_BELOW || signal.struggle > 0.5)){
          appendSupportQuestion(qid);
          BANK = ensureAdaptiveBankReady();
        }
        setProgress();
        renderSidebar();
      }
    }catch(e){}
    return result;
  };

  next = function(){
    if(!window.__examRunning){
      return originalNext.apply(this, arguments);
    }
    BANK = ensureAdaptiveBankReady();
    const current = BANK[state.currentIndex];
    const nextId = chooseNextAdaptiveId(current ? current.id : null);
    if(nextId){
      BANK = ensureAdaptiveBankReady();
      const nextIndex = BANK.findIndex((item)=> item.id === nextId);
      if(nextIndex >= 0){
        state.currentIndex = nextIndex;
        saveState();
        renderAll();
        return;
      }
    }
    tryShowResults();
  };

  injectAdaptiveStyles();
  ensureSessionState();
  BANK = ensureAdaptiveBankReady();
})();
/* Codex Adaptive Mastery End */



/* Codex Unified AI Logic Start */
(function(){
  function aiEscape(value){
    return value == null ? "" : String(value);
  }

  function aiLatex(value){
    const text = aiEscape(value);
    return typeof latexFix === "function" ? latexFix(text) : text;
  }

  function aiLevel(branch){
    return aiEscape(branch && (branch.level ?? branch.difficulty ?? branch.name ?? "")).trim();
  }

  function aiList(items, fallback){
    const values = Array.isArray(items) ? items.filter(Boolean) : [];
    if(!values.length){
      return `<div class="ai-help-note">${fallback}</div>`;
    }
    return `<ul>${values.map((item) => `<li>${escapeHtml(aiLatex(item))}</li>`).join("")}</ul>`;
  }

  function ensureAiAssistModal(){
    let modal = document.getElementById("aiAssistModal");
    if(modal){
      return modal;
    }

    modal = document.createElement("div");
    modal.id = "aiAssistModal";
    modal.className = "ai-assist-modal";
    modal.setAttribute("aria-hidden", "true");
    modal.innerHTML = `
      <div class="ai-assist-shell" role="dialog" aria-modal="true" aria-labelledby="aiAssistLabel">
        <div class="ai-assist-topbar">
          <button class="btn small ai-assist-close" type="button" id="aiAssistCloseBtn">ط¥ط؛ظ„ط§ظ‚</button>
          <div class="ai-assist-topbar-title" id="aiAssistLabel">ظ…ط³ط§ط¹ط¯ط©</div>
        </div>
        <div class="ai-assist-body" id="aiAssistBody"></div>
      </div>
    `;

    modal.addEventListener("click", (event) => {
      if(event.target === modal){
        closeUnifiedAiHelp();
      }
    });

    document.body.appendChild(modal);

    const closeBtn = modal.querySelector("#aiAssistCloseBtn");
    if(closeBtn){
      closeBtn.onclick = closeUnifiedAiHelp;
    }

    return modal;
  }

  function closeUnifiedAiHelp(){
    const modal = document.getElementById("aiAssistModal");
    if(modal){
      modal.classList.remove("show");
      modal.setAttribute("aria-hidden", "true");
    }
    document.body.classList.remove("ai-assist-open");
  }


  function aiSafeTitle(question){
    return String((question && question.title) || "");
  }

  function aiHintItems(question, branch){
    const qid = question && question.id ? String(question.id) : "";
    const title = aiSafeTitle(question);
    const prompt = aiEscape((branch && branch.promptHtml) || "").replace(/<[^>]*>/g, " ");
    /* Codex prompt-aware safe hints */
    const lower = title.toLowerCase();
    const hints = {
      q1_mean_raw: ["ط­ط¯ظ‘ط¯ ط¹ط¯ط¯ ط§ظ„ظ‚ظٹظ… ط£ظˆظ„ط§ ط«ظ… ط§ط¬ظ…ط¹ظ‡ط§ ط¯ظˆظ† ط§ظ„ظ‚ظپط² ظ„ظ„ظ†طھظٹط¬ط©.", "ط§ظ†طھط¨ظ‡ ط¥ظ„ظ‰ ط£ظ† ط§ظ„ظ…طھظˆط³ط· ظٹط¹طھظ…ط¯ ط¹ظ„ظ‰ ظƒظ„ ط§ظ„ظ‚ظٹظ…."],
      q2_mean_freq: ["طھط¹ط§ظ…ظ„ ظ…ط¹ ظƒظ„ ظ‚ظٹظ…ط© ظ…ظƒط±ط±ط© ط¨ط¹ط¯ط¯ طھظƒط±ط§ط±ظ‡ط§.", "ط§ط¨ط¯ط£ ط¨ط¹ظ…ظˆط¯ظٹ ط­ط§طµظ„ ط§ظ„ط¶ط±ط¨ ظˆط§ظ„ظ…ط¬ظ…ظˆط¹ ط§ظ„ظƒظ„ظٹ ظ„ظ„طھظƒط±ط§ط±ط§طھ."],

<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ط¬ط§ظ…ط¹ط© ط§ظ„ظ…ظ„ظƒ ط³ط¹ظˆط¯ â€” ط§ظ„ط³ظ†ط© ط§ظ„ط£ظˆظ„ظ‰ ط§ظ„ظ…ط´طھط±ظƒط© â€” STAT 102 | 3.3 ظ…ظ‚ط§ظٹظٹط³ ط§ظ„طھط´طھطھ</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Symbols+2&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#f8fafc;
      --bg-warm:#fefefe;
      --card:#ffffff;
      --ink:#0f172a;
      --ink-soft:#1e293b;
      --muted:#64748b;
      --brand:#0369a1;
      --brand2:#0c4a6e;
      --brand-light:#e0f2fe;
      --accent:#0284c7;
      --good:#059669;
      --good-bg:#d1fae5;
      --bad:#dc2626;
      --bad-bg:#fee2e2;
      --warn:#d97706;
      --warn-bg:#fef3c7;
      --line:#e2e8f0;
      --line-soft:#f1f5f9;
      --shadow-sm: 0 1px 3px rgba(15,23,42,.06);
      --shadow: 0 4px 20px rgba(15,23,42,.07);
      --shadow-lg: 0 20px 50px rgba(15,23,42,.1);
      --r:16px;
      --r-lg:22px;
      --font:"Cairo", "Noto Sans Symbols 2", system-ui, sans-serif;
      --transition: .2s cubic-bezier(.4,0,.2,1);
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:var(--font);
      color:var(--ink);
      line-height:1.6;
      background:
        radial-gradient(ellipse 140% 80% at 90% 0%, rgba(3,105,161,.06), transparent 50%),
        radial-gradient(ellipse 100% 60% at 10% 100%, rgba(12,74,110,.04), transparent 45%),
        var(--bg);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .topbar{
      background: linear-gradient(135deg, var(--brand2) 0%, var(--brand) 50%, #0e7490 100%);
      color:#fff;
      padding:16px 14px;
      min-height:80px;
      position:sticky; top:0; z-index:10;
      box-shadow: var(--shadow-lg);
    }
    .topbar .row{
      max-width:1280px;
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      position:relative;
      gap:16px;
      padding:12px 80px;
      min-height:56px;
    }
    .topbar .row .topbarRight{display:flex; align-items:center; gap:8px; flex:0 0 auto;}
    .topbar .row .timerBar{flex:0 0 auto;}
    .topbar .row .brandblock{position:absolute; left:50%; transform:translateX(-50%); display:flex; align-items:center; justify-content:center; gap:14px; min-width:0; max-width:55%; text-align:center;}
    .topbar .row .logoWrap{flex:0 0 auto;}
    .brandblock{display:flex; align-items:center; gap:14px; min-width:0; text-align:center;}
    .brandtext{min-width:0; text-align:center}
    .brandtext .u{font-size:19px;font-weight:800;letter-spacing:-.02em;line-height:1.2}
    .brandtext .u.en{font-size:13px;font-weight:700;opacity:.9;margin-top:2px;direction:ltr;unicode-bidi:embed}
    .sep{opacity:.6;margin:0 6px;font-weight:600;font-size:12px}
    .brandtext .d{font-size:13px;font-weight:700;opacity:.92;margin-top:2px;line-height:1.3}
    .brandtext .s{font-size:12px;opacity:.85;margin-top:2px;font-weight:600}

    .timerBar{font-size:14px;font-weight:800;white-space:nowrap;padding:6px 12px;background:rgba(255,255,255,.2);border-radius:10px;border:1px solid rgba(255,255,255,.35);min-width:90px;text-align:center;}
    .timerBar.warn{background:rgba(217,119,6,.4);border-color:rgba(255,255,255,.5);}
    .timerBar.done{background:rgba(220,38,38,.4);border-color:rgba(255,255,255,.5);}

    .logoWrap{
      position:absolute;
      left:14px;
      top:50%;
      transform:translateY(-50%);
      display:flex; align-items:center; justify-content:center;
      padding:10px 12px;
      background: rgba(255,255,255,.18);
      border:1px solid rgba(255,255,255,.35);
      border-radius:12px;
      box-shadow: 0 8px 20px rgba(0,0,0,.2);
      flex:0 0 auto;
      transition: var(--transition);
    }
    .logoWrap:hover{background:rgba(255,255,255,.25);transform:translateY(-50%) scale(1.02)}
    .logoWrap img{height:52px;width:auto;display:block;}
    .logoWrap .textLogo{height:52px;min-width:52px;padding:0 10px;border-radius:12px;display:grid;place-items:center;font-size:18px;font-weight:900;letter-spacing:.06em;color:#fff;}

    .wrap{
      max-width:900px;
      margin:24px auto 40px;
      padding:0 24px;
      display:block;
    }
    @media (min-width:1100px){
      .wrap{ max-width:calc(66.666vw); }
    }
    @media (max-width: 820px){ .wrap{ max-width:100%; padding:0 12px; } }
    /* ط¥ط®ظپط§ط، ط§ظ„ظ„ظˆط­ط§طھ ط§ظ„ط¬ط§ظ†ط¨ظٹط© ظ…ظ† ط§ظ„ط´ط¨ظƒط© â€“ ط³طھظڈط¹ط±ط¶ ظƒط¯ط±ط¬ ط¹ط§ط¦ظ… */
    .side, .aiResultsRail { display:none !important; }

    .card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--r-lg);
      box-shadow: var(--shadow);
      overflow:hidden;
      transition: var(--transition);
    }
    .card:hover{box-shadow: 0 8px 30px rgba(15,23,42,.09)}
    .mainhead{
      padding:12px 16px;
      border-bottom:1px solid var(--line);
      display:flex; gap:10px; align-items:center; justify-content:center;
      background: linear-gradient(180deg, var(--line-soft) 0%, var(--card) 100%);
    }
    .pill{
      background:var(--brand-light);color:var(--brand);border:1px solid rgba(3,105,161,.25);
      border-radius:999px;padding:6px 12px;font-weight:700;font-size:12px;white-space:nowrap;
    }
    .pill.warn{background:var(--warn-bg);color:var(--warn);border-color:rgba(217,119,6,.3)}
    .content{padding:20px 22px 24px}

    .qtitleRow{display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:16px; flex-wrap:wrap;}
    .qtitle{display:flex; align-items:center; gap:12px; font-size:17px; font-weight:800; color:var(--ink); min-width:0;}
    .qtitle .qnum{
      width:42px;height:42px;border-radius:12px;display:grid;place-items:center;
      background: linear-gradient(135deg, var(--brand-light), #bae6fd);
      border:1px solid rgba(3,105,161,.2);color:var(--brand);font-weight:800;flex:0 0 auto;
      font-size:16px;
    }
    .qmeta{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}

    .btn{
      border:1px solid var(--line);
      background:var(--card);
      color:var(--ink);
      border-radius:12px;
      padding:10px 16px;
      font-weight:800;
      font-size:14px;
      cursor:pointer;
      transition: var(--transition);
      display:inline-flex; align-items:center; gap:8px;
      user-select:none;
      white-space:nowrap;
      font-family:var(--font);
    }
    .btn:hover{
      background:var(--line-soft);
      border-color:var(--muted);
      transform:translateY(-1px);
      box-shadow: var(--shadow-sm);
    }
    .btn.primary{
      background: linear-gradient(135deg, var(--brand), var(--brand2));
      border-color: transparent;
      color:#fff;
    }
    .btn.primary:hover{
      background: linear-gradient(135deg, var(--accent), var(--brand));
      box-shadow: 0 4px 16px rgba(3,105,161,.35);
    }
    .btn.small{padding:8px 14px;font-size:13px;border-radius:10px}
    .btn:disabled{cursor:not-allowed;opacity:.55;transform:none;box-shadow:none}
        .btn.ai-help-btn{
      position:relative;
      isolation:isolate;
      border:1px solid rgba(8,145,178,.34);
      background:
        linear-gradient(135deg, rgba(224,242,254,.98) 0%, rgba(240,249,255,.98) 52%, rgba(207,250,254,.98) 100%);
      color:var(--brand2);
      font-weight:900;
      overflow:hidden;
      box-shadow:0 10px 24px rgba(8,145,178,.16);
    }
    .btn.ai-help-btn::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(115deg, transparent 0 28%, rgba(255,255,255,.78) 45%, transparent 62%),
        repeating-linear-gradient(90deg, rgba(14,165,233,.09) 0 1px, transparent 1px 12px);
      opacity:.9;
      transform:translateX(-26%);
      transition:transform .45s ease;
      z-index:-1;
    }
    .btn.ai-help-btn::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:inherit;
      pointer-events:none;
      box-shadow:0 0 0 0 rgba(8,145,178,.28);
      animation:aiPulse 2.4s infinite;
    }
    .btn.ai-help-btn:hover{
      border-color:#0891b2;
      background:linear-gradient(135deg, #dbeafe 0%, #e0f7ff 48%, #ccfbf1 100%);
      box-shadow:0 14px 28px rgba(8,145,178,.24);
      transform:translateY(-2px) scale(1.01);
    }
    .btn.ai-help-btn:hover::before{transform:translateX(6%)}
    .btn.ai-help-btn:hover .ai-help-glyph{animation:aiWake .9s ease both}
    .ai-help-glyph{
      width:22px;
      height:22px;
      border-radius:8px;
      display:inline-grid;
      place-items:center;
      position:relative;
      background:linear-gradient(135deg, #0f172a, #0369a1 72%, #22d3ee 100%);
      color:#fff;
      font-size:11px;
      font-weight:900;
      letter-spacing:.04em;
      box-shadow:0 6px 16px rgba(3,105,161,.28);
    }
    .ai-help-glyph::before,
    .ai-help-glyph::after{
      content:"";
      position:absolute;
    }
    .ai-help-glyph::before{
      inset:3px;
      border:1.5px solid rgba(255,255,255,.72);
      border-radius:4px;
      opacity:.88;
    }
    .ai-help-glyph::after{
      width:6px;
      height:6px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 0 2px rgba(255,255,255,.18), 0 0 14px rgba(103,232,249,.9);
    }
    .ai-help-panel{
      display:grid;
      gap:16px;
      animation:aiPanelReveal .38s ease both;
    }
    .ai-help-hero{
      position:relative;
      animation:aiHeroFloat 5.2s ease-in-out infinite;
      overflow:hidden;
      display:flex;
      align-items:center;
      gap:16px;
      padding:18px;
      border-radius:18px;
      border:1px solid rgba(8,145,178,.22);
      background:
        radial-gradient(circle at 18% 22%, rgba(34,211,238,.24), transparent 28%),
        radial-gradient(circle at 88% 18%, rgba(59,130,246,.18), transparent 24%),
        linear-gradient(135deg, #082f49 0%, #0f172a 48%, #0c4a6e 100%);
      color:#fff;
      box-shadow:0 18px 40px rgba(15,23,42,.18);
    }
    .ai-help-hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:repeating-linear-gradient(90deg, rgba(255,255,255,.06) 0 1px, transparent 1px 16px);
      opacity:.35;
      pointer-events:none;
    }
    .ai-help-orb{
      width:72px;
      height:72px;
      border-radius:22px;
      flex:0 0 auto;
      display:grid;
      place-items:center;
      position:relative;
      border:1px solid rgba(255,255,255,.2);
      background:linear-gradient(135deg, rgba(255,255,255,.2), rgba(255,255,255,.08));
      box-shadow:inset 0 1px 0 rgba(255,255,255,.18), 0 14px 28px rgba(8,145,178,.22);
    }
    .ai-help-orb::before,
    .ai-help-orb::after{
      content:"";
      position:absolute;
      border-radius:50%;
      border:1px solid rgba(103,232,249,.55);
    }
    .ai-help-orb::before{inset:10px}
    .ai-help-orb::after{inset:20px;border-color:rgba(255,255,255,.65)}
    .ai-help-orb span{
      width:14px;
      height:14px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 18px rgba(103,232,249,.95);
      animation:aiCorePulse 2.8s ease-in-out infinite;
    }
    .ai-help-copy{position:relative;z-index:1;display:grid;gap:6px}
    .ai-help-kicker{
      display:inline-flex;
      align-items:center;
      gap:8px;
      width:max-content;
      padding:5px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.16);
      font-size:11px;
      font-weight:800;
      letter-spacing:.08em;
    }
    .ai-help-kicker::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 10px rgba(103,232,249,.9);
    }
    .ai-help-title{
      font-size:18px;
      font-weight:900;
      line-height:1.5;
    }
    .ai-help-subtitle{
      color:rgba(255,255,255,.82);
      font-size:13px;
      font-weight:700;
      line-height:1.9;
    }
    .ai-help-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:14px;
    }
    .ai-help-section{
      position:relative;
      overflow:hidden;
      border:1px solid rgba(148,163,184,.24);
      border-radius:16px;
      padding:16px;
      background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      box-shadow:0 10px 28px rgba(15,23,42,.07);
    }
    .ai-help-section::before{
      content:"";
      position:absolute;
      inset:0 auto 0 0;
      width:4px;
      background:linear-gradient(180deg, #22d3ee, #0369a1);
    }
    .ai-help-section-head{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:10px;
      font-size:15px;
      font-weight:900;
      color:var(--ink);
    }
    .ai-help-chip-icon{
      width:34px;
      height:34px;
      border-radius:11px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg, rgba(8,145,178,.16), rgba(14,165,233,.08));
      color:var(--brand2);
      border:1px solid rgba(8,145,178,.2);
      font-size:16px;
    }
    .ai-help-body{
      color:var(--ink-soft);
      font-size:14px;
      font-weight:700;
      line-height:1.95;
    }
    .ai-help-body ul,
    .ai-help-body ol{margin:0;padding-right:18px}
    @media (max-width: 720px){
      .ai-help-hero{flex-direction:column;align-items:flex-start;padding:16px}
      .ai-help-grid{grid-template-columns:1fr}
      .ai-help-orb{width:64px;height:64px;border-radius:18px}
    }
    @keyframes aiPulse{0%{box-shadow:0 0 0 0 rgba(8,145,178,.28)}70%{box-shadow:0 0 0 10px rgba(8,145,178,0)}100%{box-shadow:0 0 0 0 rgba(8,145,178,0)}}
    @keyframes aiWake{0%{transform:scale(1) rotate(0)}35%{transform:scale(1.08) rotate(-8deg)}70%{transform:scale(.96) rotate(8deg)}100%{transform:scale(1) rotate(0)}}
    @keyframes aiCorePulse{0%,100%{transform:scale(.92);box-shadow:0 0 14px rgba(103,232,249,.72)}50%{transform:scale(1.14);box-shadow:0 0 26px rgba(103,232,249,.98)}}
    @keyframes aiHeroFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
    @keyframes aiPanelReveal{0%{opacity:0;transform:translateY(8px) scale(.985)}100%{opacity:1;transform:translateY(0) scale(1)}}
    button:focus, .btn:focus{outline:none}
    button:focus-visible, .btn:focus-visible, a:focus-visible{outline:2px solid var(--accent);outline-offset:2px}

    .branches{display:grid; gap:16px;}
    .branch{border:1px solid var(--line); border-radius:16px; background:var(--card); overflow:hidden; transition: var(--transition);}
    .branch:hover{border-color:var(--line);box-shadow: var(--shadow-sm)}
    .branchHead{
      display:flex; align-items:center; justify-content:flex-end; gap:12px;
      padding:14px 16px;
      background: linear-gradient(180deg, var(--line-soft), var(--card));
      border-bottom:1px solid var(--line);
    }
    .btag{font-size:12px;padding:6px 12px;border-radius:10px;font-weight:800;border:1px solid;white-space:nowrap;}
    .btag.easy{background:var(--good-bg);border-color:rgba(5,150,105,.25);color:var(--good)}
    .btag.med{background:var(--warn-bg);border-color:rgba(217,119,6,.25);color:var(--warn)}
    .btag.hard{background:var(--bad-bg);border-color:rgba(220,38,38,.25);color:var(--bad)}
    .branchBody{padding:16px 18px 18px; line-height:1.85; font-size:15px; font-weight:600; color:var(--ink-soft)}

    .parts{display:grid; gap:12px; margin-top:16px;}
    .part{
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px 16px;
      display:flex;
      gap:14px;
      align-items:center;
      justify-content:center;
      background: var(--bg-warm);
    }
    .part .label{font-weight:800;color:var(--ink);line-height:1.5;min-width:0;font-size:14px}
    .part .inputWrap{display:flex; gap:10px; align-items:center; justify-content:flex-end; flex:0 0 auto;}
    input[type="text"], input[type="number"], textarea, select{
      border:2px solid var(--line);
      border-radius:12px;
      padding:12px 14px;
      font-size:15px;
      min-width:180px;
      outline:none;
      transition: var(--transition);
      background:var(--card);
      font-family:var(--font);
      font-weight:700;
      color:var(--ink);
    }
    textarea{min-width:260px; min-height:90px; resize:vertical}
    input:focus, textarea:focus, select:focus{
      border-color:var(--brand);
      box-shadow: 0 0 0 3px rgba(3,105,161,.15);
    }
    .branchBtns{display:flex; gap:10px; flex-wrap:wrap; margin-top:14px; justify-content:flex-start}

    .side{padding:20px;}
    .side .head{display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:14px;}
    .side .head h3{margin:0; font-size:18px; font-weight:900; color:var(--ink);}
    .progress{height:12px;background:var(--line);border-radius:999px;overflow:hidden;}
    .progress > div{height:100%;width:0%;background:linear-gradient(90deg,var(--accent),var(--brand));border-radius:999px;transition:.4s width ease-out;}
    .qList{margin-top:14px;display:flex;flex-direction:column;gap:10px;}
    .qItem{
      border:2px solid var(--line);
      border-radius:14px;
      padding:12px 14px;
      display:flex; align-items:center; gap:12px;
      background:var(--card);
      cursor:pointer;
      transition: var(--transition);
    }
    .qItem:hover{
      border-color:var(--brand);
      transform:translateX(-2px);
      box-shadow: var(--shadow-sm);
    }
    .qItem.active{border-color:var(--brand); background:var(--brand-light); box-shadow: 0 0 0 2px rgba(3,105,161,.2)}
    .qItem .left{display:flex; align-items:center; gap:12px; min-width:0;}
    .dot{width:10px;height:10px;border-radius:50%;background:var(--muted); flex-shrink:0;}
    .dot.done{background:var(--good)}
    .dot.bad{background:var(--bad)}
    .qItem .name{font-weight:800;line-height:1.3;min-width:0;font-size:13px; color:var(--ink)}
    .icon{
      width:38px;height:38px;border-radius:12px;
      display:grid;place-items:center;
      background: var(--brand-light);
      border:1px solid rgba(3,105,161,.2);
      color:var(--brand);
      font-weight:900;
      flex:0 0 auto;
      font-size:15px;
    }
    .badge{
      font-size:11px;
      padding:5px 10px;
      border-radius:8px;
      font-weight:800;
      border:1px solid;
      white-space:nowrap;
    }
    .badge.warn{background:var(--warn-bg);border-color:rgba(217,119,6,.3);color:var(--warn)}
    .badge.good{background:var(--good-bg);border-color:rgba(5,150,105,.3);color:var(--good)}

    .resultWrap{padding:20px;}
    .scoreCard{
      border:2px solid var(--line);
      border-radius:18px;
      padding:20px;
      background: linear-gradient(180deg, var(--line-soft), var(--card));
      box-shadow: var(--shadow-sm);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      margin-bottom:16px;
    }
    .scoreBig{font-size:20px;font-weight:900;color:var(--ink)}
    .scoreSub{font-size:13px;font-weight:600;color:var(--muted);margin-top:4px}
    .resultCard{border:1px solid var(--line);border-radius:16px;background:var(--card);padding:16px;margin-top:14px; transition: var(--transition);}
    .resultCard:hover{border-color:var(--line); box-shadow: var(--shadow-sm)}
    .resultCard .rt{display:flex; align-items:center; justify-content:center; gap:10px; flex-wrap:wrap; margin-bottom:8px;}
    .tag{font-size:12px;padding:6px 12px;border-radius:10px;font-weight:800;border:1px solid;}
    .tag.good{background:var(--good-bg);border-color:rgba(5,150,105,.3);color:var(--good)}
    .tag.bad{background:var(--bad-bg);border-color:rgba(220,38,38,.3);color:var(--bad)}
    .partRow{
      display:grid;
      grid-template-columns: 1.15fr .9fr .95fr;
      gap:12px;
      padding:12px 14px;
      border-radius:12px;
      border:1px solid var(--line);
      background:var(--bg-warm);
      margin-top:10px;
      font-size:13px;
      font-weight:600;
    }
    .partRow b{font-weight:800}
    .partRow:first-of-type{border-top:none; margin-top:0; padding-top:0}

    .modal{position:fixed;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;padding:20px;z-index:100;}
    .modal.show{display:flex;animation:modalFadeIn .2s ease}
    @keyframes modalFadeIn{from{opacity:0}to{opacity:1}}
    .modal .box{width:min(900px, 100%);background:var(--card);border-radius:20px;border:1px solid var(--line);box-shadow: var(--shadow-lg);overflow:hidden;animation:modalSlide .25s ease;}
    @keyframes modalSlide{from{transform:scale(.96);opacity:0}to{transform:scale(1);opacity:1}}
    .modal .box .mh{padding:18px 20px;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;background:var(--line-soft);}
    .modal .box .mh b{font-size:16px;font-weight:800;color:var(--ink)}
    .modal .box .mb{padding:20px 22px;color:var(--ink-soft);line-height:1.9;max-height:70vh;overflow:auto;}

    table.ftable{
      width:100%;
      border-collapse:collapse;
      overflow:hidden;
      border-radius:14px;
      border:1px solid var(--line);
      background:var(--card);
      margin-top:14px;
      direction:ltr;
      box-shadow: var(--shadow-sm);
    }
    .ftable th{
      background: linear-gradient(135deg, var(--brand), var(--brand2));
      color:#fff;
      padding:12px 10px;
      font-size:13px;
      font-weight:800;
      border:1px solid rgba(255,255,255,.15);
      text-align:center;
      white-space:nowrap;
    }
    .ftable td{
      border:1px solid var(--line);
      padding:12px 10px;
      text-align:center;
      font-weight:700;
      color:var(--ink);
      font-size:13px;
      background:var(--card);
    }
    .ftable tr:nth-child(even) td{background:var(--bg-warm)}
    .cellInput{
      width:100%;
      min-width:unset;
      padding:10px 12px;
      border-radius:10px;
      border:2px solid var(--line);
      background:var(--card);
      font-weight:700;
      text-align:center;
      font-family:var(--font);
    }

    /* --- 3.1 specific: Math, method panel, niceTable, inline inputs, feedback --- */
.mathInline{direction:ltr; unicode-bidi:embed; display:inline-block;}
.mathBlock{direction:ltr; unicode-bidi:embed;}
.katex,.katex-display{direction:ltr; unicode-bidi:embed;}
.katex{font-size:1.06em}

.methodHead{font-weight:900;margin-bottom:10px}
.methodList{margin:0;padding-right:18px;line-height:2}
.methodLine{direction:rtl;unicode-bidi:isolate}
.methodLine .mathInline{direction:ltr;unicode-bidi:embed}

.niceTable{width:100%;border-collapse:separate;border-spacing:0;direction:ltr}
.niceTable th,.niceTable td{padding:12px 12px;border-bottom:1px solid var(--line);text-align:center}
.niceTable thead th{background:var(--brand-light);font-weight:900}
.niceTable tbody tr:last-child td{border-bottom:none}

input.inlineInput, textarea.inlineInput{
  min-width:92px !important;
  width:92px !important;
  padding:10px 10px !important;
  border:2px solid var(--line) !important;
  background:var(--card) !important;
  text-align:center;
}
.ltr{direction:ltr; unicode-bidi:embed; display:inline-block;}
.hint{margin-top:8px;font-size:13px;color:var(--muted);font-weight:800}
select option{direction:ltr;unicode-bidi:embed;}

table.ftable, table.niceTable{ direction:ltr; }
table.ftable th, table.ftable td, table.niceTable th, table.niceTable td{ text-align:center; }
table.ftable th, table.niceTable th{ white-space:nowrap; }

input.is-wrong, textarea.is-wrong, select.is-wrong{
  border-color:var(--bad) !important;
  box-shadow:0 0 0 4px rgba(220,38,38,.12) !important;
  background:var(--card) !important;
}
input.is-wrong-strong, textarea.is-wrong-strong, select.is-wrong-strong{
  border-color:var(--bad) !important;
  box-shadow:0 0 0 4px rgba(220,38,38,.12) !important;
  background:var(--bad-bg) !important;
}
input.is-right, textarea.is-right, select.is-right{
  border-color:var(--good) !important;
  box-shadow:0 0 0 4px rgba(5,150,105,.15) !important;
}

.katex,.katex-display,.mathInline,.mathBlock{direction:ltr;unicode-bidi:embed;}
.mathInline{display:inline-block;}
.mathBlock{display:block;}
.katex-display{overflow-x:auto; overflow-y:hidden;}
.rtlText{ direction:rtl; unicode-bidi:plaintext; }
  body.font-sm{ font-size: 90%; }
  body.font-lg{ font-size: 110%; }
  .unsaved-dot{ width:8px;height:8px;border-radius:50%;background:var(--warn);flex-shrink:0; }
  .sidebar-filter{ display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap; }
  .score-bar-wrap{ height:12px;background:var(--line);border-radius:999px;overflow:hidden;margin:10px 0;display:flex; }
  .score-bar-correct{ height:100%;background:linear-gradient(90deg,var(--good),var(--accent));border-radius:999px;transition:width .3s; }
  .score-bar-wrong{ height:100%;background:var(--line);border-radius:0 999px 999px 0; }
  @media print{ body * { visibility: hidden; } .modal.show, .modal.show * { visibility: visible; } .modal.show { position: fixed; inset: 0; background: #fff; z-index: 99999; } .modal .box { box-shadow: none; border: 1px solid #ccc; } }

/* Codex Unified AI Help Start */
    .branchHead{
      flex-wrap:wrap;
      align-items:center;
      gap:12px;
      justify-content:flex-start;
    }
    body.ai-assist-open{
      overflow:hidden;
    }
    .ai-assist-modal{
      position:fixed;
      inset:0;
      display:none;
      align-items:flex-start;
      justify-content:center;
      padding:22px;
      background:rgba(15,23,42,.34);
      backdrop-filter:blur(10px);
      -webkit-backdrop-filter:blur(10px);
      z-index:160;
    }
    .ai-assist-modal.show{
      display:flex;
      animation:modalFadeIn .22s ease;
    }
    .ai-assist-shell{
      width:min(1120px, 100%);
      background:linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
      border:1px solid #d7e7f4;
      border-radius:28px;
      box-shadow:0 28px 70px rgba(15,23,42,.22);
      overflow:hidden;
      animation:modalSlide .24s ease;
    }
    .ai-assist-topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:20px 24px;
      background:rgba(255,255,255,.96);
      border-bottom:1px solid #d7e7f4;
    }
    .ai-assist-topbar-title{
      font-size:18px;
      font-weight:900;
      color:#0f172a;
    }
    .ai-assist-close{
      min-width:92px;
      border-radius:14px;
      border-color:#d7e7f4;
      background:#fff;
      box-shadow:0 8px 18px rgba(15,23,42,.08);
    }
    .ai-assist-close:hover{
      background:#f8fbff;
      border-color:#bfdbfe;
    }
    .ai-assist-body{
      padding:18px 24px 24px;
      max-height:calc(100vh - 88px);
      overflow:auto;
      background:linear-gradient(180deg, #f3f8fd 0%, #ffffff 100%);
    }
    .btn.ai-help-btn{
      position:relative;
      isolation:isolate;
      border:1px solid rgba(3,105,161,.18);
      background:
        linear-gradient(135deg, #ffffff 0%, #f0f9ff 52%, #e0f2fe 100%);
      color:var(--brand2);
      font-weight:900;
      overflow:hidden;
      box-shadow:0 10px 24px rgba(3,105,161,.12);
    }
    .btn.ai-help-btn::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(115deg, transparent 0 28%, rgba(255,255,255,.78) 45%, transparent 62%),
        repeating-linear-gradient(90deg, rgba(14,165,233,.09) 0 1px, transparent 1px 14px);
      opacity:.92;
      transform:translateX(-26%);
      transition:transform .45s ease;
      z-index:-1;
    }
    .btn.ai-help-btn::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:inherit;
      pointer-events:none;
      box-shadow:0 0 0 0 rgba(14,165,233,.24);
      animation:aiPulse 2.4s infinite;
    }
    .btn.ai-help-btn:hover{
      border-color:rgba(3,105,161,.34);
      background:linear-gradient(135deg, #ffffff 0%, #e0f2fe 48%, #dbeafe 100%);
      box-shadow:0 14px 28px rgba(3,105,161,.18);
      transform:translateY(-2px);
    }
    .btn.ai-help-btn:hover::before{transform:translateX(6%)}
    .btn.ai-help-btn:hover .ai-help-glyph{animation:aiWake .9s ease both}
    .ai-help-inline-btn{
      order:-1;
      padding:8px 12px;
      min-height:40px;
      font-size:12px;
      border-radius:12px;
      box-shadow:0 8px 18px rgba(3,105,161,.14);
    }
    .ai-help-inline-btn .ai-help-glyph{
      width:20px;
      height:20px;
      border-radius:7px;
      font-size:10px;
    }
    .ai-help-glyph{
      width:22px;
      height:22px;
      border-radius:8px;
      display:inline-grid;
      place-items:center;
      position:relative;
      background:linear-gradient(135deg, #0f172a 0%, #0c4a6e 56%, #38bdf8 100%);
      color:#fff;
      font-size:11px;
      font-weight:900;
      letter-spacing:.04em;
      box-shadow:0 6px 16px rgba(3,105,161,.24);
    }
    .ai-help-glyph::before,
    .ai-help-glyph::after{
      content:"";
      position:absolute;
    }
    .ai-help-glyph::before{
      inset:3px;
      border:1.5px solid rgba(255,255,255,.72);
      border-radius:4px;
      opacity:.9;
    }
    .ai-help-glyph::after{
      width:6px;
      height:6px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 0 2px rgba(255,255,255,.18), 0 0 14px rgba(103,232,249,.9);
    }
    .ai-help-panel{
      display:grid;
      gap:18px;
      direction:rtl;
    }
    .ai-help-hero{
      position:relative;
      overflow:hidden;
      display:flex;
      align-items:center;
      gap:16px;
      padding:20px;
      border-radius:22px;
      border:1px solid rgba(14,165,233,.18);
      background:
        radial-gradient(circle at 18% 22%, rgba(56,189,248,.24), transparent 28%),
        radial-gradient(circle at 88% 18%, rgba(59,130,246,.18), transparent 24%),
        linear-gradient(135deg, #0b4f74 0%, #0f172a 48%, #0c4a6e 100%);
      color:#fff;
      box-shadow:0 18px 40px rgba(15,23,42,.18);
    }
    .ai-help-hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:repeating-linear-gradient(90deg, rgba(255,255,255,.06) 0 1px, transparent 1px 16px);
      opacity:.35;
      pointer-events:none;
    }
    .ai-help-orb{
      width:78px;
      height:78px;
      border-radius:24px;
      flex:0 0 auto;
      display:grid;
      place-items:center;
      position:relative;
      border:1px solid rgba(255,255,255,.24);
      background:linear-gradient(135deg, rgba(255,255,255,.22), rgba(255,255,255,.08));
      box-shadow:inset 0 1px 0 rgba(255,255,255,.18), 0 14px 28px rgba(8,145,178,.22);
    }
    .ai-help-orb::before,
    .ai-help-orb::after{
      content:"";
      position:absolute;
      border-radius:50%;
      border:1px solid rgba(103,232,249,.55);
    }
    .ai-help-orb::before{inset:11px}
    .ai-help-orb::after{
      inset:22px;
      border-color:rgba(255,255,255,.7);
    }
    .ai-help-orb span{
      width:16px;
      height:16px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 18px rgba(103,232,249,.95);
      animation:aiCorePulse 2.8s ease-in-out infinite;
    }
    .ai-help-copy{
      position:relative;
      z-index:1;
      display:grid;
      gap:8px;
      min-width:0;
      flex:1 1 auto;
    }
    .ai-help-kicker{
      display:inline-flex;
      align-items:center;
      gap:8px;
      width:max-content;
      padding:5px 11px;
      border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.16);
      font-size:11px;
      font-weight:800;
      letter-spacing:.08em;
    }
    .ai-help-kicker::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 10px rgba(103,232,249,.9);
    }
    .ai-help-title{
      font-size:clamp(19px, 2vw, 30px);
      font-weight:900;
      line-height:1.55;
      word-break:break-word;
    }
    .ai-help-level{
      font-size:13px;
      font-weight:700;
      color:rgba(255,255,255,.78);
    }
    .ai-help-subtitle{
      color:rgba(255,255,255,.86);
      font-size:14px;
      font-weight:700;
      line-height:1.9;
    }
    .ai-help-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:16px;
    }
    .ai-help-section{
      position:relative;
      overflow:hidden;
      border:1px solid rgba(148,163,184,.22);
      border-radius:18px;
      padding:18px;
      background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      box-shadow:0 12px 28px rgba(15,23,42,.07);
    }
    .ai-help-section::before{
      content:"";
      position:absolute;
      inset:0 auto 0 0;
      width:4px;
      background:linear-gradient(180deg, #38bdf8, #0369a1);
    }
    .ai-help-section-head{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:12px;
      font-size:15px;
      font-weight:900;
      color:var(--ink);
      line-height:1.4;
    }
    .ai-help-chip-icon{
      width:36px;
      height:36px;
      border-radius:12px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg, rgba(8,145,178,.16), rgba(14,165,233,.08));
      color:var(--brand2);
      border:1px solid rgba(8,145,178,.2);
      font-size:16px;
      flex:0 0 auto;
    }
    .ai-help-body{
      color:var(--ink-soft);
      font-size:14px;
      font-weight:700;
      line-height:1.95;
    }
    .ai-help-body ul,
    .ai-help-body ol{
      margin:0;
      padding-right:18px;
    }
    .ai-help-note{
      color:var(--muted);
      font-size:14px;
      font-weight:700;
      line-height:1.95;
    }
    @media (max-width: 980px){
      .topbar{
        padding:12px 10px;
        min-height:auto;
      }
      .topbar .row{
        padding:10px 12px;
        min-height:auto;
        flex-wrap:wrap;
        justify-content:center;
        gap:10px;
      }
      .topbar .row .brandblock{
        position:static;
        left:auto;
        transform:none;
        order:3;
        width:100%;
        max-width:none;
      }
      .logoWrap{
        position:static;
        left:auto;
        top:auto;
        transform:none;
        order:2;
        margin-inline-start:auto;
      }
      .logoWrap:hover{
        transform:none;
      }
      .topbar .row .topbarRight,
      .topbar .row .timerBar{
        order:1;
      }
      .wrap{
        grid-template-columns:1fr;
        gap:18px;
        margin:18px auto 30px;
        padding:0 14px;
      }
    }
    @media (max-width: 720px){
      .ai-assist-modal{
        padding:10px;
      }
      .ai-assist-shell{
        width:100%;
        border-radius:22px;
      }
      .ai-assist-topbar{
        padding:14px 16px;
      }
      .ai-assist-body{
        padding:14px 16px 18px;
      }
      .mainhead{
        padding:12px 14px;
        flex-wrap:wrap;
      }
      .content,
      .side,
      .resultWrap{
        padding:16px;
      }
      .qtitleRow{
        align-items:stretch;
        gap:12px;
      }
      .qtitle{
        font-size:18px;
        line-height:1.5;
      }
      .qmeta{
        width:100%;
        display:grid;
        grid-template-columns:repeat(2, minmax(0,1fr));
      }
      .qmeta .btn{
        justify-content:center;
      }
      .branchHead{
        justify-content:space-between;
      }
      .branchBody{
        padding:14px 14px 16px;
        font-size:14px;
      }
      .part{
        flex-direction:column;
        align-items:stretch;
      }
      .part .inputWrap{
        width:100%;
        justify-content:stretch;
        flex:1 1 auto;
      }
      input[type="text"],
      input[type="number"],
      textarea,
      select{
        min-width:0;
        width:100%;
      }
      textarea{
        min-width:0;
      }
      .scoreCard{
        padding:16px;
      }
      .scoreBig{
        font-size:18px;
      }
      .partRow{
        grid-template-columns:1fr !important;
      }
      .ai-help-hero{
        flex-direction:column;
        align-items:flex-start;
        padding:18px 16px;
      }
      .ai-help-grid{
        grid-template-columns:1fr;
      }
      .ai-help-orb{
        width:68px;
        height:68px;
        border-radius:20px;
      }
      .ai-help-inline-btn{
        width:100%;
        justify-content:center;
      }
      .logoWrap img{
        height:44px;
      }
      .brandtext .u{
        font-size:16px;
      }
      .brandtext .u.en,
      .brandtext .d,
      .brandtext .s{
        font-size:11px;
      }
    }
    @media (max-width: 560px){
      .wrap{
        padding:0 10px;
      }
      .qmeta{
        grid-template-columns:1fr;
      }
      .btn,
      .btn.small{
        width:100%;
        justify-content:center;
      }
      .qtitle .qnum{
        width:42px;
        height:42px;
        font-size:16px;
      }
      .topbar .row{
        padding:8px 8px 4px;
      }
      .logoWrap{
        width:100%;
        margin-inline-start:0;
        justify-content:center;
      }
    }
    @keyframes aiPulse{
      0%{box-shadow:0 0 0 0 rgba(14,165,233,.24)}
      70%{box-shadow:0 0 0 10px rgba(14,165,233,0)}
      100%{box-shadow:0 0 0 0 rgba(14,165,233,0)}
    }
    @keyframes aiWake{
      0%{transform:scale(1) rotate(0)}
      35%{transform:scale(1.08) rotate(-8deg)}
      70%{transform:scale(.96) rotate(8deg)}
      100%{transform:scale(1) rotate(0)}
    }
    @keyframes aiCorePulse{
      0%,100%{transform:scale(.92);box-shadow:0 0 14px rgba(103,232,249,.72)}
      50%{transform:scale(1.14);box-shadow:0 0 26px rgba(103,232,249,.98)}
    }
/* Codex Unified AI Help End */

/* Codex Adaptive Mastery Start */
    .mainhead div:first-child{font-size:0;}
    .mainhead div:first-child::after{content:"ط³ط¤ط§ظ„ طھظƒظٹظپظٹ";font-size:14px;font-weight:900;color:#0f2a3b;}
    .side .head{justify-content:space-between;}
    .side .head h3{font-size:0;}
    .side .head h3::after{content:"ظ„ظˆط­ط© ط§ظ„ط¥طھظ‚ط§ظ†";font-size:18px;font-weight:900;color:var(--ink);}
    .sidebar-filter,
    .qList{display:none !important;}
    .branchBody{overflow-x:auto;}
    .branchBody table.ftable,
    table.ftable{min-width:520px;}
    @media (max-width:720px){
      .branchBody table.ftable,
      table.ftable{min-width:480px;}
    }
    @media (max-width:560px){
      .topbar .row .topbarRight{
        width:100%;
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:8px;
        margin:0;
      }
      .topbar .row .topbarRight .timerBar{
        grid-column:1 / -1;
        width:100%;
        min-width:0;
      }
      .topbar .row .topbarRight .btn.small{
        width:100%;
        min-width:0;
        padding-inline:8px;
      }
      .topbar .row .topbarRight #fullscreenBtn{
        grid-column:1 / -1;
      }
      .qtitle{
        width:100%;
        overflow-wrap:anywhere;
      }
    }/* Codex Adaptive Mastery End */

/* Codex AI Models Panel Start */
    .wrap{
      direction:ltr;
      grid-template-columns:minmax(220px,.72fr) minmax(0,1.5fr) minmax(260px,.9fr);
      grid-template-areas:"titles main results";
      gap:20px;
      align-items:start;
    }
    .wrap > *{
      direction:rtl;
    }
    .wrap > section.card{
      grid-area:main;
      margin-top:0;
    }
    .side{
      grid-area:titles;
      position:static;
      top:auto;
      align-self:start;
      margin-top:0;
    }
    .aiResultsRail{
      grid-area:results;
      position:static;
      top:auto;
      align-self:start;
      padding:20px;
      margin-top:0;
    }
    .aiModelsPanel{
      display:grid;
      gap:14px;
      margin:0;
    }
    .aiModelsHero{
      position:relative;
      overflow:hidden;
      border-radius:22px;
      padding:18px;
      color:#fff;
      background:
        radial-gradient(circle at 16% 20%, rgba(56,189,248,.28), transparent 24%),
        radial-gradient(circle at 88% 18%, rgba(96,165,250,.22), transparent 26%),
        linear-gradient(135deg, var(--brand2) 0%, #0f172a 50%, var(--brand) 100%);
      box-shadow:0 18px 34px rgba(15,23,42,.16);
      border:1px solid rgba(255,255,255,.12);
      display:grid;
      gap:14px;
    }
    .aiModelsHero::after{
      content:"";
      position:absolute;
      inset:0;
      background:repeating-linear-gradient(90deg, rgba(255,255,255,.05) 0 1px, transparent 1px 16px);
      opacity:.38;
      pointer-events:none;
    }
    .aiModelsHeroTop{
      position:relative;
      z-index:1;
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
    }
    .aiModelsCopy{
      display:grid;
      gap:6px;
      min-width:0;
      flex:1 1 auto;
    }
    .aiModelsBadge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      width:max-content;
      padding:5px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.14);
      font-size:11px;
      font-weight:900;
      letter-spacing:.08em;
    }
    .aiModelsBadge::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 12px rgba(103,232,249,.9);
    }
    .aiModelsTitle{
      font-size:22px;
      font-weight:900;
      line-height:1.45;
    }
    .aiModelsOrb{
      width:76px;
      height:76px;
      border-radius:24px;
      flex:0 0 auto;
      display:grid;
      place-items:center;
      position:relative;
      border:1px solid rgba(255,255,255,.2);
      background:linear-gradient(135deg, rgba(255,255,255,.22), rgba(255,255,255,.08));
      box-shadow:inset 0 1px 0 rgba(255,255,255,.16), 0 14px 28px rgba(8,145,178,.24);
    }
    .aiModelsOrb::before,
    .aiModelsOrb::after{
      content:"";
      position:absolute;
      border-radius:50%;
      border:1px solid rgba(103,232,249,.55);
    }
    .aiModelsOrb::before{ inset:10px; }
    .aiModelsOrb::after{ inset:22px; border-color:rgba(255,255,255,.7); }
    .aiModelsOrb span{
      width:16px;
      height:16px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 18px rgba(103,232,249,.95);
      animation:aiModelsPulse 2.8s ease-in-out infinite;
    }
    .aiModelsChips{
      position:relative;
      z-index:1;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }
    .aiModelsChip{
      font-size:11px;
      font-weight:900;
      padding:5px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.1);
      border:1px solid rgba(255,255,255,.14);
      color:#eff6ff;
    }
    .aiModelsGrid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:12px;
    }
    .aiModelCard{
      position:relative;
      overflow:hidden;
      border-radius:18px;
      border:1px solid var(--line);
      background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      padding:14px;
      box-shadow:0 10px 24px rgba(15,23,42,.07);
    }
    .aiModelCard::before{
      content:"";
      position:absolute;
      inset:0 auto 0 0;
      width:4px;
      background:linear-gradient(180deg, #38bdf8, var(--brand));
    }
    .aiModelHead{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:8px;
    }
    .aiModelIcon{
      width:34px;
      height:34px;
      border-radius:12px;
      flex:0 0 auto;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg, rgba(3,105,161,.14), rgba(14,165,233,.08));
      border:1px solid rgba(3,105,161,.14);
      color:var(--brand2);
      font-size:11px;
      font-weight:900;
    }
    .aiModelName{
      font-size:13px;
      font-weight:900;
      color:var(--ink);
      line-height:1.5;
    }
    .aiModelValue{
      font-size:24px;
      font-weight:900;
      color:var(--brand2);
      line-height:1.1;
    }
    .aiModelMeta{
      margin-top:6px;
      font-size:11px;
      font-weight:800;
      color:var(--muted);
      line-height:1.7;
    }
    .aiModelCard.full{
      grid-column:1 / -1;
    }
    .aiTopicBoard,
    .aiInferenceCard{
      border-radius:18px;
      border:1px solid var(--line);
      background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      padding:14px;
      box-shadow:0 10px 24px rgba(15,23,42,.06);
    }
    .aiSectionTitle{
      font-size:14px;
      font-weight:900;
      color:var(--ink);
      margin-bottom:10px;
    }
    .aiTopicList{
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .aiTopicRow{
      display:grid;
      grid-template-columns:auto 1fr auto;
      gap:8px;
      align-items:center;
    }
    .aiTopicName{
      font-size:11px;
      font-weight:900;
      color:#24455f;
    }
    .aiTopicBar{
      height:8px;
      border-radius:999px;
      border:1px solid #dbe7f2;
      background:#edf4fb;
      overflow:hidden;
    }
    .aiTopicFill{
      height:100%;
      background:linear-gradient(90deg, var(--brand), #38bdf8);
      border-radius:inherit;
    }
    .aiTopicPct{
      font-size:11px;
      font-weight:900;
      color:var(--brand2);
      min-width:40px;
      text-align:left;
      direction:ltr;
    }
    .aiInferenceText{
      font-size:13px;
      font-weight:800;
      line-height:1.9;
      color:#334155;
    }
    .aiInferenceHint{
      margin-top:8px;
      font-size:11px;
      font-weight:900;
      color:var(--muted);
    }
    @media (max-width: 980px){
      .wrap{
        grid-template-columns:1fr;
        grid-template-areas:
          "main"
          "results"
          "titles";
      }
      .wrap > section.card,
      .wrap > .side,
      .wrap > .aiResultsRail{
        grid-area:auto;
      }
      .side{
        position:static;
        top:auto;
      }
      .aiResultsRail{
        position:static;
        top:auto;
      }
      .aiModelsGrid{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }
    }
    @media (max-width: 640px){
      .aiModelsHeroTop{
        flex-direction:column;
        align-items:flex-start;
      }
      .aiModelsOrb{
        width:66px;
        height:66px;
        border-radius:20px;
      }
      .aiModelsGrid{
        grid-template-columns:1fr;
      }
    }
    @keyframes aiModelsPulse{
      0%,100%{transform:scale(.92);box-shadow:0 0 14px rgba(103,232,249,.72)}
      50%{transform:scale(1.14);box-shadow:0 0 26px rgba(103,232,249,.98)}
    }
/* Codex AI Models Panel End */







/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   طھطµظ…ظٹظ… ط¬ط§ظ…ط¹ظٹ â€” ظ†ط¸ط§ظ… ط£ظ„ظˆط§ظ† ط±ط³ظ…ظٹ
â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
:root{
  --uni-gold: #C8972A;
  --uni-gold-light: #FDF6E3;
  --uni-gold-border: rgba(200,151,42,.25);
  --uni-green: #1a6b3c;
}

/* ط´ط±ظٹط· ط¹ظ„ظˆظٹ â€” ظ‡ظˆظٹط© ط£ظƒط§ط¯ظٹظ…ظٹط© */
.topbar{
  background:linear-gradient(135deg,#0b3c5d 0%,#154360 40%,#0d3349 100%) !important;
  border-bottom:3px solid var(--uni-gold);
}
.topbar.scrolled{
  box-shadow:0 4px 30px rgba(11,60,93,.45) !important;
}

/* ط´ط±ظٹط· ط°ظ‡ط¨ظٹ ط¯ظ‚ظٹظ‚ طھط­طھ ط§ظ„ظ€ topbar */
.topbar::after{
  content:"";
  position:absolute;
  bottom:-3px; left:0; right:0;
  height:3px;
  background:linear-gradient(90deg,transparent,var(--uni-gold),transparent);
  opacity:.6;
}

/* Cards â€” ط­ط¯ظˆط¯ ط£ظƒط§ط¯ظٹظ…ظٹط© */
.card{
  border-top:3px solid var(--brand) !important;
  border-radius:18px;
}

/* Section titles â€” ط·ط±ط§ط² ط£ظƒط§ط¯ظٹظ…ظٹ */
.mainhead{
  background:linear-gradient(180deg,#f0f7ff 0%,#ffffff 100%);
  border-bottom:2px solid var(--uni-gold-border);
}
.mainhead::after{
  content:"";
  display:block;
  position:absolute;
  bottom:0; left:20px; right:20px;
  height:1px;
  background:linear-gradient(90deg,transparent,var(--uni-gold),transparent);
  opacity:.5;
}
.mainhead{ position:relative; }

/* ط´ط§ط±ط© ط§ظ„ط¬ط§ظ…ط¹ط© ط¹ظ„ظ‰ ط§ظ„ط³ط¤ط§ظ„ */
.pill{
  background:linear-gradient(135deg,var(--uni-gold-light),#fff8e7);
  color:#8B6914;
  border-color:var(--uni-gold-border);
  font-weight:900;
}

/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   طھط­ط³ظٹظ† ط´ط§ط´ط© ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©
â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
.choice.goodField{
  background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 100%) !important;
  border-color:#16a34a !important;
  border-width:2px !important;
  color:#15803d !important;
  box-shadow:0 0 0 4px rgba(22,163,74,.12), 0 4px 14px rgba(22,163,74,.1) !important;
  position:relative;
}
.choice.goodField::after{
  content:"âœ“ طµط­ظٹط­";
  position:absolute;
  left:14px; top:50%;
  transform:translateY(-50%);
  font-size:11px;font-weight:900;
  color:#15803d;
  background:#dcfce7;
  padding:3px 8px;border-radius:6px;
  border:1px solid rgba(22,163,74,.3);
}
.choice.badField{
  background:linear-gradient(135deg,#fff5f5 0%,#fee2e2 100%) !important;
  border-color:#dc2626 !important;
  border-width:2px !important;
  color:#b91c1c !important;
  box-shadow:0 0 0 4px rgba(220,38,38,.1) !important;
  position:relative;
}
.choice.badField::after{
  content:"âœ— ط®ط·ط£";
  position:absolute;
  left:14px; top:50%;
  transform:translateY(-50%);
  font-size:11px;font-weight:900;
  color:#b91c1c;
  background:#fee2e2;
  padding:3px 8px;border-radius:6px;
  border:1px solid rgba(220,38,38,.25);
}
input.goodField, textarea.goodField{
  border-color:#16a34a !important;
  background:linear-gradient(135deg,#f0fdf4,#dcfce7) !important;
  box-shadow:0 0 0 3px rgba(22,163,74,.15) !important;
}
input.badField, textarea.badField{
  border-color:#dc2626 !important;
  background:linear-gradient(135deg,#fff5f5,#fee2e2) !important;
  box-shadow:0 0 0 3px rgba(220,38,38,.12) !important;
}

/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   طھط·ظˆظٹط± طµظپط­ط© ط§ظ„ظ†طھط§ط¦ط¬
â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
.scoreCard{
  border-radius:20px !important;
  background:linear-gradient(135deg,#0b3c5d 0%,#154360 60%,#1a6b3c 100%) !important;
  border:none !important;
  color:#fff !important;
  padding:24px !important;
  box-shadow:0 20px 40px rgba(11,60,93,.25) !important;
  position:relative;
  overflow:hidden;
}
.scoreCard::before{
  content:"";
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(90deg,rgba(255,255,255,.04) 0 1px,transparent 1px 20px);
  pointer-events:none;
}
.scoreCard::after{
  content:"";
  position:absolute;
  bottom:0; left:0; right:0;
  height:4px;
  background:linear-gradient(90deg,var(--uni-gold),#fde68a,var(--uni-gold));
}
.scoreBig{
  font-size:24px !important;
  font-weight:900 !important;
  color:#fff !important;
  position:relative;
}
.scoreSub{ color:rgba(255,255,255,.8) !important; position:relative; }
.score-bar-wrap{
  background:rgba(255,255,255,.15) !important;
  height:10px !important;
  border-radius:999px;
  position:relative;
}
.score-bar-correct{
  background:linear-gradient(90deg,#34d399,#a7f3d0) !important;
}

/* ط¨ط·ط§ظ‚ط§طھ ط§ظ„ظ†طھط§ط¦ط¬ */
.resultCard{
  border-radius:16px !important;
  border:1px solid var(--line) !important;
  box-shadow:0 4px 16px rgba(15,23,42,.06) !important;
  overflow:hidden;
  transition:var(--transition);
}
.resultCard:hover{
  border-color:var(--brand) !important;
  box-shadow:0 8px 24px rgba(3,105,161,.1) !important;
  transform:translateY(-1px);
}
/* ط±ط£ط³ ط¨ط·ط§ظ‚ط© ط§ظ„ظ†طھظٹط¬ط© */
.resultCard > div:first-child{
  background:linear-gradient(180deg,#f8fbff 0%,#ffffff 100%);
  padding:14px 16px 12px !important;
  border-bottom:1px solid var(--line);
  margin-bottom:0 !important;
}

.tag.good{
  background:linear-gradient(135deg,#dcfce7,#f0fdf4) !important;
  border-color:rgba(22,163,74,.3) !important;
  color:#15803d !important;
  font-weight:900;
  padding:6px 14px;
}
.tag.bad{
  background:linear-gradient(135deg,#fee2e2,#fff5f5) !important;
  border-color:rgba(220,38,38,.3) !important;
  color:#b91c1c !important;
  font-weight:900;
  padding:6px 14px;
}

/* طµظپظˆظپ ط§ظ„ط£ط¬ط²ط§ط، */
.partRow{
  border-radius:10px !important;
  border:1px solid var(--line) !important;
  background:#f8fbff !important;
  padding:12px 16px !important;
  font-size:13px;
  transition:var(--transition);
}
.partRow:hover{ background:#eef6ff !important; border-color:rgba(3,105,161,.2) !important; }

/* ط£ط²ط±ط§ط± ط§ظ„ظ†طھظٹط¬ط© */
.scoreCard .btn.primary{
  background:linear-gradient(135deg,var(--uni-gold),#b07d20) !important;
  border:none !important;
  box-shadow:0 4px 14px rgba(200,151,42,.35) !important;
  color:#fff !important;
  position:relative;
}
.scoreCard .btn.primary:hover{
  background:linear-gradient(135deg,#d4a43a,var(--uni-gold)) !important;
  transform:translateY(-2px) !important;
  box-shadow:0 8px 20px rgba(200,151,42,.45) !important;
}
:root{
  --shadow-sm: 0 1px 2px rgba(15,23,42,.04), 0 2px 8px rgba(15,23,42,.06);
  --shadow:    0 4px 6px rgba(15,23,42,.04), 0 10px 28px rgba(15,23,42,.08);
  --shadow-lg: 0 20px 25px rgba(15,23,42,.08), 0 40px 60px rgba(15,23,42,.12);
}
/* Topbar â€” Glass ط£ظ‚ظˆظ‰ */
.topbar{
  backdrop-filter:blur(20px) saturate(180%);
  -webkit-backdrop-filter:blur(20px) saturate(180%);
  border-bottom:1px solid rgba(255,255,255,.1);
}
/* Scroll-linked shadow ط¹ظ„ظ‰ ط§ظ„ظ€ topbar */
.topbar.scrolled{ box-shadow:0 4px 30px rgba(15,23,42,.3); }

/* Cards â€” ط¶ظ„ط¹ ط¹ظ„ظˆظٹ ظ…ظ„ظˆظ† + hover ط£ط¬ظ…ظ„ */
.card{ border-top:3px solid var(--brand); }
.card:hover{ box-shadow:0 12px 36px rgba(15,23,42,.11); transform:translateY(-1px); }

/* Progress bar â€” shimmer ظ…طھط­ط±ظƒ */
.progress{
  height:8px;
  box-shadow:inset 0 1px 3px rgba(0,0,0,.07);
}
.progress > div{
  background-size:200% 100%;
  animation:progressShimmer 2.4s linear infinite;
  background-image:linear-gradient(90deg, #0369a1 0%, #38bdf8 50%, #0369a1 100%);
}
@keyframes progressShimmer{
  0%{background-position:100% 0}
  100%{background-position:-100% 0}
}

/* Question number badge */
.qtitle .qnum{
  background:linear-gradient(135deg, var(--brand), var(--brand2));
  color:#fff;
  border:none;
  box-shadow:0 6px 16px rgba(3,105,161,.3);
  font-size:17px;
  width:44px; height:44px;
  border-radius:14px;
}

/* MCQ choices â€” طھط­ط³ظٹظ† ط§ظ„طھظپط§ط¹ظ„ */
.choice{
  position:relative;
  transition:all .2s cubic-bezier(.4,0,.2,1);
  border-width:2px;
}
.choice:hover{ transform:translateX(-3px); box-shadow:0 4px 14px rgba(3,105,161,.12); }
.choice.goodField{
  box-shadow:0 0 0 3px rgba(5,150,105,.18);
  animation:correctPop .3s ease;
}
.choice.badField{ box-shadow:0 0 0 3px rgba(220,38,38,.15); }
@keyframes correctPop{
  0%{transform:scale(1)}
  50%{transform:scale(1.02)}
  100%{transform:scale(1)}
}

/* Difficulty tags */
.btag{ letter-spacing:.04em; text-transform:uppercase; font-size:11px; border-radius:8px; }

/* Timer */
.timerBar{
  font-variant-numeric:tabular-nums;
  letter-spacing:.06em;
  font-size:16px;
  padding:8px 18px;
  background:rgba(255,255,255,.15);
  border:1px solid rgba(255,255,255,.3);
  border-radius:14px;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.2);
}

/* AI Model cards â€” hover ظ…ط¹ ط®ط· ط³ظپظ„ظٹ */
.aiModelCard{
  transition:transform .2s, box-shadow .2s;
  cursor:default;
}
.aiModelCard::after{
  content:"";
  position:absolute;
  bottom:0; left:0; right:0;
  height:3px;
  background:linear-gradient(90deg, var(--brand), #38bdf8);
  transform:scaleX(0);
  transition:transform .3s;
  transform-origin:right;
  border-radius:0 0 4px 4px;
}
.aiModelCard:hover{ transform:translateY(-2px); box-shadow:0 10px 28px rgba(15,23,42,.1); }
.aiModelCard:hover::after{ transform:scaleX(1); }

/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   ط§ظ„ظ†ظ…ط§ط°ط¬ ط§ظ„ط®ظ…ط³ط© ط§ظ„ط¬ط¯ظٹط¯ط© â€” CSS
â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */

/* ظ‚ط³ظ… ط§ظ„ظ†ظ…ط§ط°ط¬ ط§ظ„ظ…ظˆط³ظ‘ط¹ */
.aiExtSection{
  border-radius:18px;
  border:1px solid var(--line);
  background:linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);
  padding:16px;
  box-shadow:0 10px 24px rgba(15,23,42,.06);
  display:grid;
  gap:12px;
}

/* ظ،. ظ…ظ†ط­ظ†ظ‰ ط§ظ„ظ†ط³ظٹط§ظ† */
.forgettingCard{
  display:grid;
  gap:10px;
}
.forgettingTopicRow{
  display:grid;
  grid-template-columns:auto 1fr auto auto;
  gap:8px;
  align-items:center;
}
.forgettingTopicName{font-size:11px;font-weight:900;color:#24455f}
.forgettingBar{height:8px;border-radius:999px;border:1px solid #dbe7f2;background:#edf4fb;overflow:hidden;}
.forgettingFill{height:100%;border-radius:inherit;transition:width .5s ease;}
.forgettingPct{font-size:11px;font-weight:900;min-width:36px;text-align:left;direction:ltr;}
.forgettingReview{
  font-size:10px;font-weight:900;padding:3px 7px;border-radius:6px;white-space:nowrap;
}
.forgettingReview.now{background:#fee2e2;color:#dc2626;border:1px solid rgba(220,38,38,.2)}
.forgettingReview.soon{background:#fef3c7;color:#d97706;border:1px solid rgba(217,119,6,.2)}
.forgettingReview.ok{background:#d1fae5;color:#059669;border:1px solid rgba(5,150,105,.2)}

/* ظ¢. IRT â€” ظ‚ط¯ط±ط© ط§ظ„ط·ط§ظ„ط¨ */
.irtCard{
  display:grid;
  gap:12px;
}
.irtTheta{
  display:flex;
  align-items:center;
  gap:14px;
}
.irtThetaNum{
  font-size:28px;
  font-weight:900;
  color:var(--brand2);
  direction:ltr;
  white-space:nowrap;
}
.irtThetaSub{font-size:12px;font-weight:800;color:var(--muted);line-height:1.6}
.irtScale{
  position:relative;
  height:12px;
  border-radius:999px;
  background:linear-gradient(90deg,#dc2626 0%,#d97706 25%,#0369a1 50%,#059669 75%,#0284c7 100%);
  overflow:visible;
  margin:4px 0;
}
.irtPointer{
  position:absolute;
  top:50%;
  transform:translate(-50%,-50%);
  width:18px;height:18px;
  border-radius:50%;
  background:#fff;
  border:3px solid var(--brand);
  box-shadow:0 2px 8px rgba(3,105,161,.35);
  transition:left .5s ease;
}
.irtLabels{
  display:flex;
  justify-content:space-between;
  font-size:10px;
  font-weight:900;
  color:var(--muted);
  direction:ltr;
}
.irtSE{
  font-size:11px;
  font-weight:800;
  color:var(--muted);
  background:#f1f5f9;
  border-radius:8px;
  padding:6px 10px;
  text-align:center;
}

/* ظ£. ظ…ط­ظ„ظ„ ظ†ظ…ط· ط§ظ„ط£ط®ط·ط§ط، */
.errorPatternCard{display:grid;gap:10px}
.errorTypeRow{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;border-radius:12px;
  border:1px solid var(--line);
  background:#f8fbff;
}
.errorTypeBadge{
  font-size:11px;font-weight:900;padding:4px 10px;border-radius:8px;white-space:nowrap;
}
.errorTypeBadge.conceptual{background:#fee2e2;color:#dc2626;border:1px solid rgba(220,38,38,.2)}
.errorTypeBadge.computational{background:#fef3c7;color:#d97706;border:1px solid rgba(217,119,6,.2)}
.errorTypeBadge.application{background:#ede9fe;color:#7c3aed;border:1px solid rgba(124,58,237,.2)}
.errorTypeBadge.none{background:#d1fae5;color:#059669;border:1px solid rgba(5,150,105,.2)}
.errorTypeDetail{flex:1;min-width:0}
.errorTypeName{font-size:12px;font-weight:900;color:var(--ink);margin-bottom:2px}
.errorTypeAdvice{font-size:11px;font-weight:800;color:var(--muted);line-height:1.5}
.errorTypeCount{font-size:18px;font-weight:900;color:var(--brand2);flex:0 0 auto}
.errorBarWrap{display:flex;gap:3px;height:6px;border-radius:999px;overflow:hidden;background:#edf4fb}
.errorBarSeg{height:100%;border-radius:999px;transition:width .5s ease}

/* ظ¤. ظ…ط¹ط§ظٹط±ط© ط§ظ„ط«ظ‚ط© */
.calibCard{display:grid;gap:12px}
.calibMatrix{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
}
.calibCell{
  border-radius:12px;
  border:1px solid var(--line);
  background:#f8fbff;
  padding:10px 8px;
  text-align:center;
}
.calibCellVal{font-size:20px;font-weight:900;color:var(--brand2)}
.calibCellLabel{font-size:10px;font-weight:900;color:var(--muted);margin-top:3px;line-height:1.4}
.calibDiag{
  font-size:12px;font-weight:800;line-height:1.8;
  padding:10px 12px;border-radius:12px;
  background:#f1f5f9;border:1px solid var(--line);
  color:#334155;
}
.calibScore{
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  padding:8px 12px;border-radius:10px;
  font-size:12px;font-weight:900;
}
.calibScore.good{background:#d1fae5;color:#059669}
.calibScore.warn{background:#fef3c7;color:#d97706}
.calibScore.bad{background:#fee2e2;color:#dc2626}

/* ظ¥. طھظˆظ‚ط¹ ط§ظ„ط¯ط±ط¬ط© */
.gradeCard{display:grid;gap:12px}
.gradeBig{
  display:flex;align-items:center;gap:16px;
  padding:16px;border-radius:16px;
  border:2px solid var(--line);
}
.gradeLabel{font-size:22px;font-weight:900}
.gradeRange{font-size:13px;font-weight:800;color:var(--muted);margin-top:2px}
.gradeTrajectory{
  display:grid;gap:6px;
}
.gradeTrajectoryRow{
  display:grid;grid-template-columns:auto 1fr auto;gap:8px;align-items:center;
  font-size:11px;font-weight:900;
}
.gradeTrajectoryBar{height:8px;border-radius:999px;background:#edf4fb;overflow:hidden;border:1px solid #dbe7f2}
.gradeTrajectoryFill{height:100%;border-radius:inherit;transition:width .6s ease}
.gradeTip{
  font-size:12px;font-weight:800;line-height:1.8;color:#334155;
  padding:10px 12px;border-radius:12px;background:#f1f5f9;border:1px solid var(--line);
}

/* Section titles ظ„ظ„ط£ظ‚ط³ط§ظ… ط§ظ„ط¬ط¯ظٹط¯ط© */
.aiExtSectionTitle{
  font-size:13px;font-weight:900;color:var(--ink);
  display:flex;align-items:center;gap:8px;
  padding-bottom:8px;
  border-bottom:1px solid var(--line);
}
.aiExtSectionTitle::before{
  content:"";width:4px;height:18px;border-radius:2px;
  background:linear-gradient(180deg,var(--brand),#38bdf8);
  flex:0 0 auto;
}

/* ط´ط§ط±ط© ط§ظ„ظ†ظ…ظˆط°ط¬ */
.aiExtModelBadge{
  font-size:10px;font-weight:900;letter-spacing:.05em;
  padding:3px 8px;border-radius:6px;
  background:rgba(3,105,161,.08);border:1px solid rgba(3,105,161,.18);
  color:var(--brand2);margin-right:auto;
}

/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   طھط­ط³ظٹظ† ط§ظ„ظ…ظˆط¯ط§ظ„ط§طھ â€” طµط­ظٹط­ / طھظ†ط¨ظٹظ‡ / ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©
â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
.modal-success-body{
  display:flex; flex-direction:column; align-items:center;
  text-align:center; padding:36px 24px; gap:16px;
}
.modal-success-orb{
  width:88px; height:88px; border-radius:50%;
  background:radial-gradient(circle at 35% 35%, #bbf7d0, #dcfce7);
  border:3px solid rgba(22,163,74,.25);
  display:grid; place-items:center; font-size:42px;
  box-shadow:0 0 0 12px rgba(22,163,74,.07), 0 14px 32px rgba(22,163,74,.18);
  animation:successPop .45s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes successPop{
  0%{transform:scale(.4);opacity:0}
  100%{transform:scale(1);opacity:1}
}
.modal-success-title{
  font-size:24px; font-weight:900; color:#15803d;
  animation:fadeUpIn .35s .1s ease both;
}
.modal-success-badge{
  display:inline-flex; align-items:center; gap:8px;
  padding:7px 16px; border-radius:999px;
  background:linear-gradient(135deg,#dcfce7,#f0fdf4);
  border:1px solid rgba(22,163,74,.3);
  font-size:13px; font-weight:900; color:#166534;
  animation:fadeUpIn .35s .18s ease both;
}
.modal-success-badge::before{
  content:""; width:8px; height:8px; border-radius:50%;
  background:#22c55e; box-shadow:0 0 8px rgba(34,197,94,.8);
  animation:aiModelsPulse 1.8s infinite;
}
.modal-success-stars{
  display:flex; gap:8px; font-size:22px;
  animation:fadeUpIn .35s .26s ease both;
}
.modal-success-note{
  font-size:13px; font-weight:700; color:#166534;
  background:#f0fdf4; border:1px solid rgba(22,163,74,.2);
  border-radius:12px; padding:10px 16px; line-height:1.7;
  animation:fadeUpIn .35s .34s ease both;
  max-width:300px;
}
@keyframes fadeUpIn{
  0%{opacity:0;transform:translateY(12px)}
  100%{opacity:1;transform:translateY(0)}
}

/* Warning Modal */
.modal-warn-body{
  display:flex; gap:14px; align-items:flex-start;
  padding:24px;
}
.modal-warn-icon{
  width:52px; height:52px; flex:0 0 auto;
  border-radius:14px;
  background:linear-gradient(135deg,#fef3c7,#fde68a);
  border:1px solid rgba(217,119,6,.22);
  display:grid; place-items:center; font-size:24px;
}
.modal-warn-title{ font-size:16px; font-weight:900; color:#92400e; margin-bottom:6px; }
.modal-warn-text{ font-size:14px; font-weight:700; color:#78350f; line-height:1.75; }

/* طھط­ط³ظٹظ† modal ط¹ط§ظ… */
.modal .box{ border-radius:22px !important; box-shadow:0 30px 70px rgba(15,23,42,.2) !important; }
.modal .box .mh{
  background:linear-gradient(180deg,#f8fbff 0%,#ffffff 100%);
  border-bottom:2px solid var(--line);
  padding:16px 20px;
}
.modal .box .mh b{ font-size:16px; font-weight:900; }

    /* ط²ط± ط¥ط¹ط§ط¯ط© ط§ظ„طھط¹ظٹظٹظ† ظپظٹ ط±ط£ط³ ط§ظ„ط¨ط·ط§ظ‚ط© */
    #resetBtnMain{
      display:flex;align-items:center;gap:5px;
      padding:5px 10px;

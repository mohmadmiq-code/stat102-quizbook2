/* ===== أدوات مساعدة ===== */
const SVG_TAGS = new Set(["svg","g","path","rect","line","circle","text","defs","linearGradient","stop","polyline","polygon"]);
function el(tag, attrs={}, children=[]){
  const isSvg = SVG_TAGS.has(String(tag).toLowerCase());
  const node = isSvg ? document.createElementNS("http://www.w3.org/2000/svg", tag) : document.createElement(tag);
  Object.entries(attrs).forEach(([k,v])=>{
    if(k==="class") node.className=v;
    else if(k==="html") node.innerHTML=v;
    else if(k.startsWith("on") && typeof v==="function") node.addEventListener(k.slice(2), v);
    else if(k==="disabled") node.disabled=!!v;
    else node.setAttribute(k,v);
  });
  (Array.isArray(children)?children:[children]).forEach(ch=>{
    if(ch===null || ch===undefined) return;
    node.appendChild(typeof ch==="string" ? document.createTextNode(ch) : ch);
  });
  return node;
}
function escapeHtml(s){ return String(s).replace(/[&<>"']/g, m=>({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[m])); }
function normalizeText(s){ if(s==null) return ""; return String(s).trim().replace(/\s+/g," ").replace(/[٪%]/g,"%"); }
function parseNumberLoose(v){
  if(v==null) return NaN;
  const s = String(v).replace(/[٬،]/g,",").replace(/[%٪]/g,"").trim();
  if(!s) return NaN;
  const n = Number(s);
  return Number.isFinite(n) ? n : NaN;
}
function nearlyEqual(a,b,eps=1e-2){
  if(a==null||b==null) return false;
  if(!Number.isFinite(a) || !Number.isFinite(b)) return false;
  return Math.abs(a-b) <= eps;
}
function roundTo(x, d=2){
  const n = Number(x);
  if(!Number.isFinite(n)) return String(x);
  const m = Math.pow(10,d);
  return (Math.round(n*m)/m).toFixed(d);
}
function formatNumber(x){
  const n = Number(x);
  if(!Number.isFinite(n)) return String(x);
  if(Math.abs(n - Math.round(n)) < 1e-9) return String(Math.round(n));
  return roundTo(n, 2);
}
function parseNumberList(s){
  if(s==null) return [];
  const raw = String(s).replace(/[،]/g, ",").trim();
  if(!raw) return [];
  return raw.split(",").map(x=>x.trim()).filter(Boolean).map(x=>Number(x)).filter(x=>Number.isFinite(x)).sort((a,b)=>a-b);
}
function sameNumberList(a,b){
  const A=parseNumberList(a), B=parseNumberList(b);
  if(A.length!==B.length) return false;
  for(let i=0;i<A.length;i++){
    if(Math.abs(A[i]-B[i])>1e-9) return false;
  }
  return true;
}

function latexFix(s){
  if(s==null) return "";
  // Reduce doubled backslashes produced by JS string escaping
  return String(s).replace(/\\\\/g, "\\");
}

/* ===== نافذة منبثقة ===== */
function openModal(title, html){
  document.getElementById("modalTitle").textContent = title;
  document.getElementById("modalBody").innerHTML = html;
  document.getElementById("modal").classList.add("show");
  typesetMath(document.getElementById("modalBody"));
}
function closeModal(){ document.getElementById("modal").classList.remove("show"); }
window.closeModal = closeModal;
document.getElementById("closeModal").onclick = closeModal;
document.getElementById("modal").addEventListener("click", (e)=>{ if(e.target.id==="modal") closeModal(); });

function typesetMath(root){
  if(!root) return;
  try{
    if(window.renderMathInElement){
      window.renderMathInElement(root, {
        delimiters: [
          {left: "\\(", right: "\\)", display: false},
          {left: "\\[", right: "\\]", display: true}
        ],
        throwOnError: false
      });
    }
  }catch(e){}
}

/* ===== بنك الأسئلة (الوحدة 4 | 4.1) ===== */
const TEMPLATES = [
  {
    id:"q1_circle_pool",
    icon:"①",
    title:"ضع دائرة — مفاهيم الارتباط وبيرسون",
    gen:(variant)=>{
      const r = seededRand("q1_circle_pool|"+variant);

      const fmt = (v)=> (v>=0 ? "+" : "") + (Math.round(v*100)/100).toFixed(2);
      const pickR = ()=>{
        const mag = randInt(r, 25, 95)/100; // 0.25..0.95
        const sign = (randInt(r,0,1)===0) ? -1 : 1;
        return sign*mag;
      };
      const pickNiceR = ()=>{
        const choices = [0.2,0.4,0.5,0.6,0.7,0.8,0.9];

}
.irtSE{
  font-size:11px;
  font-weight:800;
  color:var(--muted);
  background:#f1f5f9;
  border-radius:8px;
  padding:6px 10px;
  text-align:center;
}

/* ٣. محلل نمط الأخطاء */
.errorPatternCard{display:grid;gap:10px}
.errorTypeRow{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;border-radius:12px;
  border:1px solid var(--line);
  background:#f8fbff;
}
.errorTypeBadge{
  font-size:11px;font-weight:900;padding:4px 10px;border-radius:8px;white-space:nowrap;
}
.errorTypeBadge.conceptual{background:#fee2e2;color:#dc2626;border:1px solid rgba(220,38,38,.2)}
.errorTypeBadge.computational{background:#fef3c7;color:#d97706;border:1px solid rgba(217,119,6,.2)}
.errorTypeBadge.application{background:#ede9fe;color:#7c3aed;border:1px solid rgba(124,58,237,.2)}
.errorTypeBadge.none{background:#d1fae5;color:#059669;border:1px solid rgba(5,150,105,.2)}
.errorTypeDetail{flex:1;min-width:0}
.errorTypeName{font-size:12px;font-weight:900;color:var(--ink);margin-bottom:2px}
.errorTypeAdvice{font-size:11px;font-weight:800;color:var(--muted);line-height:1.5}
.errorTypeCount{font-size:18px;font-weight:900;color:var(--brand2);flex:0 0 auto}
.errorBarWrap{display:flex;gap:3px;height:6px;border-radius:999px;overflow:hidden;background:#edf4fb}
.errorBarSeg{height:100%;border-radius:999px;transition:width .5s ease}

/* ٤. معايرة الثقة */
.calibCard{display:grid;gap:12px}
.calibMatrix{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
}
.calibCell{
  border-radius:12px;
  border:1px solid var(--line);
  background:#f8fbff;
  padding:10px 8px;
  text-align:center;
}
.calibCellVal{font-size:20px;font-weight:900;color:var(--brand2)}
.calibCellLabel{font-size:10px;font-weight:900;color:var(--muted);margin-top:3px;line-height:1.4}
.calibDiag{
  font-size:12px;font-weight:800;line-height:1.8;
  padding:10px 12px;border-radius:12px;
  background:#f1f5f9;border:1px solid var(--line);
  color:#334155;
}
.calibScore{
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  padding:8px 12px;border-radius:10px;
  font-size:12px;font-weight:900;
}
.calibScore.good{background:#d1fae5;color:#059669}
.calibScore.warn{background:#fef3c7;color:#d97706}
.calibScore.bad{background:#fee2e2;color:#dc2626}

/* ٥. توقع الدرجة */
.gradeCard{display:grid;gap:12px}
.gradeBig{

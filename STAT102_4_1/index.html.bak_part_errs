<script>
/* ===== أدوات عشوائية (Seeded RNG) ===== */
function xmur3(str){
  let h = 1779033703 ^ str.length;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
    h = (h << 13) | (h >>> 19);
  }
  return function(){
    h = Math.imul(h ^ (h >>> 16), 2246822507);
    h = Math.imul(h ^ (h >>> 13), 3266489909);
    return (h ^= h >>> 16) >>> 0;
  }
}
function mulberry32(a){
  return function(){
    let t = a += 0x6D2B79F5;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  }
}
function seededRand(seedStr){
  const seed = xmur3(seedStr)();
  return mulberry32(seed);
}
function randInt(r, lo, hi){ return Math.floor(r()*(hi-lo+1))+lo; }

/* ===== حالة الصفحة (تُحفظ فقط عند ضغط حفظ الإجابة) ===== */
const STATE_KEY = "stat102_4_1_state_v2";
const TIMER_MINUTES = 30;
const TIMER_KEY = "stat102_4_1_timerEnd_v2";
// Safe storage wrapper (works even if localStorage is blocked)
const __storage = (function(){
  try{
    const k="__stat102_test__";
    window.storageSet(k,"1");
    window.storageRemove(k);
    return window.localStorage;
  }catch(e){
    return null;
  }
})();
function storageGet(key){ try{ return __storage ? __storage.getItem(key) : null; }catch(e){ return null; } }
function storageSet(key, val){ try{ if(__storage) __storage.setItem(key, val); }catch(e){} }
function storageRemove(key){ try{ if(__storage) __storage.removeItem(key); }catch(e){} }

const state = loadState() || { currentIndex: 0, variants: {}, branches: {}, order: null, activeOrder: null, masteryVersion: null, masterySupportCount: 0, masterySupportLog: [], masterySupportSources: {}, timerEnded: false, dirty: {}, sidebarFilter: "all", fontSize: 0 };
function saveState(){ storageSet(STATE_KEY, JSON.stringify(state)); }
function loadState(){ try{ const s = JSON.parse(storageGet(STATE_KEY)); if(s){ s.timerEnded = !!s.timerEnded; if(!s.dirty) s.dirty = {}; if(!s.sidebarFilter) s.sidebarFilter = "all"; if(s.fontSize==null) s.fontSize = 0; } return s; }catch(e){ return null; } }

let timerInterval = null;
function startTimer(){
  let endAt = null;
  try{ const v = storageGet(TIMER_KEY); if(v) endAt = parseInt(v,10); }catch(e){}
  if(endAt == null || endAt < Date.now()){
    endAt = Date.now() + TIMER_MINUTES * 60 * 1000;
    storageSet(TIMER_KEY, String(endAt));
  }
  if(endAt != null && endAt > Date.now()){
    state.timerEnded = false;
    saveState();
    renderAll();
  }
  let oneMinuteWarned = false;
  function tick(){
    if(state.timerEnded) return;
    const rem = Math.max(0, Math.ceil((endAt - Date.now()) / 1000));
    const el = document.getElementById("timerBar");
    if(!el) return;
    const m = Math.floor(rem/60), s = rem % 60;
    el.textContent = "الوقت المتبقي: " + m + ":" + (s<10?"0":"") + s;
    el.classList.remove("warn","done");
    if(rem <= 60) el.classList.add("warn");
    if(rem === 60 && !oneMinuteWarned){ oneMinuteWarned = true; openModal("تنبيه", `
      <div class="modal-warn-body">
        <div class="modal-warn-icon">⏰</div>
        <div>
          <div class="modal-warn-title">دقيقة واحدة متبقية</div>
          <div class="modal-warn-text">احفظ إجاباتك إن لم تكن محفوظة بعد.</div>
        </div>
      </div>
    `); }
    if(rem === 0){
      if(timerInterval) clearInterval(timerInterval);
      timerInterval = null;
      window.__examRunning = false;
      state.timerEnded = true;
      saveState();
      el.textContent = "انتهى الوقت";
      el.classList.add("done");
      showResultsModal();
      renderAll();
    }
  }
  tick();
  if(timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(tick, 1000);
}

function resetAll(){
  try{
    var _k = (typeof AI_MODELS_KEY !== "undefined") ? AI_MODELS_KEY : null;
    if(_k){
      var _s = null;
      try{ _s = JSON.parse(localStorage.getItem(_k) || "null"); }catch(_e){}
      if(_s && typeof _s === "object"){
        _s.examAttempts = (Number(_s.examAttempts) || 0) + 1;
        localStorage.setItem(_k, JSON.stringify(_s));
      }
    }
  }catch(_e){}
  state.currentIndex = 0;
  state.variants = {};
  state.branches = {};
  state.order = null;
  state.timerEnded = false;
  state.dirty = {};
  state.sidebarFilter = "all";
  state.fontSize = 0;
  storageRemove(TIMER_KEY);
  saveState();
  location.reload();
}

.modal .box .mh b{ font-size:16px; font-weight:900; }







/* ═══════════════════════════════════════════════
   تصميم جامعي — نظام ألوان رسمي
═══════════════════════════════════════════════ */
:root{
  --uni-gold: #C8972A;
  --uni-gold-light: #FDF6E3;
  --uni-gold-border: rgba(200,151,42,.25);
  --uni-green: #1a6b3c;
}

/* شريط علوي — هوية أكاديمية */
.topbar{
  background:linear-gradient(135deg,#0b3c5d 0%,#154360 40%,#0d3349 100%) !important;
  border-bottom:3px solid var(--uni-gold);
}
.topbar.scrolled{
  box-shadow:0 4px 30px rgba(11,60,93,.45) !important;
}

/* شريط ذهبي دقيق تحت الـ topbar */
.topbar::after{
  content:"";
  position:absolute;
  bottom:-3px; left:0; right:0;
  height:3px;
  background:linear-gradient(90deg,transparent,var(--uni-gold),transparent);
  opacity:.6;
}

/* Cards — حدود أكاديمية */
.card{
  border-top:3px solid var(--brand) !important;
  border-radius:18px;
}

/* Section titles — طراز أكاديمي */
.mainhead{
  background:linear-gradient(180deg,#f0f7ff 0%,#ffffff 100%);
  border-bottom:2px solid var(--uni-gold-border);
}
.mainhead::after{
  content:"";
  display:block;
  position:absolute;
  bottom:0; left:20px; right:20px;
  height:1px;
  background:linear-gradient(90deg,transparent,var(--uni-gold),transparent);
  opacity:.5;
}
.mainhead{ position:relative; }

/* شارة الجامعة على السؤال */
.pill{
  background:linear-gradient(135deg,var(--uni-gold-light),#fff8e7);
  color:#8B6914;
  border-color:var(--uni-gold-border);
  font-weight:900;
}

/* ═══════════════════════════════════════════════
   تحسين شاشة الإجابة الصحيحة
═══════════════════════════════════════════════ */
.choice.goodField{
  background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 100%) !important;
  border-color:#16a34a !important;
  border-width:2px !important;
  color:#15803d !important;
  box-shadow:0 0 0 4px rgba(22,163,74,.12), 0 4px 14px rgba(22,163,74,.1) !important;
  position:relative;
}
.choice.goodField::after{
  content:"✓ صحيح";
  position:absolute;
  left:14px; top:50%;
  transform:translateY(-50%);
  font-size:11px;font-weight:900;
  color:#15803d;
  background:#dcfce7;
  padding:3px 8px;border-radius:6px;
  border:1px solid rgba(22,163,74,.3);
}
.choice.badField{
  background:linear-gradient(135deg,#fff5f5 0%,#fee2e2 100%) !important;
  border-color:#dc2626 !important;
  border-width:2px !important;
  color:#b91c1c !important;
  box-shadow:0 0 0 4px rgba(220,38,38,.1) !important;
  position:relative;
}
.choice.badField::after{
  content:"✗ خطأ";
  position:absolute;
  left:14px; top:50%;
  transform:translateY(-50%);
  font-size:11px;font-weight:900;
  color:#b91c1c;
  background:#fee2e2;
  padding:3px 8px;border-radius:6px;
  border:1px solid rgba(220,38,38,.25);
}
input.goodField, textarea.goodField{
  border-color:#16a34a !important;
  background:linear-gradient(135deg,#f0fdf4,#dcfce7) !important;
  box-shadow:0 0 0 3px rgba(22,163,74,.15) !important;
}
input.badField, textarea.badField{
  border-color:#dc2626 !important;
  background:linear-gradient(135deg,#fff5f5,#fee2e2) !important;
  box-shadow:0 0 0 3px rgba(220,38,38,.12) !important;
}

/* ═══════════════════════════════════════════════
   تطوير صفحة النتائج
═══════════════════════════════════════════════ */
.scoreCard{
  border-radius:20px !important;
  background:linear-gradient(135deg,#0b3c5d 0%,#154360 60%,#1a6b3c 100%) !important;
  border:none !important;
  color:#fff !important;
  padding:24px !important;
  box-shadow:0 20px 40px rgba(11,60,93,.25) !important;
  position:relative;
  overflow:hidden;
}
.scoreCard::before{
  content:"";
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(90deg,rgba(255,255,255,.04) 0 1px,transparent 1px 20px);
  pointer-events:none;
}
.scoreCard::after{
  content:"";
  position:absolute;
  bottom:0; left:0; right:0;
  height:4px;
  background:linear-gradient(90deg,var(--uni-gold),#fde68a,var(--uni-gold));
}
.scoreBig{
  font-size:24px !important;
  font-weight:900 !important;
  color:#fff !important;
  position:relative;
}
.scoreSub{ color:rgba(255,255,255,.8) !important; position:relative; }
.score-bar-wrap{
  background:rgba(255,255,255,.15) !important;
  height:10px !important;
  border-radius:999px;
  position:relative;
}
.score-bar-correct{
  background:linear-gradient(90deg,#34d399,#a7f3d0) !important;
}

/* بطاقات النتائج */
.resultCard{
  border-radius:16px !important;
  border:1px solid var(--line) !important;
  box-shadow:0 4px 16px rgba(15,23,42,.06) !important;
  overflow:hidden;
  transition:var(--transition);
}
.resultCard:hover{
  border-color:var(--brand) !important;
  box-shadow:0 8px 24px rgba(3,105,161,.1) !important;
  transform:translateY(-1px);
}
/* رأس بطاقة النتيجة */
.resultCard > div:first-child{
  background:linear-gradient(180deg,#f8fbff 0%,#ffffff 100%);
  padding:14px 16px 12px !important;
  border-bottom:1px solid var(--line);
  margin-bottom:0 !important;
}

.tag.good{
  background:linear-gradient(135deg,#dcfce7,#f0fdf4) !important;
  border-color:rgba(22,163,74,.3) !important;
  color:#15803d !important;
  font-weight:900;
  padding:6px 14px;
}
.tag.bad{
  background:linear-gradient(135deg,#fee2e2,#fff5f5) !important;
  border-color:rgba(220,38,38,.3) !important;
  color:#b91c1c !important;
  font-weight:900;
  padding:6px 14px;
}

/* صفوف الأجزاء */
.partRow{
  border-radius:10px !important;
  border:1px solid var(--line) !important;
  background:#f8fbff !important;
  padding:12px 16px !important;
  font-size:13px;
  transition:var(--transition);
}
.partRow:hover{ background:#eef6ff !important; border-color:rgba(3,105,161,.2) !important; }

/* أزرار النتيجة */
.scoreCard .btn.primary{
  background:linear-gradient(135deg,var(--uni-gold),#b07d20) !important;
  border:none !important;
  box-shadow:0 4px 14px rgba(200,151,42,.35) !important;
  color:#fff !important;
  position:relative;
}
.scoreCard .btn.primary:hover{
  background:linear-gradient(135deg,#d4a43a,var(--uni-gold)) !important;
  transform:translateY(-2px) !important;
  box-shadow:0 8px 20px rgba(200,151,42,.45) !important;
}
:root{
  --shadow-sm: 0 1px 2px rgba(15,23,42,.04), 0 2px 8px rgba(15,23,42,.06);
  --shadow:    0 4px 6px rgba(15,23,42,.04), 0 10px 28px rgba(15,23,42,.08);
  --shadow-lg: 0 20px 25px rgba(15,23,42,.08), 0 40px 60px rgba(15,23,42,.12);
}
/* Topbar — Glass أقوى */
.topbar{
  backdrop-filter:blur(20px) saturate(180%);
  -webkit-backdrop-filter:blur(20px) saturate(180%);
  border-bottom:1px solid rgba(255,255,255,.1);
}
/* Scroll-linked shadow على الـ topbar */
.topbar.scrolled{ box-shadow:0 4px 30px rgba(15,23,42,.3); }

/* Cards — ضلع علوي ملون + hover أجمل */
.card{ border-top:3px solid var(--brand); }
.card:hover{ box-shadow:0 12px 36px rgba(15,23,42,.11); transform:translateY(-1px); }

/* Progress bar — shimmer متحرك */
.progress{
  height:8px;
  box-shadow:inset 0 1px 3px rgba(0,0,0,.07);
}
.progress > div{
  background-size:200% 100%;
  animation:progressShimmer 2.4s linear infinite;
  background-image:linear-gradient(90deg, #0369a1 0%, #38bdf8 50%, #0369a1 100%);
}
@keyframes progressShimmer{
  0%{background-position:100% 0}
  100%{background-position:-100% 0}
}

/* Question number badge */
.qtitle .qnum{
  background:linear-gradient(135deg, var(--brand), var(--brand2));
  color:#fff;
  border:none;
  box-shadow:0 6px 16px rgba(3,105,161,.3);
  font-size:17px;
  width:44px; height:44px;
  border-radius:14px;
}

/* MCQ choices — تحسين التفاعل */
.choice{
  position:relative;
  transition:all .2s cubic-bezier(.4,0,.2,1);
  border-width:2px;
}
.choice:hover{ transform:translateX(-3px); box-shadow:0 4px 14px rgba(3,105,161,.12); }
.choice.goodField{
  box-shadow:0 0 0 3px rgba(5,150,105,.18);
  animation:correctPop .3s ease;
}
.choice.badField{ box-shadow:0 0 0 3px rgba(220,38,38,.15); }
@keyframes correctPop{
  0%{transform:scale(1)}
  50%{transform:scale(1.02)}
  100%{transform:scale(1)}
}

/* Difficulty tags */
.btag{ letter-spacing:.04em; text-transform:uppercase; font-size:11px; border-radius:8px; }

/* Timer */
.timerBar{
  font-variant-numeric:tabular-nums;
  letter-spacing:.06em;
  font-size:16px;
  padding:8px 18px;
  background:rgba(255,255,255,.15);
  border:1px solid rgba(255,255,255,.3);
  border-radius:14px;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.2);
}

/* AI Model cards — hover مع خط سفلي */
.aiModelCard{
  transition:transform .2s, box-shadow .2s;
  cursor:default;
}
.aiModelCard::after{
  content:"";
  position:absolute;
  bottom:0; left:0; right:0;
  height:3px;
  background:linear-gradient(90deg, var(--brand), #38bdf8);
  transform:scaleX(0);
  transition:transform .3s;
  transform-origin:right;
  border-radius:0 0 4px 4px;
}
.aiModelCard:hover{ transform:translateY(-2px); box-shadow:0 10px 28px rgba(15,23,42,.1); }
.aiModelCard:hover::after{ transform:scaleX(1); }


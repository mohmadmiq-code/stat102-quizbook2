    const statusText = ensemble < 0.45
      ? "هناك حاجة إلى دعم إضافي قبل السؤال التالي."
      : (ensemble < 0.7
        ? "الوضع متوسط ويحتاج إلى تثبيت أكثر."
        : "الأداء الحالي يوحي بجاهزية جيدة للسؤال التالي.");
    return `الموضوع الأقوى حاليًا: «${strong ? strong.label : "—"}»، والموضوع الذي يحتاج إلى مراجعة: «${weak.label}». ${statusText}`;
  }


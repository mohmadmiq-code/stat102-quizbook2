function computeScore(){
  let total=0, correct=0;
  BANK.forEach(q=>{
    q.branches.forEach((branch,bi)=>{
      const rec = ensureBranchRec(q.id,bi);
      const keys = collectPartKeys(branch);
      const grade = gradeBranch(q, branch, bi, rec.saved||{});
      keys.forEach(k=>{
        total++;
        if(grade.byKey[k]) correct++;
      });
    });
  });
  const pct = total? (correct/total)*100 : 0;
  return {correct,total,pct:Math.round(pct*10)/10};
}


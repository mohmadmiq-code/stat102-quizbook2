const MASTERY_VERSION = "stat102_4_1_mastery_v2";
const MASTERY_CORE = ["q1_circle_pool", "q3_compute_r", "q5_r_context_interpretation"];
const MASTERY_PROFILES = {
  q1_circle_pool:{supports:["q2_pearson_props_9","q4_scatter_plot","q6_smart_transform"]},
  q3_compute_r:{supports:["q5_r_context_interpretation","q2_pearson_props_9","q6_smart_transform"]},
  q5_r_context_interpretation:{supports:["q4_scatter_plot","q2_pearson_props_9","q6_smart_transform"]},
  q4_scatter_plot:{supports:["q1_circle_pool","q5_r_context_interpretation","q2_pearson_props_9"]},
  q6_smart_transform:{supports:["q2_pearson_props_9","q5_r_context_interpretation","q3_compute_r"]}
};

function normalizeAdaptiveOrder(order){
  const ids = TEMPLATES.map(t=>t.id);
  const seen = new Set();
  return (Array.isArray(order) ? order : []).filter(id=>{
    if(!ids.includes(id) || seen.has(id)) return false;
    seen.add(id);
    return true;
  });
}

function ensureAdaptiveState(){
  const ids = TEMPLATES.map(t=>t.id);
  const core = MASTERY_CORE.filter(id=>ids.includes(id));
  let active = normalizeAdaptiveOrder(state.activeOrder);
  if(state.masteryVersion !== MASTERY_VERSION || active.length===0){
    const r = seededRand("mastery-core|" + Date.now() + "|" + Math.random());
    active = shuffleInPlace([...core], r);
    state.masteryVersion = MASTERY_VERSION;
    state.activeOrder = active;
    state.order = active.slice();
    state.masterySupportCount = 0;
    state.masterySupportLog = [];
    state.masterySupportSources = {};
    saveState();
  }else if(active.length !== (state.activeOrder || []).length){
    state.activeOrder = active;
    state.order = active.slice();
    saveState();
  }
  if(state.currentIndex >= state.activeOrder.length){
    state.currentIndex = Math.max(0, state.activeOrder.length - 1);
    saveState();
  }
  return state.activeOrder;
}

function chooseSupportId(qid){
  const active = ensureAdaptiveState();
  const ids = TEMPLATES.map(t=>t.id);
  const pools = [];
  if(qid && MASTERY_PROFILES[qid]) pools.push(MASTERY_PROFILES[qid].supports || []);
  pools.push(MASTERY_CORE.filter(id=>id!==qid));
  pools.push(ids);
  for(const pool of pools){
    for(const id of pool){
      if(ids.includes(id) && !active.includes(id)) return id;
    }
  }
  return null;
}

function addAdaptiveSupportFor(qid, reason){
  const active = ensureAdaptiveState();
  const sourceKey = qid || "general";
  state.masterySupportSources = state.masterySupportSources || {};
  if((state.masterySupportSources[sourceKey] || 0) >= 1) return null;
  const nextId = chooseSupportId(qid);
  if(!nextId) return null;
  active.push(nextId);
  state.activeOrder = active;
  state.order = active.slice();
  state.masterySupportSources[sourceKey] = (state.masterySupportSources[sourceKey] || 0) + 1;
  state.masterySupportCount = (state.masterySupportCount || 0) + 1;
  state.masterySupportLog = state.masterySupportLog || [];
  state.masterySupportLog.push({ source: sourceKey, support: nextId, reason: reason || "mastery", at: Date.now() });
  saveState();
  return nextId;
}

function maybeQueueAdaptiveSupport(question){
  if(!window.__examRunning || !question) return null;
  if(isQuestionWrong(question)) return addAdaptiveSupportFor(question.id, "wrong");
  return null;
}

function ensureSupportForWeakQuestions(){
  if(!window.__examRunning) return false;
  ensureAdaptiveState();
  const activeSet = new Set(state.activeOrder || []);
  const activeQuestions = BANK.filter(q=>activeSet.has(q.id));
  const done = activeQuestions.filter(q=>isQuestionComplete(q));
  const wrong = done.filter(q=>isQuestionWrong(q));
  let added = false;
  wrong.forEach(q=>{ if(addAdaptiveSupportFor(q.id, "locked")) added = true; });
  if(!added && done.length > 0 && done.length === activeQuestions.length && state.activeOrder.length < TEMPLATES.length){
    const correctCount = done.filter(q=>isQuestionCorrect(q)).length;
    const masteryRatio = correctCount / done.length;
    if(masteryRatio < 0.85){
      const anchor = wrong[0] || done.find(q=>!isQuestionCorrect(q)) || done[done.length-1];
      if(addAdaptiveSupportFor(anchor && anchor.id, "mastery-threshold")) added = true;
    }
  }
  if(added) BANK = buildBank();
  return added;
}

function buildBank(){
  const order = ensureAdaptiveState();
  const bank = order.map(buildQuestionById).filter(Boolean);
  if(bank.length) return bank;
  state.activeOrder = TEMPLATES.slice(0, Math.min(3, TEMPLATES.length)).map(t=>t.id);
  state.order = state.activeOrder.slice();
  saveState();
  return state.activeOrder.map(buildQuestionById).filter(Boolean);
}


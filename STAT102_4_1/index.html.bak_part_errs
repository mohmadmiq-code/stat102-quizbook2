<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>جامعة الملك سعود — السنة الأولى المشتركة — STAT 102 | 4.1 الارتباط ومعامل ارتباط بيرسون</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Symbols+2&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#f8fafc;
      --bg-warm:#fefefe;
      --card:#ffffff;
      --ink:#0f172a;
      --ink-soft:#1e293b;
      --muted:#64748b;
      --brand:#0369a1;
      --brand2:#0c4a6e;
      --brand-light:#e0f2fe;
      --accent:#0284c7;
      --accent-hover:#0ea5e9;
      --good:#059669;
      --good-bg:#d1fae5;
      --bad:#dc2626;
      --bad-bg:#fee2e2;
      --warn:#d97706;
      --warn-bg:#fef3c7;
      --line:#e2e8f0;
      --line-soft:#f1f5f9;
      --shadow-sm: 0 1px 3px rgba(15,23,42,.06);
      --shadow: 0 4px 20px rgba(15,23,42,.07);
      --shadow-lg: 0 20px 50px rgba(15,23,42,.1);
      --r:16px;
      --r-lg:22px;
      --font:"Cairo", "Noto Sans Symbols 2", system-ui, -apple-system, sans-serif;
      --transition: .2s cubic-bezier(.4,0,.2,1);
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:var(--font);
      color:var(--ink);
      line-height:1.6;
      background:
        radial-gradient(ellipse 140% 80% at 90% 0%, rgba(3,105,161,.06), transparent 50%),
        radial-gradient(ellipse 100% 60% at 10% 100%, rgba(12,74,110,.04), transparent 45%),
        var(--bg);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .topbar{
      background: linear-gradient(135deg, var(--brand2) 0%, var(--brand) 50%, #0e7490 100%);
      color:#fff;
      padding:16px 14px;
      min-height:80px;
      position:sticky; top:0; z-index:10;
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(8px);
    }
    .topbar .row{
      max-width:1280px;
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      position:relative;
      gap:16px;
      padding:12px 80px;
      min-height:56px;
    }
    .topbar .row .topbarRight{display:flex; align-items:center; gap:8px; flex:0 0 auto;}
    .topbar .row .timerBar{flex:0 0 auto;}
    .topbar .row .brandblock{position:absolute; left:50%; transform:translateX(-50%); display:flex; align-items:center; justify-content:center; gap:14px; min-width:0; max-width:55%; text-align:center;}
    .topbar .row .logoWrap{flex:0 0 auto;}
    .brandblock{display:flex; align-items:center; gap:14px; min-width:0; text-align:center;}
    .brandtext{min-width:0; text-align:center}
    .brandtext .u{font-size:19px;font-weight:800;letter-spacing:-.02em;line-height:1.2}
    .brandtext .u.en{font-size:13px;font-weight:700;opacity:.9;margin-top:2px;direction:ltr;unicode-bidi:embed;letter-spacing:.03em}
    .sep{opacity:.6;margin:0 6px;font-weight:600;font-size:12px}
    .brandtext .d{font-size:13px;font-weight:700;opacity:.92;margin-top:2px;line-height:1.3}
    .brandtext .s{font-size:12px;opacity:.85;margin-top:2px;font-weight:600}

    .timerBar{font-size:14px;font-weight:800;white-space:nowrap;padding:6px 12px;background:rgba(255,255,255,.2);border-radius:10px;border:1px solid rgba(255,255,255,.35);min-width:90px;text-align:center;}
    .timerBar.warn{background:rgba(217,119,6,.4);border-color:rgba(255,255,255,.5);}
    .timerBar.done{background:rgba(220,38,38,.4);border-color:rgba(255,255,255,.5);}

    .logoWrap{
      position:absolute;
      left:14px;
      top:50%;
      transform:translateY(-50%);
      display:flex; align-items:center; justify-content:center;
      padding:10px 12px;
      background: rgba(255,255,255,.18);
      border:1px solid rgba(255,255,255,.35);
      border-radius:12px;
      box-shadow:
        0 12px 24px rgba(0,0,0,.2),
        0 0 0 4px rgba(30,167,255,.10);
      flex:0 0 auto;
      transition: var(--transition);
    }
    .logoWrap:hover{background:rgba(255,255,255,.25);transform:translateY(-50%) scale(1.02)}
    .logoWrap img{height:52px;width:auto;display:block;}

    .wrap{
      max-width:900px;
      margin:24px auto 40px;
      padding:0 24px;
      display:block;
    }
    @media (min-width:1100px){
      .wrap{ max-width:calc(66.666vw); }
    }
    @media (max-width: 820px){ .wrap{ max-width:100%; padding:0 12px; } }
    /* إخفاء اللوحات الجانبية من الشبكة – ستُعرض كدرج عائم */
    .side, .aiResultsRail { display:none !important; }

    .card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--r-lg);
      box-shadow: var(--shadow);
      overflow:hidden;
      transition: var(--transition);
    }
    .card:hover{box-shadow: 0 8px 30px rgba(15,23,42,.09)}
    .mainhead{
      padding:12px 16px;
      border-bottom:1px solid var(--line);
      display:flex; gap:10px; align-items:center; justify-content:center;
      background: linear-gradient(180deg, var(--line-soft) 0%, var(--card) 100%);
    }
    .pill{
      background:var(--brand-light);color:var(--brand);border:1px solid rgba(3,105,161,.25);
      border-radius:999px;padding:6px 12px;font-weight:700;font-size:12px;white-space:nowrap;
    }
    .pill.warn{background:var(--warn-bg);color:var(--warn);border-color:rgba(217,119,6,.3)}
    .content{padding:20px 22px 24px}

    .qtitleRow{display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:16px; flex-wrap:wrap;}
    .qtitle{display:flex; align-items:center; gap:12px; font-size:17px; font-weight:800; color:var(--ink); min-width:0;}
    .qtitle .qnum{
      width:42px;height:42px;border-radius:12px;display:grid;place-items:center;
      background: linear-gradient(135deg, var(--brand-light), #bae6fd);
      border:1px solid rgba(3,105,161,.2);color:var(--brand);font-weight:800;flex:0 0 auto;
      font-size:16px;
    }
    .qmeta{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}

    .btn{
      border:1px solid var(--line);
      background:var(--card);
      color:var(--ink);
      border-radius:12px;
      padding:10px 16px;
      font-weight:800;
      font-size:14px;
      cursor:pointer;
      transition: var(--transition);
      display:inline-flex; align-items:center; gap:8px;
      user-select:none;
      white-space:nowrap;
      font-family:var(--font);
    }
    .btn:hover{
      background:var(--line-soft);
      border-color:var(--muted);
      transform:translateY(-1px);
      box-shadow: var(--shadow-sm);
    }
    .btn.primary{
      background: linear-gradient(135deg, var(--brand), var(--brand2));
      border-color: transparent;
      color:#fff;
    }
    .btn.primary:hover{
      background: linear-gradient(135deg, var(--accent), var(--brand));
      box-shadow: 0 4px 16px rgba(3,105,161,.35);
    }
    .btn.small{padding:8px 14px;font-size:13px;border-radius:10px}
    .btn:disabled{cursor:not-allowed;opacity:.55;transform:none;box-shadow:none}
        .btn.ai-help-btn{
      position:relative;
      isolation:isolate;
      border:1px solid rgba(8,145,178,.34);
      background:
        linear-gradient(135deg, rgba(224,242,254,.98) 0%, rgba(240,249,255,.98) 52%, rgba(207,250,254,.98) 100%);
      color:var(--brand2);
      font-weight:900;
      overflow:hidden;
      box-shadow:0 10px 24px rgba(8,145,178,.16);
    }
    .btn.ai-help-btn::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(115deg, transparent 0 28%, rgba(255,255,255,.78) 45%, transparent 62%),
        repeating-linear-gradient(90deg, rgba(14,165,233,.09) 0 1px, transparent 1px 12px);
      opacity:.9;
      transform:translateX(-26%);
      transition:transform .45s ease;
      z-index:-1;
    }
    .btn.ai-help-btn::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:inherit;
      pointer-events:none;
      box-shadow:0 0 0 0 rgba(8,145,178,.28);
      animation:aiPulse 2.4s infinite;
    }
    .btn.ai-help-btn:hover{
      border-color:#0891b2;
      background:linear-gradient(135deg, #dbeafe 0%, #e0f7ff 48%, #ccfbf1 100%);
      box-shadow:0 14px 28px rgba(8,145,178,.24);
      transform:translateY(-2px) scale(1.01);
    }
    .btn.ai-help-btn:hover::before{transform:translateX(6%)}
    .btn.ai-help-btn:hover .ai-help-glyph{animation:aiWake .9s ease both}
    .ai-help-glyph{
      width:22px;
      height:22px;
      border-radius:8px;
      display:inline-grid;
      place-items:center;
      position:relative;
      background:linear-gradient(135deg, #0f172a, #0369a1 72%, #22d3ee 100%);
      color:#fff;
      font-size:11px;
      font-weight:900;
      letter-spacing:.04em;
      box-shadow:0 6px 16px rgba(3,105,161,.28);
    }
    .ai-help-glyph::before,
    .ai-help-glyph::after{
      content:"";
      position:absolute;
    }
    .ai-help-glyph::before{
      inset:3px;
      border:1.5px solid rgba(255,255,255,.72);
      border-radius:4px;
      opacity:.88;
    }
    .ai-help-glyph::after{
      width:6px;
      height:6px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 0 2px rgba(255,255,255,.18), 0 0 14px rgba(103,232,249,.9);
    }
    .ai-help-panel{
      display:grid;
      gap:16px;
      animation:aiPanelReveal .38s ease both;
    }
    .ai-help-hero{
      position:relative;
      animation:aiHeroFloat 5.2s ease-in-out infinite;
      overflow:hidden;
      display:flex;
      align-items:center;
      gap:16px;
      padding:18px;
      border-radius:18px;
      border:1px solid rgba(8,145,178,.22);
      background:
        radial-gradient(circle at 18% 22%, rgba(34,211,238,.24), transparent 28%),
        radial-gradient(circle at 88% 18%, rgba(59,130,246,.18), transparent 24%),
        linear-gradient(135deg, #082f49 0%, #0f172a 48%, #0c4a6e 100%);
      color:#fff;
      box-shadow:0 18px 40px rgba(15,23,42,.18);
    }
    .ai-help-hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:repeating-linear-gradient(90deg, rgba(255,255,255,.06) 0 1px, transparent 1px 16px);
      opacity:.35;
      pointer-events:none;
    }
    .ai-help-orb{
      width:72px;
      height:72px;
      border-radius:22px;
      flex:0 0 auto;
      display:grid;
      place-items:center;
      position:relative;
      border:1px solid rgba(255,255,255,.2);
      background:linear-gradient(135deg, rgba(255,255,255,.2), rgba(255,255,255,.08));
      box-shadow:inset 0 1px 0 rgba(255,255,255,.18), 0 14px 28px rgba(8,145,178,.22);
    }
    .ai-help-orb::before,
    .ai-help-orb::after{
      content:"";
      position:absolute;
      border-radius:50%;
      border:1px solid rgba(103,232,249,.55);
    }
    .ai-help-orb::before{inset:10px}
    .ai-help-orb::after{inset:20px;border-color:rgba(255,255,255,.65)}
    .ai-help-orb span{
      width:14px;
      height:14px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 18px rgba(103,232,249,.95);
      animation:aiCorePulse 2.8s ease-in-out infinite;
    }
    .ai-help-copy{position:relative;z-index:1;display:grid;gap:6px}
    .ai-help-kicker{
      display:inline-flex;
      align-items:center;
      gap:8px;
      width:max-content;
      padding:5px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.16);
      font-size:11px;
      font-weight:800;
      letter-spacing:.08em;
    }
    .ai-help-kicker::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:50%;
      background:#67e8f9;
      box-shadow:0 0 10px rgba(103,232,249,.9);
    }
    .ai-help-title{
      font-size:18px;
      font-weight:900;
      line-height:1.5;
    }
    .ai-help-subtitle{
      color:rgba(255,255,255,.82);
      font-size:13px;
      font-weight:700;
      line-height:1.9;
    }
    .ai-help-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:14px;
    }
    .ai-help-section{
      position:relative;
      overflow:hidden;
      border:1px solid rgba(148,163,184,.24);
      border-radius:16px;
      padding:16px;
      background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      box-shadow:0 10px 28px rgba(15,23,42,.07);
    }
    .ai-help-section::before{
      content:"";
      position:absolute;
      inset:0 auto 0 0;
      width:4px;
      background:linear-gradient(180deg, #22d3ee, #0369a1);
    }
    .ai-help-section-head{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:10px;
      font-size:15px;
      font-weight:900;
      color:var(--ink);
    }
    .ai-help-chip-icon{
      width:34px;
      height:34px;
      border-radius:11px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg, rgba(8,145,178,.16), rgba(14,165,233,.08));
      color:var(--brand2);
      border:1px solid rgba(8,145,178,.2);
      font-size:16px;
    }
    .ai-help-body{
      color:var(--ink-soft);
      font-size:14px;
      font-weight:700;
      line-height:1.95;
    }
    .ai-help-body ul,
    .ai-help-body ol{margin:0;padding-right:18px}
    @media (max-width: 720px){
      .ai-help-hero{flex-direction:column;align-items:flex-start;padding:16px}
      .ai-help-grid{grid-template-columns:1fr}
      .ai-help-orb{width:64px;height:64px;border-radius:18px}
    }
    @keyframes aiPulse{0%{box-shadow:0 0 0 0 rgba(8,145,178,.28)}70%{box-shadow:0 0 0 10px rgba(8,145,178,0)}100%{box-shadow:0 0 0 0 rgba(8,145,178,0)}}
    @keyframes aiWake{0%{transform:scale(1) rotate(0)}35%{transform:scale(1.08) rotate(-8deg)}70%{transform:scale(.96) rotate(8deg)}100%{transform:scale(1) rotate(0)}}
    @keyframes aiCorePulse{0%,100%{transform:scale(.92);box-shadow:0 0 14px rgba(103,232,249,.72)}50%{transform:scale(1.14);box-shadow:0 0 26px rgba(103,232,249,.98)}}
    @keyframes aiHeroFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
    @keyframes aiPanelReveal{0%{opacity:0;transform:translateY(8px) scale(.985)}100%{opacity:1;transform:translateY(0) scale(1)}}
    button:focus, .btn:focus{outline:none}
    button:focus-visible, .btn:focus-visible, a:focus-visible{outline:2px solid var(--accent);outline-offset:2px}

    .branches{display:grid; gap:16px;}
    .branch{border:1px solid var(--line); border-radius:16px; background:var(--card); overflow:hidden; transition: var(--transition);}
    .branch:hover{border-color:var(--line);box-shadow: var(--shadow-sm)}
    .branchHead{
      display:flex; align-items:center; justify-content:flex-end; gap:12px;
      padding:14px 16px;
      background: linear-gradient(180deg, var(--line-soft), var(--card));
      border-bottom:1px solid var(--line);
    }
    .btag{font-size:12px;padding:6px 12px;border-radius:10px;font-weight:800;border:1px solid;white-space:nowrap;}
    .btag.easy{background:var(--good-bg);border-color:rgba(5,150,105,.25);color:var(--good)}
    .btag.med{background:var(--warn-bg);border-color:rgba(217,119,6,.25);color:var(--warn)}
    .btag.hard{background:var(--bad-bg);border-color:rgba(220,38,38,.25);color:var(--bad)}
    .branchBody{padding:16px 18px 18px; line-height:1.85; font-size:15px; font-weight:600; color:var(--ink-soft); overflow-x:auto;}

    .parts{display:grid; gap:12px; margin-top:16px;}
    .part{
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px 16px;
      display:flex;
      gap:14px;
      align-items:center;
      justify-content:center;
      background: var(--bg-warm);
    }
    .part .label{font-weight:800;color:var(--ink);line-height:1.5;min-width:0;font-size:14px}
    .part .inputWrap{display:flex; gap:10px; align-items:center; justify-content:flex-end; flex:0 0 auto;}
    .part.mcqPart{flex-direction:column;align-items:stretch;justify-content:flex-start;}
    .part.mcqPart .label{width:100%;font-size:15px;}
    .part.mcqPart .inputWrap{width:100%;justify-content:stretch;flex:1 1 auto;}
    input[type="text"], input[type="number"], textarea, select{
      border:2px solid var(--line);
      border-radius:12px;
      padding:12px 14px;
      font-size:15px;
      min-width:180px;
      outline:none;
      transition: var(--transition);
      background:var(--card);
      font-family:var(--font);
      font-weight:700;
      color:var(--ink);
    }
    textarea{min-width:260px; min-height:90px; resize:vertical}
    input:focus, textarea:focus, select:focus{
      border-color:var(--brand);
      box-shadow: 0 0 0 3px rgba(3,105,161,.15);
    }
    .branchBtns{display:flex; gap:10px; flex-wrap:wrap; margin-top:14px; justify-content:flex-start}

    .side{padding:20px;}
    .side .head{display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:14px;}
    .side .head h3{margin:0; font-size:18px; font-weight:900; color:var(--ink);}
    .progress{height:12px;background:var(--line);border-radius:999px;overflow:hidden;}
    .progress > div{height:100%;width:0%;background:linear-gradient(90deg,var(--accent),var(--brand));border-radius:999px;transition:.4s width ease-out;}
    .qList{margin-top:14px;display:flex;flex-direction:column;gap:10px;}
    .qItem{
      border:2px solid var(--line);
      border-radius:14px;
      padding:12px 14px;
      display:flex; align-items:center; gap:12px;
      background:var(--card);
      cursor:pointer;
      transition: var(--transition);
    }
    .qItem:hover{
      border-color:var(--brand);
      transform:translateX(-2px);
      box-shadow: var(--shadow-sm);
    }
    .qItem.active{border-color:var(--brand); background:var(--brand-light); box-shadow: 0 0 0 2px rgba(3,105,161,.2)}
    .qItem .left{display:flex; align-items:center; gap:12px; min-width:0;}
    .dot{width:10px;height:10px;border-radius:50%;background:var(--muted); flex-shrink:0;}
    .dot.done{background:var(--good)}
    .dot.bad{background:var(--bad)}
    .qItem .name{font-weight:800;line-height:1.3;min-width:0;font-size:13px; color:var(--ink)}
    .icon{
      width:38px;height:38px;border-radius:12px;
      display:grid;place-items:center;
      background: var(--brand-light);
      border:1px solid rgba(3,105,161,.2);
      color:var(--brand);
      font-weight:900;
      flex:0 0 auto;
      font-size:15px;
    }
    .badge{
      font-size:11px;
      padding:5px 10px;
      border-radius:8px;
      font-weight:800;
      border:1px solid;
      white-space:nowrap;
    }
    .badge.warn{background:var(--warn-bg);border-color:rgba(217,119,6,.3);color:var(--warn)}
    .badge.good{background:var(--good-bg);border-color:rgba(5,150,105,.3);color:var(--good)}

    .resultWrap{padding:20px;}
    .scoreCard{
      border:2px solid var(--line);
      border-radius:18px;
      padding:20px;
      background: linear-gradient(180deg, var(--line-soft), var(--card));
      box-shadow: var(--shadow-sm);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      margin-bottom:16px;
    }
    .scoreBig{font-size:20px;font-weight:900;color:var(--ink)}
    .scoreSub{font-size:13px;font-weight:600;color:var(--muted);margin-top:4px}
    .resultCard{border:1px solid var(--line);border-radius:16px;background:var(--card);padding:16px;margin-top:14px; transition: var(--transition);}
    .resultCard:hover{border-color:var(--line); box-shadow: var(--shadow-sm)}
    .resultCard .rt{display:flex; align-items:center; justify-content:center; gap:10px; flex-wrap:wrap; margin-bottom:8px;}
    .tag{font-size:12px;padding:6px 12px;border-radius:10px;font-weight:800;border:1px solid;}
    .tag.good{background:var(--good-bg);border-color:rgba(5,150,105,.3);color:var(--good)}
    .tag.bad{background:var(--bad-bg);border-color:rgba(220,38,38,.3);color:var(--bad)}
    .partRow{
      display:grid;
      grid-template-columns: 1.15fr .9fr .95fr;
      gap:12px;
      padding:12px 14px;

/* ===== حفظ الإجابة (المنطق المتفق عليه) ===== */
function handleSaveBranch(q, branch, bi){
  const rec = ensureBranchRec(q.id, bi);

  // إذا كان مغلق/صحيح فلا حفظ
  if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) return;

  const {saved, okFilled} = readBranchInputs(q.id, bi, branch);
  if(!okFilled){
    openModal("تنبيه", `
      <div class="modal-warn-body">
        <div class="modal-warn-icon">⚠️</div>
        <div>
          <div class="modal-warn-title">خانات غير مكتملة</div>
          <div class="modal-warn-text">أكمل جميع الخانات المطلوبة ثم اضغط <b>حفظ الإجابة</b>.</div>
        </div>
      </div>
    `);
    return;
  }

  // سجل المحاولة والحفظ
  rec.attempts = (rec.attempts || 0) + 1;
  rec.saved = saved;
  delete state.dirty[q.id];
  saveState();

  const grade = gradeBranch(q, branch, bi, rec.saved);
  if(grade.okAll){
    rec.status = "correct";
    saveState();
  applyFieldFeedback(q.id, bi, grade);
    disableBranchInputs(q.id, bi);
    setProgress(); renderSidebar();
    openModal("تم الحفظ", `
      <div class="modal-success-body">
        <div class="modal-success-orb">✓</div>
        <div class="modal-success-title">إجابة صحيحة!</div>
        <div class="modal-success-badge">أحسنت — واصل التقدم</div>
        <div class="modal-success-stars">⭐ ⭐ ⭐</div>
        <div class="modal-success-note">تم حفظ إجابتك بنجاح. انتقل للسؤال التالي أو راجع إجابتك في لوحة النتائج.</div>
      </div>
    `);
    return;
  }

  // خطأ
  if(rec.attempts === 1){
    rec.status = "wrong1";
    saveState();
  applyFieldFeedback(q.id, bi, grade);
    setProgress(); renderSidebar();
    // افتح المساعدة تلقائياً (بدون طريقة الحل)
    openHelp(q, branch);
    return;
  }

  // المحاولة الثانية: إظهار الإجابة الصحيحة وإغلاق التعديل
  rec.status = "locked";
  saveState();
  applyFieldFeedback(q.id, bi, grade);
  disableBranchInputs(q.id, bi);
  setProgress(); renderSidebar();
  promptOpenCorrectAnswer(q, branch, bi);
}


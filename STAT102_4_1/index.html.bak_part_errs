      const grade = gradeBranch(q, branch, bi, rec.saved);
    }
  });

  wrap.appendChild(titleRow);
  wrap.appendChild(branches);
  typesetMath(wrap);
}

/* ===== تبديل السؤال ===== */
function swapQuestion(qid){
  bumpVariant(qid);
  clearQuestionState(qid);
  const t = TEMPLATES.find(x=>x.id===qid);
  if(t){
    const v = getVariant(t.id);
    const g = t.gen(v);
    const ni = BANK.findIndex(q=>q.id===qid);
    const obj = { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
    if(ni>=0) BANK[ni]=obj;
  }
  saveState();
  renderAll();
}

/* ===== التنقل ===== */
function next(){
  if(typeof ensureSupportForWeakQuestions === "function" && ensureSupportForWeakQuestions()){
    saveState();
  }
  const start = Math.min(state.currentIndex + 1, BANK.length);
  for(let i=start;i<BANK.length;i++){
    if(!isQuestionComplete(BANK[i])){
      state.currentIndex = i;
      saveState();
      renderAll();
      return;
    }
  }
  for(let i=0;i<BANK.length;i++){
    if(!isQuestionComplete(BANK[i])){
      state.currentIndex = i;
      saveState();
      renderAll();
      return;
    }
  }
  tryShowResults();
}
function prev(){
  for(let i=state.currentIndex-1;i>=0;i--){
    if(BANK[i]){
      state.currentIndex=i;
      saveState();
      renderAll();
      return;
    }
  }
}


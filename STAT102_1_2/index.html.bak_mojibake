        { s:"ط§ظ„ظˆط²ظ† ط¨ط§ظ„ظƒظٹظ„ظˆط؛ط±ط§ظ…", options:["ط§ط³ظ…ظٹ (Nominal)","طھط±طھظٹط¨ظٹ (Ordinal)","ظپط¦ظˆظٹ (Interval)","ظ†ط³ط¨ظٹ (Ratio)"], a:"ظ†ط³ط¨ظٹ (Ratio)" },
        { s:"ط±ظ‚ظ… ط§ظ„ط·ط§ظ„ط¨ ط§ظ„ط¬ط§ظ…ط¹ظٹ", options:["ط§ط³ظ…ظٹ (Nominal)","طھط±طھظٹط¨ظٹ (Ordinal)","ظپط¦ظˆظٹ (Interval)","ظ†ط³ط¨ظٹ (Ratio)"], a:"ط§ط³ظ…ظٹ (Nominal)" },
        { s:"ط§ظ„ظ…ط³طھظˆظ‰ ط§ظ„طھط¹ظ„ظٹظ…ظٹ", options:["ط§ط³ظ…ظٹ (Nominal)","طھط±طھظٹط¨ظٹ (Ordinal)","ظپط¦ظˆظٹ (Interval)","ظ†ط³ط¨ظٹ (Ratio)"], a:"طھط±طھظٹط¨ظٹ (Ordinal)" },
        { s:"ط§ظ„ط¹ظ…ط± ط¨ط§ظ„ط³ظ†ظˆط§طھ", options:["ط§ط³ظ…ظٹ (Nominal)","طھط±طھظٹط¨ظٹ (Ordinal)","ظپط¦ظˆظٹ (Interval)","ظ†ط³ط¨ظٹ (Ratio)"], a:"ظ†ط³ط¨ظٹ (Ratio)" }
      ];

      const items = POOL.slice();
      shuffleInPlace(items, r);
      const picked = items.slice(0,3);
      const parts = picked.map((it,i)=>({ type:"mcq", key:"lvl"+(i+1), label:(i+1)+") "+it.s, options:it.options }));
      const answers = {};
      picked.forEach((it,i)=>{ answers["lvl"+(i+1)] = it.a; });
      return {
        branches:[{
          level:"ظ…طھظˆط³ط·",
          prompt:"ط­ط¯ط¯ ظ…ط³طھظˆظ‰ ط§ظ„ظ‚ظٹط§ط³ ط§ظ„ظ…ظ†ط§ط³ط¨ ظ„ظƒظ„ ظ…ط«ط§ظ„:",
          parts,
          answers,
          explain:[
            "ط§ط³ط£ظ„: ظ‡ظ„ طھظˆط¬ط¯ ظپط¦ط§طھ ظپظ‚ط· ط£ظ… طھط±طھظٹط¨ ط£ظ… ظپط±ظˆظ‚ ط°ط§طھ ظ…ط¹ظ†ظ‰ ط£ظ… طµظپط± ط­ظ‚ظٹظ‚ظٹطں",
            "ظˆط¬ظˆط¯ طµظپط± ط­ظ‚ظٹظ‚ظٹ ظٹط¬ط¹ظ„ ط§ظ„ظ…ط³طھظˆظ‰ ظ†ط³ط¨ظٹط§."
          ],
          formula:[
            "ط§ط³ظ…ظٹ: ظپط¦ط§طھ ظپظ‚ط·.",
            "طھط±طھظٹط¨ظٹ: ظپط¦ط§طھ ظ…ط±طھط¨ط©.",
            "ظپط¦ظˆظٹ: ظپط±ظˆظ‚ ط°ط§طھ ظ…ط¹ظ†ظ‰ ط¨ظ„ط§ طµظپط± ط­ظ‚ظٹظ‚ظٹ.",
            "ظ†ط³ط¨ظٹ: ظپط±ظˆظ‚ ط°ط§طھ ظ…ط¹ظ†ظ‰ ظ…ط¹ طµظپط± ط­ظ‚ظٹظ‚ظٹ."
          ],
          solutionSteps:[
            "ط­ط¯ط¯ ط¥ظ† ظƒط§ظ†طھ ط§ظ„ط¨ظٹط§ظ†ط§طھ ظپط¦ظˆظٹط© ط£ظˆ ط¹ط¯ط¯ظٹط©.",
            "ط§ظپط­طµ ظˆط¬ظˆط¯ طھط±طھظٹط¨.",
            "ط§ظپط­طµ ظ…ط¹ظ†ظ‰ ط§ظ„ظپط±ظˆظ‚ ظˆظˆط¬ظˆط¯ ط§ظ„طµظپط± ط§ظ„ط­ظ‚ظٹظ‚ظٹ."
          ]
        }]
      };
    }
  }
];

const ADAPTIVE_TEMPLATE_EXTRA_IDS_12 = new Set(["q5_nominal_ordinal","q6_interval_ratio","q7_codes_vs_values","q8_advanced_tf"]);
const ADAPTIVE_TEMPLATES_12 = CLEAN_TEMPLATES_12.concat(
  TEMPLATES.filter((template) => ADAPTIVE_TEMPLATE_EXTRA_IDS_12.has(template.id))
);

function buildBank(){
  const order = ensureOrder();
  const bank = order.map(id=>{
    const t = ADAPTIVE_TEMPLATES_12.find(x=>x.id===id);
    if(!t) return null;
    const v = getVariant(t.id);
    const g = t.gen(v);
    return { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
  }).filter(Boolean);
  return bank.length ? bank : ADAPTIVE_TEMPLATES_12.map(t=>{
    const v = getVariant(t.id);
    const g = t.gen(v);
    return { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
  });
}

function swapQuestion(qid){
  bumpVariant(qid);
  clearQuestionState(qid);
  const t = ADAPTIVE_TEMPLATES_12.find(x=>x.id===qid);
  if(t){
    const v = getVariant(t.id);
    const g = t.gen(v);
    const ni = BANK.findIndex(q=>q.id===qid);
    const obj = { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
    if(ni>=0) BANK[ni]=obj;
  }
  saveState();
  renderAll();
}

function setProgress(){
  const completed = BANK.filter(q=>isQuestionComplete(q)).length;
  const visibleCompleted = window.__examRunning ? completed : 0;
    const qCountEl = document.getElementById("qCount");
  const qNoEl = document.getElementById("qNo");
  if(qCountEl) qCountEl.textContent = BANK.length;
  if(qNoEl) qNoEl.textContent = (state.currentIndex+1);
  document.getElementById("progressText").textContent = `طھظ… ط­ظ„ ${visibleCompleted} ط³ط¤ط§ظ„`;
  document.getElementById("progressBar").style.width = `${BANK.length ? (visibleCompleted/BANK.length)*100 : 0}%`;

  const pill = document.getElementById("statusPill");
  const q = BANK[state.currentIndex];
  if(isQuestionComplete(q)){
    if(isQuestionCorrect(q)){
      pill.textContent = "ظ…ظƒطھظ…ظ„";
      pill.className = "pill";
    }else{
      pill.textContent = "ظ…ظƒطھظ…ظ„ (طھظˆط¬ط¯ ط£ط®ط·ط§ط،)";
      pill.className = "pill warn";
    }
  }else{
    pill.textContent = "ط؛ظٹط± ظ…ظƒطھظ…ظ„";
    pill.className = "pill warn";
  }

  const showBtn = document.getElementById("showResultsBtn");
  const nextBtnSide = document.getElementById("nextBtnSide");
  showBtn.disabled = (completed !== BANK.length) || !window.__examRunning;
  if(nextBtnSide) nextBtnSide.disabled = !window.__examRunning;

  return {completed, doneAll:(completed===BANK.length)};
}

function renderSidebar(){
  const list = document.getElementById("qList");
  list.innerHTML = "";
  state.dirty = state.dirty || {};
  const filter = state.sidebarFilter || "all";
  const toShow = BANK.map((q,i)=>({q,i})).filter(({q})=>filter==="incomplete" ? !isQuestionComplete(q) : true);

  toShow.forEach(({q,i})=>{
    const complete = isQuestionComplete(q);
    const correct = complete && isQuestionCorrect(q);
    const dotClass = !complete ? "" : (correct ? "done" : "bad");
    const badge = !complete
      ? el("span",{class:"badge warn"},["ط؛ظٹط± ظ…ظƒطھظ…ظ„"])
      : el("span",{class:"badge "+(correct?"good":"warn")},[correct?"ظ…ظƒطھظ…ظ„":"ظ…ظƒطھظ…ظ„ (ط®ط·ط£)"]);
    const unsaved = state.dirty[q.id];
    const item = el("div",{class:"qItem"+(state.currentIndex===i?" active":""), onclick:()=>{ state.currentIndex=i; saveState(); renderAll(); }},[
      el("div",{class:"left"},[
        unsaved ? el("div",{class:"unsaved-dot", title:"طھظˆط¬ط¯ ط¥ط¬ط§ط¨ط© ط؛ظٹط± ظ…ط­ظپظˆط¸ط©"},[]) : null,
        el("div",{class:"dot "+dotClass}),
        el("div",{},[
          el("div",{class:"name"},[`ط³ط¤ط§ظ„ ${i+1}: ${q.title}`]),
          el("div",{style:"margin-top:6px"},[badge])
        ])
      ]),
      el("div",{class:"icon"},[q.icon])
    ].filter(Boolean));
    list.appendChild(item);
  });

  ["filterAllBtn","filterIncompleteBtn"].forEach(id=>{
    const btn = document.getElementById(id);
    if(btn) btn.className = "btn small" + ((btn.getAttribute("data-filter")===filter) ? " primary" : "");
  });
}

function openHelp(q, branch){
  const explainHtml = (branch.explain && branch.explain.length)
    ? `<ul>${branch.explain.map(s=>`<li>${escapeHtml(latexFix(s))}</li>`).join("")}</ul>`
    : "<div style='color:var(--muted);font-weight:700'>ط§ط¨ط¯ط£ ط¨ظپظ‡ظ… ط§ظ„ظ…ط·ظ„ظˆط¨ ط«ظ… ط­ط¯ط¯ ظ†ظˆط¹ ط§ظ„ظپظƒط±ط© ظ‚ط¨ظ„ ط§ظ„ط­ظ„.</div>";
  const formulaHtml = (branch.formula && branch.formula.length)
    ? `<ul>${branch.formula.map(s=>`<li>${escapeHtml(latexFix(s))}</li>`).join("")}</ul>`
    : "<div style='color:var(--muted);font-weight:700'>ط§ظƒطھط¨ ط§ظ„ظ‚ط§ظ†ظˆظ† ط£ظˆ ط§ظ„ظ‚ط§ط¹ط¯ط© ط§ظ„ظ…ظ†ط§ط³ط¨ط© ط«ظ… ط¹ظˆظ‘ط¶ ط¹ظ„ظٹظ‡ط§.</div>";

  openModal("ظ…ط³ط§ط¹ط¯ط©", `
    <div class="ai-help-panel">
      <div class="ai-help-hero">
        <div class="ai-help-orb"><span></span></div>
        <div class="ai-help-copy">
          <div class="ai-help-kicker">HELP</div>
          <div class="ai-help-title">${escapeHtml(q.title)} <span style="font-size:13px;color:rgba(255,255,255,.7)">(${escapeHtml(branch.level)})</span></div>        </div>
      </div>
      <div class="ai-help-grid">
        <div class="ai-help-section">
          <div class="ai-help-section-head">
            <span class="ai-help-chip-icon">?</span>
            <span>ط§ظ„ظپظƒط±ط©</span>
          </div>
          <div class="ai-help-body">${explainHtml}</div>
        </div>
        <div class="ai-help-section">
          <div class="ai-help-section-head">
            <span class="ai-help-chip-icon">?</span>
            <span>ط§ظ„ظ‚ط§ظ†ظˆظ†</span>
          </div>
          <div class="ai-help-body">${formulaHtml}</div>
        </div>
      </div>
    </div>
  `);
}

function openCorrectAnswer(q, branch, bi){
  const steps = (branch.solutionSteps && branch.solutionSteps.length)
    ? `<div style="font-weight:900;margin:10px 0 6px">ط®ط·ظˆط§طھ ط§ظ„ط­ظ„</div><ol style="margin:0;padding-right:18px">${branch.solutionSteps.map(s=>`<li style="margin:8px 0">${escapeHtml(latexFix(s))}</li>`).join("")}</ol>`
    : "";

  const correctList = [];
  (branch.parts||[]).forEach(p=>{
    const val = (p.type==="mcq") ? branch.answers[p.key] : formatNumber(branch.answers[p.key]);
    correctList.push(`<li><b>${escapeHtml(p.label)}:</b> ${escapeHtml(String(val))}</li>`);
  });
  const correctHtml = correctList.length
    ? `<div style="font-weight:900;margin:12px 0 6px">ط§ظ„ط¥ط¬ط§ط¨ط§طھ ط§ظ„طµط­ظٹط­ط©</div><ul style="margin:0;padding-right:18px">${correctList.join("")}</ul>`
    : "";

  openModal("ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©", `
    <div style="font-weight:900;margin-bottom:6px">${escapeHtml(q.title)} - (${escapeHtml(branch.level)})</div>
    ${steps}
    ${correctHtml}
    <div style="margin-top:14px;color:#5b6b7a;font-weight:900">ظٹظ…ظƒظ†ظƒ طھظˆظ„ظٹط¯ ظ†ط³ط®ط© ط¬ط¯ظٹط¯ط© ظ…ظ† ط§ظ„ط³ط¤ط§ظ„ ط¨ط¹ط¯ ط§ظ„ط¥ط؛ظ„ط§ظ‚.</div>
    <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap"><button class="btn primary" id="regenAfterShowAnswerBtn">ط³ط¤ط§ظ„ ط¬ط¯ظٹط¯</button><button class="btn small" onclick="closeModal()">ط¥ط؛ظ„ط§ظ‚</button></div>
  `);
  const regenBtn = document.getElementById("regenAfterShowAnswerBtn");
  if(regenBtn) regenBtn.onclick = ()=>{ closeModal(); swapQuestion(q.id); };
}

function promptOpenCorrectAnswer(q, branch, bi){
  openModal("ط¹ط±ط¶ ط§ظ„ط¥ط¬ط§ط¨ط©", `
    <div style="font-weight:900;margin-bottom:10px">ط§ظ†طھظ‡طھ ط§ظ„ظ…ط­ط§ظˆظ„ط§طھ ظ„ظ‡ط°ط§ ط§ظ„ط¬ط²ط،.</div>
    <div style="color:var(--muted);font-weight:700;margin-bottom:14px">ظٹظ…ظƒظ†ظƒ ط§ظ„ط¢ظ† ط¹ط±ط¶ ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„طµط­ظٹط­ط©.</div>
    <button class="btn primary" id="showAnswerAfterAttemptsBtn">ط¹ط±ط¶ ط§ظ„ط¥ط¬ط§ط¨ط©</button>
  `);
  const btn = document.getElementById("showAnswerAfterAttemptsBtn");
  if(btn) btn.onclick = ()=>openCorrectAnswer(q, branch, bi);
}

function handleSaveBranch(q, branch, bi){
  const rec = ensureBranchRec(q.id, bi);
  if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) return;

  const {saved, okFilled} = readBranchInputs(q.id, bi, branch);
  if(!okFilled){
    openModal("طھظ†ط¨ظٹظ‡", `<div style="font-weight:900">ط£ظƒظ…ظ„ ط¬ظ…ظٹط¹ ط§ظ„ط­ظ‚ظˆظ„ ط§ظ„ظ…ط·ظ„ظˆط¨ط© ط«ظ… ط§ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط©.</div>`);
    return;
  }

  rec.attempts = (rec.attempts || 0) + 1;
  rec.saved = saved;
  delete state.dirty[q.id];
  saveState();

  const grade = gradeBranch(q, branch, bi, rec.saved);
  if(grade.okAll){
    rec.status = "correct";
    saveState();
    applyFieldFeedback(q.id, bi, grade);
    disableBranchInputs(q.id, bi);
    setProgress();
    renderSidebar();
    return;
  }

  if(rec.attempts === 1){
    rec.status = "wrong1";
    saveState();
    applyFieldFeedback(q.id, bi, grade);
    setProgress();
    renderSidebar();
    openHelp(q, branch);
    return;
  }

  rec.status = "locked";
  saveState();
  applyFieldFeedback(q.id, bi, grade);
  disableBranchInputs(q.id, bi);
  setProgress();
  renderSidebar();
  promptOpenCorrectAnswer(q, branch, bi);
}

function renderMain(){
  BANK = buildBank();
  const i = state.currentIndex;
  const q = BANK[i];
  const wrap = document.getElementById("mainContent");
  wrap.innerHTML = "";
  const p = setProgress();

  const titleRow = el("div",{class:"qtitleRow"},[
    el("div",{class:"qtitle"},[
      el("div",{class:"qnum"},[String(i+1)]),
      el("div",{},[q.title])
    ]),
    el("div",{class:"qmeta"},[
      el("button",{class:"btn small", disabled: !window.__examRunning, onclick:()=>swapQuestion(q.id)},["طھط¨ط¯ظٹظ„ ط§ظ„ط³ط¤ط§ظ„"]),
      el("button",{class:"btn small", disabled: !p.doneAll || !window.__examRunning, onclick:()=>tryShowResults()},["ط¥ط¸ظ‡ط§ط± ط§ظ„ظ†طھظٹط¬ط©"]),
      el("button",{class:"btn small", disabled: !window.__examRunning, onclick:()=>prev()},["ط§ظ„ط³ط§ط¨ظ‚"]),
      el("button",{class:"btn primary small", disabled: !window.__examRunning, onclick:()=>next()},["ط§ظ„طھط§ظ„ظٹ"])
    ])
  ]);

  const branches = el("div",{class:"branches"},[]);
  q.branches.forEach((branch, bi)=>{
    const tagClass = (branch.level==="ط³ظ‡ظ„") ? "easy" : (branch.level==="ظ…طھظˆط³ط·" ? "med" : "hard");
    const rec = ensureBranchRec(q.id, bi);
    const branchCard = el("div",{class:"branch"},[]);
    const statusTag = (rec.status==="correct" || rec.status==="locked" || !window.__examRunning)
      ? el("span",{class:"btag", style:`border-color:${rec.status==="correct"?"#0b7a43":"#b42318"};background:${rec.status==="correct"?"#eafff4":"#ffecec"};color:${rec.status==="correct"?"#0b7a43":"#b42318"}`},[rec.status==="correct" ? "طµط­ظٹط­" : "ط®ط·ط£"])
      : null;

    const head = el("div",{class:"branchHead"},[
      el("span",{class:`btag ${tagClass}`},[branch.level]),
      statusTag
    ]);
    const body = el("div",{class:"branchBody"},[]);
    body.innerHTML = latexFix(branch.prompt).replace(/\n/g,"<br/>");
    typesetMath(body);

    const parts = el("div",{class:"parts"},[]);
    (branch.parts||[]).forEach(p=>{
      const row = el("div",{class:"part"},[]);
      if(p.type==="mcq") row.classList.add("mcqPart");
      const label = el("div",{class:"label"},[p.label]);
      const inputWrap = el("div",{class:"inputWrap"},[]);
      const savedVal = (rec.saved && rec.saved[p.key]!=null) ? rec.saved[p.key] : "";

      if(p.type==="mcq"){
        const group = el("div",{class:"mcqGroup"},[]);
        (p.options||[]).forEach((op,idx)=>{
          const id = `${q.id}_${bi}_${p.key}_${idx}`;
          const radio = el("input",{type:"radio", id, name:`${q.id}_${bi}_${p.key}`, value:op},[]);
          radio.setAttribute("data-qid", q.id);
          radio.setAttribute("data-bi", String(bi));
          radio.setAttribute("data-key", p.key);
          if(String(savedVal)===String(op)) radio.checked = true;
          radio.onchange = ()=>{ markDirty(q.id); };
          if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) radio.disabled = true;
          group.appendChild(el("label",{class:"choice", for:id},[radio, el("span",{},[op])]));
        });
        inputWrap.appendChild(group);
      }

      row.appendChild(label);
      row.appendChild(inputWrap);
      parts.appendChild(row);
    });

    const btns = el("div",{class:"branchBtns"},[
      el("button",{class:"btn small primary", "data-save-btn":`${q.id}::${bi}`, disabled: !window.__examRunning, onclick:()=>handleSaveBranch(q, branch, bi)},["ط­ظپط¸ ط§ظ„ط¥ط¬ط§ط¨ط©"]),
      el("button",{class:"btn small ai-help-btn", disabled: !window.__examRunning, onclick:()=>openHelp(q, branch), title:"ظپطھط­ ط§ظ„ظ…ط³ط§ط¹ط¯ط©"},[
        el("span",{class:"ai-help-glyph","aria-hidden":"true"},["?"]),
        "ظ…ط³ط§ط¹ط¯ط©"
      ])
    ]);
    if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning){
      const sb = btns.querySelector(`[data-save-btn="${q.id}::${bi}"]`);
      if(sb) sb.disabled = true;
    }

    const container = el("div",{"data-branch-container":`${q.id}::${bi}`},[]);
    container.appendChild(head);
    container.appendChild(body);
    if((branch.parts||[]).length>0){ typesetMath(parts); container.appendChild(parts); }
    container.appendChild(btns);
    branchCard.appendChild(container);
    branches.appendChild(branchCard);
  });

  wrap.appendChild(titleRow);
  wrap.appendChild(branches);
}

function listIncomplete(){
  const arr = [];
  BANK.forEach((q,i)=>{ if(!isQuestionComplete(q)) arr.push({i:i+1, title:q.title}); });
  return arr;
}

function tryShowResults(){
  const p = setProgress();
  if(!p.doneAll){
    if(!confirm("ظ„ظ… طھظƒظ…ظ„ ط¬ظ…ظٹط¹ ط§ظ„ط£ط³ط¦ظ„ط©. ظ‡ظ„ طھط±ظٹط¯ ط¹ط±ط¶ ط§ظ„ظ†طھظٹط¬ط© ط§ظ„ط¢ظ†طں")) return;
  }
  showResultsModal();
}

function showResultsModal(){
  BANK = buildBank();
  const s = computeScore();
  const cards = BANK.map((q,qi)=>{
    const complete = isQuestionComplete(q);
    const correctQ = complete && isQuestionCorrect(q);
    let inner = `
      <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
        <div style="font-weight:900">ط³ط¤ط§ظ„ ${qi+1}: ${escapeHtml(q.title)}</div>
        <span class="tag ${correctQ?"good":"bad"}">${correctQ?"طھظ… ط¨ظ†ط¬ط§ط­":"طھظˆط¬ط¯ ط£ط®ط·ط§ط،"}</span>
      </div>
    `;

    q.branches.forEach((branch,bi)=>{
      const rec = ensureBranchRec(q.id,bi);
      const grade = gradeBranch(q, branch, bi, rec.saved||{});
      const keys = collectPartKeys(branch);
      inner += `<div style="margin-top:10px;font-weight:900;color:#0f2a3b">(${escapeHtml(branch.level)})</div>`;
      keys.forEach(k=>{
        const student = (rec.saved && rec.saved[k]!=null) ? rec.saved[k] : "-";
        const correctVal = branch.answers[k];
        const ok = grade.byKey[k];
        const correctText = (typeof correctVal === "string") ? correctVal : formatNumber(correctVal);
        inner += `
          <div class="partRow">
            <div><b>ط§ظ„ط¨ظ†ط¯:</b> ${escapeHtml(k)}</div>
            <div><b>ط¥ط¬ط§ط¨طھظƒ:</b> ${escapeHtml(String(student))}</div>
            <div><b>ط§ظ„طµط­ظٹط­:</b> ${escapeHtml(String(correctText))} <span class="tag ${ok?"good":"bad"}" style="margin-right:8px">${ok?"طµط­":"ط®ط·ط£"}</span></div>
          </div>`;
      });
    });
    return `<div class="resultCard">${inner}</div>`;
  }).join("");

  const correctPct = s.total ? (s.correct/s.total)*100 : 0;
  const wrongPct = s.total ? ((s.total-s.correct)/s.total)*100 : 0;
  openModal("ط§ظ„ظ†طھظٹط¬ط©", `
    <div class="scoreCard" style="margin-bottom:14px">
      <div>
        <div class="scoreBig">ط§ظ„ط¯ط±ط¬ط©: ${s.correct} ظ…ظ† ${s.total} - ${s.pct}%</div>
        <div class="score-bar-wrap" style="margin:10px 0"><div class="score-bar-correct" style="width:${correctPct}%"></div><div class="score-bar-wrong" style="width:${wrongPct}%"></div></div>
        <div class="scoreSub">ظ‡ط°ط§ ظ…ظ„ط®طµ ط³ط±ظٹط¹ ظ„ط¬ظ…ظٹط¹ ط¥ط¬ط§ط¨ط§طھظƒ.</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn primary" onclick="window.print()">ط·ط¨ط§ط¹ط© ط§ظ„ظ†طھظٹط¬ط©</button>
        <button class="btn primary" onclick="window.__resetAll(); closeModal();">ط¥ط¹ط§ط¯ط© ط§ظ„ط§ط®طھط¨ط§ط±</button>
      </div>
    </div>
    ${cards}
  `);
}
window.__resetAll = resetAll;


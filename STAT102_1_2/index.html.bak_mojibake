window.__startExam = function(){
  window.__examRunning = true;
  storageSet(TIMER_KEY, String(Date.now() + TIMER_MINUTES * 60 * 1000));
  state.timerEnded = false;
  saveState();
  startTimer();
  setTimeout(function(){ renderAll(); }, 0);
};

function ensureBranchRec(qid, bi){
  if(!state.branches[qid]) state.branches[qid] = {};
  if(!state.branches[qid][bi]) state.branches[qid][bi] = { attempts: 0, status: "new", saved: {} };
  return state.branches[qid][bi];
}
function clearQuestionState(qid){
  if(state.branches[qid]) delete state.branches[qid];
  saveState();
}


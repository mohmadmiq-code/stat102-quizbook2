  function aiLawItems(question, branch){
    const direct = branch && Array.isArray(branch.formula) ? branch.formula : (branch && Array.isArray(branch.law) ? branch.law : []);
    if(direct && direct.length) return direct;

    const qid = question && question.id ? String(question.id) : "";
    const title = aiSafeTitle(question);
    const prompt = aiEscape((branch && branch.promptHtml) || "").replace(/<[^>]*>/g, " ");
    /* Codex prompt-aware safe hints */
    const laws = {
      q1_mean_raw: ["\\(\\bar{x}=\\frac{\\sum x_i}{n}\\)"],
      q2_mean_freq: ["\\(\\bar{x}=\\frac{\\sum x_i f_i}{\\sum f_i}\\)"],
      q3_mean_group: ["\\(\\bar{x}=\\frac{\\sum m_i f_i}{\\sum f_i}\\)", "\\(m_i\\) ظ…ط±ظƒط² ط§ظ„ظپط¦ط© ظˆ\\(f_i\\) طھظƒط±ط§ط±ظ‡ط§."],
      q4_median_raw: ["ط¥ط°ط§ ظƒط§ظ† \\(n\\) ظپط±ط¯ظٹط§ظ‹: ظ…ظˆظ‚ط¹ ط§ظ„ظˆط³ظٹط· \\(k=\\frac{n+1}{2}\\).", "ط¥ط°ط§ ظƒط§ظ† \\(n\\) ط²ظˆط¬ظٹط§ظ‹: \\(\\tilde{x}=\\frac{x_{(n/2)}+x_{(n/2+1)}}{2}\\)."],
      q6_mode_raw: ["ظ„ظ„ط¨ظٹط§ظ†ط§طھ ط§ظ„ط®ط§ظ…: ط§ظ„ظ…ظ†ظˆط§ظ„ ظ‡ظˆ ط§ظ„ظ‚ظٹظ…ط© ط§ظ„ط£ظƒط«ط± طھظƒط±ط§ط±ط§ظ‹.", "ظ„ظ„ط¨ظٹط§ظ†ط§طھ ط§ظ„ظ…ط¬ظ…ط¹ط©: ظ†ط­ط¯ط¯ ط§ظ„ظپط¦ط© ط§ظ„ظ…ظ†ظˆط§ظ„ظٹط© ط£ظˆظ„ط§ ط«ظ… ظ†ط³طھط®ط¯ظ… ظ‚ط§ظ†ظˆظ† ط§ظ„ظ…ظ†ظˆط§ظ„ ط¥ظ† ط·ظڈظ„ط¨."],
      q2_q1_even: ["\\(L_{Q_1}=\\frac{n+1}{4}\\)"],
      q3_q3_odd: ["\\(L_{Q_3}=\\frac{3(n+1)}{4}\\)"],
      q4_percentile: ["\\(L_{P_r}=\\frac{r}{100}(n+1)\\)"],
      "33_sd_raw": ["\\(s^2=\\frac{\\sum (x_i-\\bar{x})^2}{n-1}\\)", "\\(s=\\sqrt{s^2}\\)"],
      "33_sd_freq": ["\\(s^2=\\frac{\\sum f_i(x_i-\\bar{x})^2}{\\sum f_i-1}\\)", "\\(s=\\sqrt{s^2}\\)"],
      "33_sd_group": ["\\(s^2=\\frac{\\sum f_i(m_i-\\bar{x})^2}{\\sum f_i-1}\\)", "\\(m_i\\) ظ…ط±ظƒط² ط§ظ„ظپط¦ط©."],
      "33_range_raw": ["\\(R=x_{max}-x_{min}\\)"],
      "33_iqr": ["\\(IQR=Q_3-Q_1\\)"],
      "34_cv_basic": ["\\(CV=\\frac{s}{\\bar{x}}\\times 100\\%\\)"],
      "34_qcd_basic": ["\\(QCD=\\frac{Q_3-Q_1}{Q_3+Q_1}\\)"],
      "34_z_basic": ["\\(z=\\frac{x-\\bar{x}}{s}\\)"],
      "34_x_from_z": ["\\(x=\\bar{x}+zs\\)"],
      "35_pearson": ["\\(Sk=\\frac{3(\\bar{x}-\\tilde{x})}{s}\\)"],
      "35_moment": ["\\(\\alpha_3=\\frac{m_3}{s^3}\\)"],
      "35_kurtosis": ["\\(\\alpha_4=\\frac{m_4}{s^4}\\)"],
      "35_box": ["ط§ظ„ط£ط¹ط¯ط§ط¯ ط§ظ„ط®ظ…ط³ط©: ط§ظ„طµط؛ط±ظ‰طŒ \\(Q_1\\)طŒ ط§ظ„ظˆط³ظٹط·طŒ \\(Q_3\\)طŒ ط§ظ„ط¹ط¸ظ…ظ‰."]
    };
    if((/x_i|bar\{x\}|ط§ظ†ط­ط±ط§ظپ/.test(prompt)) && (/\^2|ظ…ط±ط¨ط¹ط§طھ|طھط±ط¨ظٹط¹/.test(prompt))){

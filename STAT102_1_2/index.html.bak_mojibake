/* Codex Adaptive Flow 1.2 Start */
(function(){
  const ALL_ORDER = ["q1_circle", "q2_tf", "q3_method", "q5_nominal_ordinal", "q4_param_stat", "q6_interval_ratio", "q7_codes_vs_values", "q8_advanced_tf"];
  const CORE_ORDER = ["q1_circle", "q2_tf", "q3_method", "q4_param_stat"];
  const SUPPORT_ORDER = ALL_ORDER.filter((id) => !CORE_ORDER.includes(id));
  const QUESTION_PROFILES = {
    q1_circle: { difficulty: 1, skills: ["classification", "discrete"], remediation: ["q2_tf"], advancement: ["q3_method", "q5_nominal_ordinal"] },
    q2_tf: { difficulty: 2, skills: ["classification", "qualitative"], remediation: ["q1_circle"], advancement: ["q3_method", "q4_param_stat"] },
    q3_method: { difficulty: 3, skills: ["collection", "application"], remediation: ["q1_circle", "q2_tf"], advancement: ["q4_param_stat", "q7_codes_vs_values"] },
    q4_param_stat: { difficulty: 2, skills: ["parameter", "statistic"], remediation: ["q3_method"], advancement: ["q6_interval_ratio"] },
    q5_nominal_ordinal: { difficulty: 2, skills: ["qualitative", "scale"], remediation: ["q1_circle", "q2_tf"], advancement: ["q6_interval_ratio"] },
    q6_interval_ratio: { difficulty: 4, skills: ["scale", "quantitative"], remediation: ["q5_nominal_ordinal", "q4_param_stat"], advancement: ["q8_advanced_tf"] },
    q7_codes_vs_values: { difficulty: 3, skills: ["representation", "application"], remediation: ["q3_method", "q5_nominal_ordinal"], advancement: ["q8_advanced_tf"] },
    q8_advanced_tf: { difficulty: 4, skills: ["quantitative", "parameter"], remediation: ["q4_param_stat", "q6_interval_ratio"], advancement: [] }
  };
  const AI_KEY_ADAPT = "stat102_ai_models_v4_" + String((location.pathname || document.title || "lesson")).replace(/[^\w]+/g, "_").slice(-80);
  const MAX_VARIANT_REPEATS = 2;
  const SUPPORT_LIMIT = 2;
  const SESSION_VERSION = "mastery_only_v2";
  const LESSON_TARGET = 0.74;
  const LESSON_FLOOR = 0.58;

  function injectAdaptiveStyles(){
    if(document.getElementById("adaptiveFlowStyles12")) return;
    const style = document.createElement("style");
    style.id = "adaptiveFlowStyles12";
    style.textContent = `
      .side .head h3,
      .side .sidebar-filter,
      .side .qList{
        display:none !important;
      }
      .side{
        display:grid;
        gap:14px;
      }
      .side .head{
        justify-content:space-between;
      }
    `;
    document.head.appendChild(style);
  }

  function stableTopicKey(value){
    return String(value || "topic").toLowerCase().replace(/[^\p{L}\p{N}]+/gu, "_").replace(/^_+|_+$/g, "") || "topic";
  }

  function clampAdaptive(value, min=0, max=1){
    return Math.min(max, Math.max(min, Number.isFinite(value) ? value : min));
  }

  function loadAdaptiveAiState(){
    try{
      const raw = typeof storageGet === "function" ? storageGet(AI_KEY_ADAPT) : localStorage.getItem(AI_KEY_ADAPT);
      return raw ? JSON.parse(raw) : { topics: {} };
    }catch(e){
      return { topics: {} };
    }
  }

  function validIds(list){
    return list.filter((id) => ADAPTIVE_TEMPLATES_12.some((template) => template.id === id));
  }

  function ensureSessionState(){
    const validCore = validIds(CORE_ORDER);
    const validAll = validIds(ALL_ORDER);
    const current = Array.isArray(state.order)
      ? state.order.filter((id, index, arr) => validAll.includes(id) && arr.indexOf(id) === index)
      : [];
    let nextOrder = current.slice();

    if(state.masteryVersion !== SESSION_VERSION || !nextOrder.length){
      nextOrder = [...validCore];
      state.currentIndex = 0;
    }

    validCore.forEach((id, index) => {
      if(!nextOrder.includes(id)) nextOrder.splice(Math.min(index, nextOrder.length), 0, id);
    });

    const supportTail = nextOrder.filter((id) => !validCore.includes(id));
    nextOrder = [...validCore, ...supportTail];

    const changed = !Array.isArray(state.order)
      || state.masteryVersion !== SESSION_VERSION
      || state.order.length !== nextOrder.length
      || nextOrder.some((id, index) => state.order[index] !== id)
      || (state.masterySupportCount || 0) !== supportTail.length;

    if(changed){
      state.order = nextOrder;
      state.masteryVersion = SESSION_VERSION;
      state.masterySupportCount = supportTail.length;
      if(state.currentIndex >= nextOrder.length) state.currentIndex = 0;
      saveState();
    }
    return state.order;
  }

  function getActiveOrder(){
    return ensureSessionState().slice();
  }

  function buildFromOrder(order){
    return order.map((id) => {
      const template = ADAPTIVE_TEMPLATES_12.find((item) => item.id === id);
      if(!template) return null;
      const variant = getVariant(template.id);
      const generated = template.gen(variant);
      return { id:template.id, title:template.title, icon:template.icon, branches:generated.branches };
    }).filter(Boolean);
  }

  buildBank = function(){
    const order = getActiveOrder();
    const bank = buildFromOrder(order);
    return bank.length ? bank : forceBuildBank(order);
  };

  function forceBuildBank(order){
    const active = Array.isArray(order) && order.length ? order : getActiveOrder();
    return buildFromOrder(active);
  }

  function ensureAdaptiveBankReady(){
    let bank = buildBank();
    if(!Array.isArray(bank) || !bank.length){
      state.order = validIds(CORE_ORDER);
      state.currentIndex = 0;
      saveState();
      bank = forceBuildBank(state.order);
    }
    BANK = Array.isArray(bank) ? bank : [];
    if(state.currentIndex >= BANK.length) state.currentIndex = 0;
    return BANK;
  }

  function concealSidebarQuestions(){
    const list = document.getElementById("qList");
    if(list) list.innerHTML = "";
    const heading = document.querySelector(".side .head h3");
    if(heading) heading.style.display = "none";
    const filter = document.querySelector(".sidebar-filter");
    if(filter) filter.style.display = "none";
  }

  function getQuestionById(qid){
    return Array.isArray(BANK) ? BANK.find((question) => question.id === qid) : null;
  }

  function getCurrentQuestionId(){
    return BANK && BANK[state.currentIndex] ? BANK[state.currentIndex].id : null;
  }

  function baseScoreFromRecord(record){
    if(record.status === "correct") return record.attempts <= 1 ? 0.88 : 0.74;
    if(record.status === "locked") return 0.22;
    if(record.status === "wrong1") return 0.42;
    if(record.attempts > 0) return 0.48;
    return 0.5;
  }

  function getQuestionSignal(qid){
    const profile = QUESTION_PROFILES[qid] || { difficulty: 2, skills: [], remediation: [], advancement: [] };
    const record = ensureBranchRec(qid, 0);
    const aiState = loadAdaptiveAiState();
    const model = aiState && aiState.topics ? aiState.topics[stableTopicKey(qid)] : null;
    const fallback = baseScoreFromRecord(record);
    const attemptCount = Math.max(record.attempts || 0, model && typeof model.attempts === "number" ? model.attempts : 0);
    const ensemble = clampAdaptive(model && typeof model.ensemble === "number" ? model.ensemble : fallback);
    const mastery = clampAdaptive(model && typeof model.mastery === "number" ? model.mastery : fallback);
    const lr = clampAdaptive(model && typeof model.lr === "number" ? model.lr : ensemble);
    const nbScore = clampAdaptive(model && typeof model.nbScore === "number" ? model.nbScore : ensemble);
    const knn = clampAdaptive(model && typeof model.knn === "number" ? model.knn : ensemble);
    const readiness = clampAdaptive((ensemble * 0.42) + (mastery * 0.28) + (lr * 0.15) + (knn * 0.10) + (nbScore * 0.05));
    const struggle = clampAdaptive(((1 - readiness) * 0.55) + Math.min(0.22, attemptCount * 0.08) + (record.status === "locked" ? 0.25 : (record.status === "wrong1" ? 0.12 : 0)));
    return { qid, record, model, profile, attemptCount, ensemble, mastery, lr, nbScore, knn, readiness, struggle };
  }

  function metricIds(ids){
    const source = (Array.isArray(ids) && ids.length ? ids : getActiveOrder()).filter((id) => ALL_ORDER.includes(id));
    const answered = source.filter((id) => {
      const record = ensureBranchRec(id, 0);
      return (record.attempts || 0) > 0 || record.status !== "new";
    });
    return answered.length ? answered : source;
  }

  function lessonReadiness(ids){
    const source = metricIds(ids);
    if(!source.length) return 0.5;
    return source.reduce((sum, id) => sum + getQuestionSignal(id).readiness, 0) / source.length;
  }

  function sharesSkill(sourceId, targetId){
    const sourceSkills = (QUESTION_PROFILES[sourceId] && QUESTION_PROFILES[sourceId].skills) || [];
    const targetSkills = (QUESTION_PROFILES[targetId] && QUESTION_PROFILES[targetId].skills) || [];
    return sourceSkills.some((skill) => targetSkills.includes(skill));
  }

  function maxDifficulty(){
    return Math.max(...Object.values(QUESTION_PROFILES).map((profile) => profile.difficulty || 1), 1);
  }

  function desiredDifficulty(signal){
    const overall = lessonReadiness(CORE_ORDER);
    if(signal.readiness < 0.45 || overall < 0.45) return Math.max(1, (signal.profile.difficulty || 2) - 1);
    if(signal.readiness > 0.78 && overall > 0.7) return Math.min(maxDifficulty(), (signal.profile.difficulty || 2) + 1);
    return signal.profile.difficulty || 2;
  }

  function shouldRepeatCurrent(signal){
    return typeof swapQuestion === "function"
      && signal.record.status !== "correct"
      && signal.attemptCount < MAX_VARIANT_REPEATS
      && (signal.record.status === "locked" || signal.struggle > 0.63 || signal.readiness < 0.46);
  }

  function completed(ids){
    return ids.every((id) => {
      const question = getQuestionById(id);
      return !!question && isQuestionComplete(question);
    });
  }

  function weakestSignal(ids){
    const source = metricIds(ids);
    if(!source.length) return null;
    return source.map((id) => getQuestionSignal(id)).sort((a, b) => (a.readiness - b.readiness) || (b.struggle - a.struggle))[0] || null;
  }

  function meetsMasteryTarget(){
    const coreIds = validIds(CORE_ORDER);
    if(!coreIds.length || !completed(coreIds)) return false;
    const average = lessonReadiness(coreIds);
    const lowest = Math.min(...coreIds.map((id) => getQuestionSignal(id).readiness));
    return average >= LESSON_TARGET && lowest >= LESSON_FLOOR;
  }

  function getRemainingCandidates(currentId){
    return getActiveOrder().filter((id) => {
      if(id === currentId) return false;
      const question = getQuestionById(id);
      return !!question && !isQuestionComplete(question);
    });
  }

  function scoreCandidate(currentSignal, candidateId){
    const signal = getQuestionSignal(candidateId);
    const question = getQuestionById(candidateId);
    if(!question || isQuestionComplete(question)) return -1;
    const targetDifficulty = desiredDifficulty(currentSignal);
    const difficultyGap = Math.abs((signal.profile.difficulty || 2) - targetDifficulty);
    const difficultyFit = clampAdaptive(1 - (difficultyGap * 0.38));
    const weaknessNeed = 1 - signal.readiness;
    const unseenBonus = signal.attemptCount === 0 ? 0.18 : 0.04;
    const sameSkillBonus = sharesSkill(currentSignal.qid, candidateId) ? (currentSignal.readiness < 0.62 ? 0.24 : 0.10) : 0;
    const remediationBonus = (currentSignal.profile.remediation || []).includes(candidateId) ? 0.16 : 0;
    const advancementBonus = (currentSignal.profile.advancement || []).includes(candidateId) ? (currentSignal.readiness >= 0.7 ? 0.18 : 0.06) : 0;
    return (weaknessNeed * 0.40) + (difficultyFit * 0.22) + unseenBonus + sameSkillBonus + remediationBonus + advancementBonus;
  }

  function scoreSupportCandidate(focusSignal, candidateId){
    const signal = getQuestionSignal(candidateId);
    const sameSkillBonus = sharesSkill(focusSignal.qid, candidateId) ? 0.34 : 0;
    const remediationBonus = (focusSignal.profile.remediation || []).includes(candidateId) ? 0.28 : 0;
    const advancementBonus = (focusSignal.profile.advancement || []).includes(candidateId) ? 0.12 : 0;
    const difficultyGap = Math.abs((signal.profile.difficulty || 2) - Math.min(maxDifficulty(), (focusSignal.profile.difficulty || 2) + 1));
    const difficultyFit = clampAdaptive(1 - (difficultyGap * 0.35));
    return ((1 - focusSignal.readiness) * 0.36) + (difficultyFit * 0.22) + sameSkillBonus + remediationBonus + advancementBonus;
  }

  function selectSupportCandidate(focusId){
    const focusSignal = getQuestionSignal(focusId);
    const active = getActiveOrder();
    const available = SUPPORT_ORDER.filter((id) => !active.includes(id));
    if(!available.length) return null;
    return available.slice().sort((a, b) => scoreSupportCandidate(focusSignal, b) - scoreSupportCandidate(focusSignal, a))[0] || null;
  }

  function appendSupportQuestion(focusId){
    if((state.masterySupportCount || 0) >= SUPPORT_LIMIT) return null;
    const targetId = selectSupportCandidate(focusId);
    if(!targetId) return null;
    state.order = [...getActiveOrder(), targetId];
    state.masterySupportCount = (state.masterySupportCount || 0) + 1;
    saveState();
    return targetId;
  }

  function chooseNextAdaptiveId(){
    const currentId = getCurrentQuestionId();
    if(!currentId) return null;
    const currentSignal = getQuestionSignal(currentId);
    const remaining = getRemainingCandidates(currentId);
    if(!remaining.length) return null;
    return remaining.slice().sort((a, b) => scoreCandidate(currentSignal, b) - scoreCandidate(currentSignal, a))[0] || null;
  }

  function moveToQuestion(targetId){
    const bank = ensureAdaptiveBankReady();
    const targetIndex = bank.findIndex((question) => question.id === targetId);
    if(targetIndex < 0) return false;
    state.currentIndex = targetIndex;
    saveState();
    renderAll();
    return true;
  }

  const originalRenderSidebar = renderSidebar;
  renderSidebar = function(){
    ensureAdaptiveBankReady();
    const result = originalRenderSidebar.apply(this, arguments);
    concealSidebarQuestions();
    return result;
  };

  const originalRenderMain = renderMain;
  renderMain = function(){
    const bank = ensureAdaptiveBankReady();
    const wrap = document.getElementById("mainContent");
    if(!bank.length){
      if(wrap) wrap.innerHTML = '<div style="padding:24px;font-weight:900;color:#0f2a3b">ظٹطھظ… طھط¬ظ‡ظٹط² ط§ظ„ط£ط³ط¦ظ„ط©طŒ ط£ط¹ط¯ طھط­ظ…ظٹظ„ ط§ظ„طµظپط­ط© ظ…ط±ط© ظˆط§ط­ط¯ط©.</div>';
      return;
    }
    return originalRenderMain.apply(this, arguments);
  };

  const originalNext = next;
  next = function(){
    const bank = ensureAdaptiveBankReady();
    if(!bank.length){
      renderAll();
      return;
    }

    const currentId = getCurrentQuestionId();
    const currentSignal = currentId ? getQuestionSignal(currentId) : null;
    if(currentId && currentSignal && shouldRepeatCurrent(currentSignal)){
      swapQuestion(currentId);
      BANK = ensureAdaptiveBankReady();
      moveToQuestion(currentId);
      return;
    }

    const targetId = chooseNextAdaptiveId();
    if(targetId && moveToQuestion(targetId)) return;

    if(completed(getActiveOrder())){
      if(meetsMasteryTarget()){
        showResultsModal();
        return;
      }
      const focus = weakestSignal(CORE_ORDER) || weakestSignal(getActiveOrder());
      const supportId = focus ? appendSupportQuestion(focus.qid) : null;
      if(supportId){
        BANK = ensureAdaptiveBankReady();
        moveToQuestion(supportId);
        return;
      }
      if(focus && typeof swapQuestion === "function" && focus.attemptCount < MAX_VARIANT_REPEATS){
        swapQuestion(focus.qid);
        BANK = ensureAdaptiveBankReady();
        moveToQuestion(focus.qid);
        return;
      }
      showResultsModal();
      return;
    }

    return originalNext.apply(this, arguments);
  };

  ensureSessionState();
  BANK = ensureAdaptiveBankReady();
  if(!BANK.length){
    state.order = validIds(CORE_ORDER);
    state.currentIndex = 0;
    saveState();
    BANK = forceBuildBank(state.order);
  }
  if(state.currentIndex >= BANK.length) state.currentIndex = 0;
  injectAdaptiveStyles();
  saveState();
  renderAll();
})();
/* Codex Adaptive Flow 1.2 End */




/* Codex Unified AI Logic Start */
(function(){
  function aiEscape(value){
    return value == null ? "" : String(value);
  }

  function aiLatex(value){
    const text = aiEscape(value);
    return typeof latexFix === "function" ? latexFix(text) : text;
  }

  function aiLevel(branch){
    return aiEscape(branch && (branch.level ?? branch.difficulty ?? branch.name ?? "")).trim();
  }

  function aiList(items, fallback){
    const values = Array.isArray(items) ? items.filter(Boolean) : [];
    if(!values.length){
      return `<div class="ai-help-note">${fallback}</div>`;
    }
    return `<ul>${values.map((item) => `<li>${escapeHtml(aiLatex(item))}</li>`).join("")}</ul>`;
  }

  function ensureAiAssistModal(){
    let modal = document.getElementById("aiAssistModal");
    if(modal){
      return modal;
    }

    modal = document.createElement("div");
    modal.id = "aiAssistModal";
    modal.className = "ai-assist-modal";
    modal.setAttribute("aria-hidden", "true");
    modal.innerHTML = `
      <div class="ai-assist-shell" role="dialog" aria-modal="true" aria-labelledby="aiAssistLabel">
        <div class="ai-assist-topbar">
          <button class="btn small ai-assist-close" type="button" id="aiAssistCloseBtn">ط¥ط؛ظ„ط§ظ‚</button>
          <div class="ai-assist-topbar-title" id="aiAssistLabel">ظ…ط³ط§ط¹ط¯ط©</div>
        </div>
        <div class="ai-assist-body" id="aiAssistBody"></div>
      </div>
    `;

    modal.addEventListener("click", (event) => {
      if(event.target === modal){
        closeUnifiedAiHelp();
      }
    });

    document.body.appendChild(modal);

    const closeBtn = modal.querySelector("#aiAssistCloseBtn");
    if(closeBtn){
      closeBtn.onclick = closeUnifiedAiHelp;
    }

    return modal;
  }

  function closeUnifiedAiHelp(){
    const modal = document.getElementById("aiAssistModal");
    if(modal){
      modal.classList.remove("show");
      modal.setAttribute("aria-hidden", "true");
    }
    document.body.classList.remove("ai-assist-open");
  }


  function aiSafeTitle(question){
    return String((question && question.title) || "");
  }

  function aiHintItems(question, branch){
    const qid = question && question.id ? String(question.id) : "";
    const title = aiSafeTitle(question);
    const prompt = aiEscape((branch && branch.promptHtml) || "").replace(/<[^>]*>/g, " ");
    /* Codex prompt-aware safe hints */
    const lower = title.toLowerCase();
    const hints = {
      q1_mean_raw: ["ط­ط¯ظ‘ط¯ ط¹ط¯ط¯ ط§ظ„ظ‚ظٹظ… ط£ظˆظ„ط§ ط«ظ… ط§ط¬ظ…ط¹ظ‡ط§ ط¯ظˆظ† ط§ظ„ظ‚ظپط² ظ„ظ„ظ†طھظٹط¬ط©.", "ط§ظ†طھط¨ظ‡ ط¥ظ„ظ‰ ط£ظ† ط§ظ„ظ…طھظˆط³ط· ظٹط¹طھظ…ط¯ ط¹ظ„ظ‰ ظƒظ„ ط§ظ„ظ‚ظٹظ…."],
      q2_mean_freq: ["طھط¹ط§ظ…ظ„ ظ…ط¹ ظƒظ„ ظ‚ظٹظ…ط© ظ…ظƒط±ط±ط© ط¨ط¹ط¯ط¯ طھظƒط±ط§ط±ظ‡ط§.", "ط§ط¨ط¯ط£ ط¨ط¹ظ…ظˆط¯ظٹ ط­ط§طµظ„ ط§ظ„ط¶ط±ط¨ ظˆط§ظ„ظ…ط¬ظ…ظˆط¹ ط§ظ„ظƒظ„ظٹ ظ„ظ„طھظƒط±ط§ط±ط§طھ."],
      q3_mean_group: ["ط­ظˆظ‘ظ„ ظƒظ„ ظپط¦ط© ط¥ظ„ظ‰ ظ…ط±ظƒط²ظ‡ط§ ظ‚ط¨ظ„ ط§ظ„ط­ط³ط§ط¨.", "ط§ط³طھط®ط¯ظ… ظ…ط±ط§ظƒط² ط§ظ„ظپط¦ط§طھ ظ…ط¹ ط§ظ„طھظƒط±ط§ط±ط§طھطŒ ظ„ط§ ط­ط¯ظˆط¯ ط§ظ„ظپط¦ط§طھ ظ…ط¨ط§ط´ط±ط©."],

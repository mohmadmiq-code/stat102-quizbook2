function randomToken(){
  return String(Date.now()) + "_" + Math.floor(Math.random()*1000000);
}
function getVariant(qid){
  if(state.variants[qid]==null){
    state.variants[qid] = randomToken();
    saveState();
  }
  return state.variants[qid];
}
function bumpVariant(qid){
  state.variants[qid] = randomToken();
  saveState();
}

function shuffleInPlace(arr, r){
  for(let i=arr.length-1;i>0;i--){
    const j = Math.floor(r()*(i+1));
    const tmp = arr[i];
    arr[i] = arr[j];
    arr[j] = tmp;
  }
  return arr;
}
function ensureOrder(){
  const ids = TEMPLATES.map(t=>t.id);
  const ok = Array.isArray(state.order)
    && state.order.length === ids.length
    && ids.every(id=>state.order.includes(id));
  if(!ok){
    const r = seededRand("order|"+Date.now()+"|"+Math.random());
    state.order = shuffleInPlace([...ids], r);
    saveState();
  }
  return state.order;
}
function reshuffleOrder(){
  const ids = TEMPLATES.map(t=>t.id);
  const r = seededRand("order|"+Date.now()+"|"+Math.random());
  state.order = shuffleInPlace([...ids], r);
  saveState();
}

function buildBank(){
  const order = ensureOrder();
  return order.map(id=>{
    const t = TEMPLATES.find(x=>x.id===id);
    const v = getVariant(t.id);
    const g = t.gen(v);
    return { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
  });
}

let BANK = [];

/* ===== ????? ?????? ???????? ??? ??? ===== */
function collectPartKeys(branch){
  const keys=[];
  (branch.parts||[]).forEach(p=>keys.push(p.key));
  if(branch.customUI==="freqTable" && branch.table && branch.table.rows){
    branch.table.rows.forEach(r=>(r.inputs||[]).forEach(k=>keys.push(k)));
  }
  return keys;
}

/* ===== ????? ??? ===== */
function gradeBranch(q, branch, bi, savedObj){
  const result = { okAll: true, byKey: {} };

  // parts
  (branch.parts||[]).forEach(p=>{
    const studentRaw = (savedObj && savedObj[p.key] != null) ? savedObj[p.key] : "";
    const correct = branch.answers[p.key];
    let ok=false;
    if(p.type==="mcq"){
      ok = normalizeText(studentRaw) === normalizeText(correct);
    }else if(p.type==="text"){
      if(p.orderInsensitive) ok = sameNumberList(studentRaw, correct);
      else ok = normalizeText(studentRaw) === normalizeText(correct);
    }else{
      ok = nearlyEqual(parseNumberLoose(studentRaw), Number(correct), 1e-2);
    }
    result.byKey[p.key]=ok;
    if(!ok) result.okAll=false;
  });

  // freq table
  if(branch.customUI==="freqTable" && branch.table && branch.table.rows){
    branch.table.rows.forEach(r=>{
      (r.inputs||[]).forEach(k=>{
        const studentRaw = (savedObj && savedObj[k] != null) ? savedObj[k] : "";
        const correct = branch.answers[k];
        const ok = nearlyEqual(parseNumberLoose(studentRaw), Number(correct), 1e-2);
        result.byKey[k]=ok;
        if(!ok) result.okAll=false;
      });
    });
  }

  return result;
}

/* ===== ???? ??????? ===== */
function isBranchComplete(qid, bi){
  const rec = ensureBranchRec(qid, bi);
  return rec.status==="correct" || rec.status==="locked" || !window.__examRunning;
}
function isQuestionComplete(q){
  return q.branches.every((b,bi)=>isBranchComplete(q.id, bi));
}
function isQuestionCorrect(q){
  return q.branches.every((b,bi)=>ensureBranchRec(q.id,bi).status==="correct");
}
function isQuestionWrong(q){
  return q.branches.some((b,bi)=>ensureBranchRec(q.id,bi).status==="locked");
}

function setProgress(){
  const completed = BANK.filter(q=>isQuestionComplete(q)).length;
  const visibleCompleted = window.__examRunning ? completed : 0;
    const qCountEl = document.getElementById("qCount");
  const qNoEl = document.getElementById("qNo");
  if(qCountEl) qCountEl.textContent = BANK.length;
  if(qNoEl) qNoEl.textContent = (state.currentIndex+1);
  document.getElementById("progressText").textContent = `طھظ… ط­ظ„ ${visibleCompleted} ط³ط¤ط§ظ„`;
  document.getElementById("progressBar").style.width = `${BANK.length ? (visibleCompleted/BANK.length)*100 : 0}%`;

  const pill = document.getElementById("statusPill");
  const q = BANK[state.currentIndex];
  if(isQuestionComplete(q)){
    if(isQuestionCorrect(q)){
      pill.textContent="?????";
      pill.className="pill";
    }else{
      pill.textContent="????? (????? ??? ?????)";
      pill.className="pill warn";
    }
  }else{
    pill.textContent="??? ?????";
    pill.className="pill warn";
  }

  const showBtn = document.getElementById("showResultsBtn");
  const nextBtnSide = document.getElementById("nextBtnSide");
  showBtn.disabled = (completed !== BANK.length) || !window.__examRunning;
  if(nextBtnSide) nextBtnSide.disabled = !window.__examRunning;

  return {completed, doneAll: (completed === BANK.length)};
}

function renderSidebar(){
  const list=document.getElementById("qList");
  list.innerHTML="";
  state.dirty = state.dirty || {};
  const filter = state.sidebarFilter || "all";
  const toShow = BANK.map((q,i)=>({q,i})).filter(({q,i})=>{
    if(filter==="incomplete") return !isQuestionComplete(q);
    return true;
  });
  toShow.forEach(({q,i})=>{
    const complete = isQuestionComplete(q);
    const correct = complete && isQuestionCorrect(q);
    const dotClass = !complete ? "" : (correct ? "done" : "bad");
    const badge = !complete
      ? el("span",{class:"badge warn"},["??? ?????"])
      : el("span",{class:"badge "+(correct?"good":"warn")},[correct?"?????":"????? (???)"]);
    const unsaved = state.dirty[q.id];
    const item=el("div",{class:"qItem"+(state.currentIndex===i?" active":""), onclick:()=>{ state.currentIndex=i; saveState(); renderAll(); }},[
      el("div",{class:"left"},[
        unsaved ? el("div",{class:"unsaved-dot", title:"????? ??? ??????"},[]) : null,
        el("div",{class:"dot "+dotClass}),
        el("div",{},[
          el("div",{class:"name"},[`???? ${i+1}: ${q.title}`]),
          el("div",{style:"margin-top:6px"},[badge])
        ])
      ]),
      el("div",{class:"icon"},[q.icon])
    ].filter(Boolean));
    list.appendChild(item);
  });
  ["filterAllBtn","filterIncompleteBtn"].forEach(id=>{
    const btn=document.getElementById(id);
    if(btn) btn.className = "btn small" + ((btn.getAttribute("data-filter")===filter) ? " primary" : "");
  });
}

/* ===== ?????? ????? ===== */
function renderFreqTable(q, branch, bi){
  const rec = ensureBranchRec(q.id, bi);
  const t = branch.table;
  const table = el("table",{class:"ftable"},[]);
  const thead = el("thead",{},[]);
  thead.appendChild(el("tr",{}, t.headers.map(h=>el("th",{},[h]))));
  table.appendChild(thead);

  const tbody = el("tbody",{},[]);
  t.rows.forEach((row)=>{
    const tr = el("tr",{},[]);
    tr.appendChild(el("td",{},[row.label]));
    if(row.fixed){
      row.fixed.forEach(val=> tr.appendChild(el("td",{},[val])));
    }else if(row.inputs){
      row.inputs.forEach((k)=>{
        const savedVal = (rec.saved && rec.saved[k]!=null) ? rec.saved[k] : "";
        const inp = el("input",{class:"cellInput", type:"text", value: savedVal},[]);
        inp.setAttribute("data-qid", q.id);
        inp.setAttribute("data-bi", String(bi));
        inp.setAttribute("data-key", k);
        inp.oninput = ()=>{ inp.classList.remove("badField","goodField"); markDirty(q.id); };
        if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) inp.disabled = true;

        tr.appendChild(el("td",{},[inp]));
      });
    }
    tbody.appendChild(tr);
  });
  table.appendChild(tbody);
  return table;
}

function piePaths(counts, cx, cy, r){
  const total = counts.reduce((a,b)=>a+b,0);
  let a0 = -Math.PI/2;
  const paths = [];
  for(let i=0;i<counts.length;i++){
    const frac = counts[i]/total;
    const a1 = a0 + frac*2*Math.PI;
    const x0 = cx + r*Math.cos(a0), y0 = cy + r*Math.sin(a0);
    const x1 = cx + r*Math.cos(a1), y1 = cy + r*Math.sin(a1);
    const large = (a1-a0) > Math.PI ? 1 : 0;
    const d = `M ${cx} ${cy} L ${x0} ${y0} A ${r} ${r} 0 ${large} 1 ${x1} ${y1} Z`;
    paths.push({d, frac, a0, a1});
    a0 = a1;
  }
  return paths;
}

function renderChartsInteractive(branch){
  const {cats, counts, N} = branch.chartData;
  const max = Math.max(...counts);

  const outer = el("div",{class:"charts"},[]);
  const tip = el("div",{class:"chartTip"},[]);
  tip.style.display="none";
  document.body.appendChild(tip);

  function showTip(x,y,html){
    tip.innerHTML = html;
    tip.style.left = (x+12)+"px";
    tip.style.top  = (y+12)+"px";
    tip.style.display="block";
  }
  function hideTip(){ tip.style.display="none"; }

  // Bar chart (SVG)
  const w=520, h=260, pad=34, bw=56, gap=22, x0=24, baseY=h-54;
  const barSvg = el("svg",{viewBox:`0 0 ${w} ${h}`, class:"svgInteractive", "aria-label":"????? ????????"},[]);
  barSvg.appendChild(el("rect",{x:"0",y:"0",width:String(w),height:String(h),rx:"14",fill:"#ffffff"}));
  barSvg.appendChild(el("line",{x1:String(pad),y1:String(baseY),x2:String(w-pad),y2:String(baseY),stroke:"#dbe7f2","stroke-width":"2"}));
  barSvg.appendChild(el("line",{x1:String(pad),y1:String(pad),x2:String(pad),y2:String(baseY),stroke:"#dbe7f2","stroke-width":"2"}));

  const barGroup = el("g",{},[]);
  counts.forEach((c,i)=>{
    const bh = (c/max) * (baseY - pad);
    const x = x0 + i*(bw+gap);
    const y = baseY - bh;

    const rect = el("rect",{x:String(x),y:String(y),width:String(bw),height:String(bh),rx:"10",ry:"10",
      fill:"rgba(10,94,168,.22)", stroke:"rgba(10,94,168,.45)", "stroke-width":"1.5", class:"barSeg", "data-i":String(i)},[]);
    rect.addEventListener("mousemove",(ev)=>{
      const pct = (c/N)*100;
      showTip(ev.clientX, ev.clientY, `<b>${escapeHtml(cats[i])}</b><div style="margin-top:4px">???????: ${c}</div><div>??????: ${pct.toFixed(1)}%</div>`);
    });
    rect.addEventListener("mouseleave", hideTip);
    rect.addEventListener("click", ()=>{
      barSvg.querySelectorAll(".barSeg").forEach(n=>n.classList.remove("selected"));
      rect.classList.add("selected");
      info.innerHTML = `<div><b>?????:</b> ${escapeHtml(cats[i])}</div>
                        <div><b>???????:</b> ${c}</div>
                        <div><b>??????? ??????:</b> ${(c/N).toFixed(3)}</div>
                        <div><b>?????? ???????:</b> ${((c/N)*100).toFixed(1)}%</div>
                        <div><b>????? ??????:</b> ${Math.round((c/N)*360)}ï؟½</div>`;
    });
    barGroup.appendChild(rect);

    barGroup.appendChild(el("text",{x:String(x+bw/2),y:String(y-8),"text-anchor":"middle","font-size":"12","font-weight":"900",fill:"#0f2a3b"},[String(c)]));
    barGroup.appendChild(el("text",{x:String(x+bw/2),y:String(baseY+18),"text-anchor":"middle","font-size":"10","font-weight":"800",fill:"#2a4c66"},[cats[i]]));
  });
  barSvg.appendChild(barGroup);

  const barBox = el("div",{class:"chartBox"},[
    el("div",{class:"chartTitle"},["????? ????????"]),
    el("div",{class:"svgWrap"},[barSvg]),
    el("div",{class:"chartNote"},[`N = ${N} ï؟½ ???? ?????? ??? ?????? ?? ???? ?????? ????????.`])
  ]);

  // Pie chart (SVG)
  const pcw=320, pch=260, cx=150, cy=130, pr=92;
  const pieSvg = el("svg",{viewBox:`0 0 ${pcw} ${pch}`, class:"svgInteractive", "aria-label":"???????? ????????"},[]);
  pieSvg.appendChild(el("rect",{x:"0",y:"0",width:String(pcw),height:String(pch),rx:"14",fill:"#ffffff"}));

  const pie = piePaths(counts, cx, cy, pr);
  pie.forEach((seg,i)=>{
    const c = counts[i];
    const path = el("path",{d:seg.d, fill:`rgba(30,167,255,${0.12+0.08*i})`, stroke:"rgba(10,94,168,.25)", "stroke-width":"1.5", class:"pieSeg", "data-i":String(i)},[]);
    path.addEventListener("mousemove",(ev)=>{
      const angle = (c/N)*360;
      showTip(ev.clientX, ev.clientY, `<b>${escapeHtml(cats[i])}</b><div style="margin-top:4px">???????: ${c}</div><div>???????: ${angle.toFixed(1)}ï؟½</div>`);
    });
    path.addEventListener("mouseleave", hideTip);
    path.addEventListener("click", ()=>{
      pieSvg.querySelectorAll(".pieSeg").forEach(n=>n.classList.remove("selected"));
      path.classList.add("selected");
      info.innerHTML = `<div><b>?????:</b> ${escapeHtml(cats[i])}</div>
                        <div><b>???????:</b> ${c}</div>
                        <div><b>??????? ??????:</b> ${(c/N).toFixed(3)}</div>
                        <div><b>?????? ???????:</b> ${((c/N)*100).toFixed(1)}%</div>
                        <div><b>????? ??????:</b> ${Math.round((c/N)*360)}ï؟½</div>`;
    });
    pieSvg.appendChild(path);
  });
  pieSvg.appendChild(el("circle",{cx:String(cx),cy:String(cy),r:String(pr),fill:"none",stroke:"#dbe7f2","stroke-width":"2"}));

  const pieBox = el("div",{class:"chartBox"},[
    el("div",{class:"chartTitle"},["???????? ????????"]),
    el("div",{class:"svgWrap"},[pieSvg]),
    el("div",{class:"chartNote"},[`???? ??? ?????? ?????? ???????.`])
  ]);

  const info = el("div",{class:"chartInfo", html:`<div style="font-weight:900;color:#0f2a3b;margin-bottom:6px">?????? ?????? ??????</div><div style="color:#5b6b7a;font-weight:800">???? ??? ????/????.</div>`});
  const infoBox = el("div",{class:"chartBox"},[
    el("div",{class:"chartTitle"},["???? ????????"]),
    info
  ]);

  outer.appendChild(barBox);
  outer.appendChild(pieBox);
  outer.appendChild(infoBox);

  // clean tooltip on destroy via navigation
  outer._disposeTip = ()=>{ try{ tip.remove(); }catch(e){} };

  return outer;
}

function renderStemLeaf(branch){
  return el("div",{class:"stemleaf"},[
    ...(branch.stemleaf||[]).map(r=> el("div",{class:"slRow"},[
      el("div",{class:"stem"},[String(r.stem)]),
      el("div",{class:"sep"},["|"]),
      el("div",{class:"leaves"},[(r.leaves||[]).join("  ")])
    ]))
  ]);
}

/* ===== ????? ???????? ?? DOM ???? ??? ===== */
function readBranchInputs(qid, bi, branch){
  const container = document.querySelector(`[data-branch-container="${qid}::${bi}"]`);
  const saved = {};
  const keys = collectPartKeys(branch);

  let ok=true;
  keys.forEach(k=>{
    const node = container ? container.querySelector(`[data-qid="${qid}"][data-bi="${bi}"][data-key="${k}"]`) : null;
    let val = "";
    if(node){
      if(node.type==="radio"){
        const checked = container.querySelector(`input[type="radio"][data-qid="${qid}"][data-bi="${bi}"][data-key="${k}"]:checked`);
        val = checked ? checked.value : "";
      }else{
        val = node.value ?? "";
      }
    }
    saved[k] = val;
    if(String(val).trim()==="") ok=false;
  });

  return {saved, okFilled: ok};
}

function applyFieldFeedback(qid, bi, grade){
  const container = document.querySelector(`[data-branch-container="${qid}::${bi}"]`);
  if(!container) return;

  const q = BANK.find(x=>x.id===qid);
  const branch = (q && q.branches) ? q.branches[bi] : null;
  const rec = ensureBranchRec(qid, bi);
  const saved = rec.saved || {};
  const status = rec.status;

  Object.entries(grade.byKey||{}).forEach(([k,ok])=>{
    const nodes = container.querySelectorAll(`[data-qid="${qid}"][data-bi="${bi}"][data-key="${k}"]`);
    nodes.forEach(n=>{
      if(n.type==="radio"){
        const wrap = n.closest(".choice");
        if(!wrap) return;

        // reset
        wrap.classList.remove("badField","goodField","revealCorrect");

        const sel = normalizeText(saved[k] != null ? saved[k] : "");
        const val = normalizeText(n.value != null ? n.value : "");
        const corr = (branch && branch.answers) ? normalizeText(branch.answers[k] != null ? branch.answers[k] : "") : "";

        // highlight only the selected option
        if(sel && val===sel){
          wrap.classList.add(ok ? "goodField" : "badField");
        }

        // on second wrong (locked): reveal the correct option only
        if(status==="locked" && corr && val===corr){
          wrap.classList.add("goodField","revealCorrect");
        }
      }else{
        const hasVal = (saved[k] != null && String(saved[k]).trim() !== "");
        n.classList.remove("badField","goodField");
        if(hasVal){
          n.classList.add(ok ? "goodField" : "badField");
        }
      }
    });
  });
}

function disableBranchInputs(qid, bi){
  const container = document.querySelector(`[data-branch-container="${qid}::${bi}"]`);
  if(!container) return;
  container.querySelectorAll(`[data-qid="${qid}"][data-bi="${bi}"][data-key]`).forEach(n=>{
    if(n.type==="radio") n.disabled = true;
    else n.disabled = true;
  });
  const saveBtn = container.querySelector(`[data-save-btn="${qid}::${bi}"]`);
  if(saveBtn) saveBtn.disabled = true;
}


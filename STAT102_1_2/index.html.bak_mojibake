    if((/x_i|bar\{x\}|ط§ظ†ط­ط±ط§ظپ/.test(prompt)) && (/\^2|ظ…ط±ط¨ط¹ط§طھ|طھط±ط¨ظٹط¹/.test(prompt))){
      return [
        "ط®ط§طµظٹط© ط¹ط§ظ…ط©: ظ…ط¬ظ…ظˆط¹ ط§ظ†ط­ط±ط§ظپط§طھ ط§ظ„ظ‚ظٹظ… ط¹ظ† ظ…طھظˆط³ط·ظ‡ط§ ط§ظ„ط­ط³ط§ط¨ظٹ ظٹطھظˆط§ط²ظ† ط­ظˆظ„ ط§ظ„ظ…طھظˆط³ط·.",
        "ظ„ط§ طھط­ظˆظ‘ظ„ ظ…ط¬ظ…ظˆط¹ ظ…ط±ط¨ط¹ط§طھ ط§ظ„ط§ظ†ط­ط±ط§ظپط§طھ ط¥ظ„ظ‰ ظ…ط¬ظ…ظˆط¹ ط§ظ„ط§ظ†ط­ط±ط§ظپط§طھط› ط§ظ„ظ…ط·ظ„ظˆط¨ ظٹط¹طھظ…ط¯ ط¹ظ„ظ‰ ط§ظ„ط®ط§طµظٹط© ظ„ط§ ط¹ظ„ظ‰ ط§ظ„طھط¹ظˆظٹط¶ ظپظٹ ط±ظ‚ظ… 9."
      ];
    }
    if(prompt.includes("ظˆط²ظ†") && (prompt.includes("ظ†ط³ط¨ط©") || prompt.includes("ظ…ط¦ظˆظٹط©"))){
      return [
        "ط§ظ„ظ…طھظˆط³ط· ط§ظ„ظ…ط±ط¬ط­ = ظ…ط¬ظ…ظˆط¹ (ط§ظ„ظˆط²ظ† أ— ط§ظ„ظ‚ظٹظ…ط©) ظ…ظ‚ط³ظˆظ…ط§ظ‹ ط¹ظ„ظ‰ ظ…ط¬ظ…ظˆط¹ ط§ظ„ط£ظˆط²ط§ظ†.",
        "ط§ط³طھط®ط¯ظ… ط§ظ„ظ‚ط§ط¹ط¯ط© ط§ظ„ط¹ط§ظ…ط© ظپظ‚ط·طŒ ط«ظ… ط¹ظˆظ‘ط¶ ط§ظ„ط£ط±ظ‚ط§ظ… ط¨ظ†ظپط³ظƒ ظپظٹ ط§ظ„ط­ظ„."
      ];
    }
    if(laws[qid]) return laws[qid];
    if(title.includes("ط§ظ„ظˆط³ظٹط·")) return laws.q4_median_raw;
    if(title.includes("ط§ظ„ظ…ظ†ظˆط§ظ„")) return laws.q6_mode_raw;
    if(title.includes("ط§ظ„ظ…طھظˆط³ط·") && title.includes("طھظƒط±ط§ط±ظٹ")) return laws.q2_mean_freq;
    if(title.includes("ط§ظ„ظ…طھظˆط³ط·")) return laws.q1_mean_raw;
    if(title.includes("ظ…ط¦ظٹظ†")) return laws.q4_percentile;
    if(title.includes("ط±ط¨ظٹط¹")) return ["ط­ط¯ط¯ ظ…ظˆظ‚ط¹ ط§ظ„ط±ط¨ظٹط¹ ط§ظ„ظ…ط·ظ„ظˆط¨ ط¨ط¹ط¯ طھط±طھظٹط¨ ط§ظ„ط¨ظٹط§ظ†ط§طھ." ];
    if(title.includes("ط§ظ†ط­ط±ط§ظپ") || title.includes("طھط¨ط§ظٹظ†")) return laws["33_sd_raw"];
    if(title.includes("ظ…ط¯ظ‰")) return laws["33_range_raw"];
    if(title.includes("ط§ط®طھظ„ط§ظپ")) return laws["34_cv_basic"];
    if(title.includes("ظ…ط¹ظٹط§ط±ظٹ")) return laws["34_z_basic"];
    if(title.includes("ط§ظ„طھظˆط§ط،")) return laws["35_pearson"];
    if(title.includes("طھظپظ„ط·ط­")) return laws["35_kurtosis"];
    if(title.includes("طµظ†ط¯ظˆظ‚")) return laws["35_box"];
    return ["ط§ظƒطھط¨ ط§ظ„ظ‚ط§ظ†ظˆظ† ط§ظ„ط¹ط§ظ… ط§ظ„ظ…ط±طھط¨ط· ط¨ط§ظ„ظ…ظپظ‡ظˆظ… ط§ظ„ظ…ط·ظ„ظˆط¨ ط£ظˆظ„ط§.", "ط¨ط¹ط¯ طھط­ط¯ظٹط¯ ط§ظ„ظ‚ط§ظ†ظˆظ†طŒ ط¹ظˆظ‘ط¶ ط§ظ„ظ‚ظٹظ… ط¨ظ†ظپط³ظƒ ط®ط·ظˆط© ط®ط·ظˆط© ط¯ظˆظ† ط¹ط±ط¶ ط§ظ„ظ†ط§طھط¬ ط§ظ„ظ†ظ‡ط§ط¦ظٹ ط¯ط§ط®ظ„ ط§ظ„ظ…ط³ط§ط¹ط¯ط©."];
  }
  function openUnifiedAiHelp(question, branch){
    const modal = ensureAiAssistModal();
    const body = modal.querySelector("#aiAssistBody");
    const title = escapeHtml(aiEscape(question && question.title));
    const level = aiLevel(branch);
    const levelHtml = level ? ` <span class="ai-help-level">(${escapeHtml(level)})</span>` : "";
    const explainHtml = aiList(aiHintItems(question, branch), "ط§ط¨ط¯ط£ ط¨ظپظ‡ظ… ط§ظ„ظ…ط·ظ„ظˆط¨ ظˆط±ط¨ط·ظ‡ ط¨ط§ظ„ظ…ظپط§ظ‡ظٹظ… ط§ظ„ط£ط³ط§ط³ظٹط© ظ‚ط¨ظ„ ط§ط®طھظٹط§ط± ط§ظ„ظ‚ط§ظ†ظˆظ†.");
    const formulaHtml = aiList(aiLawItems(question, branch), "ط§ظƒطھط¨ ط§ظ„ظ‚ط§ظ†ظˆظ† ط£ظˆ ط§ظ„ظ…ط³ط§ط± ط§ظ„ظ…ظ†ط§ط³ط¨ ط«ظ… ط¹ظˆظ‘ط¶ ط®ط·ظˆط© ط®ط·ظˆط© ط¨ط¯ظˆظ† ط§ظ„ظˆطµظˆظ„ ط¥ظ„ظ‰ ط§ظ„ط¥ط¬ط§ط¨ط© ط§ظ„ظ†ظ‡ط§ط¦ظٹط© ظ…ط¨ط§ط´ط±ط©.");

    body.innerHTML = `
      <div class="ai-help-panel">
        <div class="ai-help-hero">
          <div class="ai-help-orb"><span></span></div>
          <div class="ai-help-copy">
            <div class="ai-help-kicker">HELP</div>
            <div class="ai-help-title">${title}${levelHtml}</div>          </div>
        </div>
        <div class="ai-help-grid">
          <div class="ai-help-section">
            <div class="ai-help-section-head">
              <span class="ai-help-chip-icon">âœ¦</span>
              <span>ظƒظٹظپ طھظپظƒط± ظپظٹ ط§ظ„ط³ط¤ط§ظ„طں</span>
            </div>
            <div class="ai-help-body">${explainHtml}</div>
          </div>
          <div class="ai-help-section">
            <div class="ai-help-section-head">
              <span class="ai-help-chip-icon">âˆ‘</span>
              <span>ظ…ط§ ط§ظ„ظ‚ط§ظ†ظˆظ† ط£ظˆ ط§ظ„ظ…ط³ط§ط±طں</span>
            </div>
            <div class="ai-help-body">${formulaHtml}</div>
          </div>
        </div>
      </div>
    `;

    modal.classList.add("show");
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("ai-assist-open");

    if(body && typeof typesetMath === "function"){
      typesetMath(body);
    }
  }

  window.__openUnifiedAiHelp = openUnifiedAiHelp;
  window.closeUnifiedAiHelp = closeUnifiedAiHelp;

  if(typeof openHelp === "function"){
    openHelp = openUnifiedAiHelp;
  }
  if(typeof showHelp === "function"){
    showHelp = openUnifiedAiHelp;
  }

  function relocateAiButtons(){
    document.querySelectorAll(".branch").forEach((branchEl) => {
      const head = branchEl.querySelector(".branchHead");
      const actions = branchEl.querySelector(".branchBtns");
      const helpBtn = actions ? actions.querySelector(".ai-help-btn") : null;
      if(!head || !helpBtn){
        return;
      }

      helpBtn.classList.add("ai-help-inline-btn");
      if(helpBtn.parentElement !== head){
        head.insertBefore(helpBtn, head.firstChild);
      }
    });
  }

  window.__relocateAiButtons = relocateAiButtons;

  if(typeof renderAll === "function" && !renderAll.__codexAiWrapped){
    const originalRenderAll = renderAll;
    const wrappedRenderAll = function(){
      const result = originalRenderAll.apply(this, arguments);
      relocateAiButtons();
      return result;
    };
    wrappedRenderAll.__codexAiWrapped = true;
    renderAll = wrappedRenderAll;
  }

  relocateAiButtons();

  document.addEventListener("keydown", (event) => {
    if(event.key === "Escape"){
      closeUnifiedAiHelp();
    }
  });
})();
/* Codex Unified AI Logic End */

/* Codex AI Models Logic Start */
(function(){
  const AI_MODELS_KEY = "stat102_1_2_ai_models_v1";

  function aiStoreGet(key){
    try{
      if(typeof storageGet === "function") return storageGet(key);
    }catch(e){}
    try{
      return localStorage.getItem(key);
    }catch(e){
      return null;
    }
  }

  function aiStoreSet(key, value){
    try{
      if(typeof storageSet === "function"){
        storageSet(key, value);
        return;
      }
    }catch(e){}
    try{
      localStorage.setItem(key, value);
    }catch(e){}
  }

  function defaultAiModelsState(){
    return {
      events: [],
      topics: {},
      lastTopic: "â€”",
      /* â”€â”€ ط§ظ„ظ†ظ…ط§ط°ط¬ ط§ظ„ط®ظ…ط³ط© ط§ظ„ط¬ط¯ظٹط¯ط© â”€â”€ */
      irtTheta: 0,          /* ظ‚ط¯ط±ط© ط§ظ„ط·ط§ظ„ط¨ IRT */
      irtSE: 1.0,           /* ط®ط·ط£ ظ…ط¹ظٹط§ط±ظٹ IRT */
      irtN: 0,              /* ط¹ط¯ط¯ ط§ظ„طھظ‚ط¯ظٹط±ط§طھ */
      errorCounts: { conceptual:0, computational:0, application:0 }, /* ط£ظ†ظ…ط§ط· ط§ظ„ط£ط®ط·ط§ط، */
      confidenceEvents: [], /* ظ„ط­ط³ط§ط¨ Brier Score */
      forgettingDays: {},   /* ط¢ط®ط± ظ…ط±ط§ط¬ط¹ط© ظ„ظƒظ„ ظ…ظˆط¶ظˆط¹ (timestamp) */
      forgettingStability:{} /* ظ‚ظˆط© ط§ظ„ط°ط§ظƒط±ط© ظ„ظƒظ„ ظ…ظˆط¶ظˆط¹ */
    };
  }

  function loadAiModelsState(){
    try{
      const raw = aiStoreGet(AI_MODELS_KEY);
      if(!raw) return defaultAiModelsState();
      const parsed = JSON.parse(raw);
      return parsed && typeof parsed === "object" ? parsed : defaultAiModelsState();
    }catch(e){
      return defaultAiModelsState();
    }
  }

  const aiModelsState = loadAiModelsState();

  function saveAiModelsState(){
    aiStoreSet(AI_MODELS_KEY, JSON.stringify(aiModelsState));
  }

  function clamp(value, min, max){
    return Math.max(min, Math.min(max, value));
  }

  function sigmoid(value){
    return 1 / (1 + Math.exp(-value));
  }

  function bktUpdate(prior, isCorrect, T=0.18, G=0.2, S=0.1){
    const p = clamp(prior, 0.001, 0.999);
    let posterior = isCorrect
      ? (p * (1 - S)) / ((p * (1 - S)) + ((1 - p) * G))
      : (p * S) / ((p * S) + ((1 - p) * (1 - G)));
    return posterior + (1 - posterior) * T;
  }

  function getRecentModelEvents(count=6){
    return (aiModelsState.events || []).slice(-count);
  }

  function recentAccuracy(count=6){
    const events = getRecentModelEvents(count);
    if(!events.length) return 0.5;
    return events.filter((item) => item.correct).length / events.length;
  }

  function averageAttempts(count=6){
    const events = getRecentModelEvents(count);
    if(!events.length) return 1;
    return events.reduce((sum, item) => sum + (item.attempts || 1), 0) / events.length;
  }

  function computeLR(mastery){
    const acc = recentAccuracy(6);
    const wrongRate = 1 - acc;
    const attempts = averageAttempts(6);
    return clamp(sigmoid(-0.55 + 2.2 * acc + 1.85 * mastery - 0.42 * wrongRate - 0.22 * (attempts - 1)), 0.05, 0.98);
  }

  function computeNB(model){
    const errorRate = model.attempts ? model.wrong / model.attempts : 0.5;
    const extraAttempts = model.attempts ? Math.max(0, (model.attempts - model.correct)) / model.attempts : 0.5;
    return clamp(0.18 + 0.44 * errorRate + 0.22 * extraAttempts + 0.22 * (1 - model.mastery), 0.05, 0.98);
  }

  function computeKNN(mastery){
    const features = [recentAccuracy(6), mastery, clamp((averageAttempts(6) - 1) / 2, 0, 1)];
    const prototypes = [
      { f:[0.86, 0.84, 0.06], y:0.93 },
      { f:[0.70, 0.63, 0.24], y:0.76 },
      { f:[0.52, 0.48, 0.42], y:0.58 },
      { f:[0.34, 0.30, 0.68], y:0.31 }
    ];
    const weighted = prototypes.map((prototype) => {
      const distance = Math.sqrt(prototype.f.reduce((sum, value, index) => sum + Math.pow(value - features[index], 2), 0));
      return { weight: 1 / (distance + 0.08), value: prototype.y };
    });
    const totalWeight = weighted.reduce((sum, item) => sum + item.weight, 0);
    return clamp(weighted.reduce((sum, item) => sum + item.weight * item.value, 0) / totalWeight, 0.05, 0.98);
  }

  /* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
     ط§ظ„ظ†ظ…ظˆط°ط¬ ظ،: ظ…ظ†ط­ظ†ظ‰ ط§ظ„ظ†ط³ظٹط§ظ† (Ebbinghaus)
  â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
  function forgettingRetention(daysSince, stability){
    /* R = e^(-t/S) â€” ظ†ط³ط¨ط© ط§ظ„ط§ط­طھظپط§ط¸ ط¨ط§ظ„ظ…ط¹ظ„ظˆظ…ط© */
    return Math.exp(-Math.max(0, daysSince) / Math.max(0.1, stability));
  }
  function forgettingReviewLabel(retention){
    if(retention < 0.5) return { text:"ط±ط§ط¬ط¹ ط§ظ„ط¢ظ†", cls:"now" };
    if(retention < 0.75) return { text:"ط±ط§ط¬ط¹ ظ‚ط±ظٹط¨ط§ظ‹", cls:"soon" };
    return { text:"ط¨ط®ظٹط± âœ“", cls:"ok" };
  }
  function updateForgetting(model, correct){
    /* طھط­ط¯ظٹط« ظ‚ظˆط© ط§ظ„ط°ط§ظƒط±ط© ط¨ط¹ط¯ ظƒظ„ ظ…ط±ط§ط¬ط¹ط© */
    const oldStab = model.forgettingStab || 1.0;
    model.forgettingStab = correct
      ? clamp(oldStab * 1.8, 1, 60)   /* ظ†ط¬ط§ط­: طھط¶ط§ط¹ظپ ط§ظ„ط§ط³طھظ‚ط±ط§ط± */
      : clamp(oldStab * 0.5, 0.3, 60); /* ظپط´ظ„: ط§ظ†ط®ظپط§ط¶ ط§ظ„ط§ط³طھظ‚ط±ط§ط± */
    model.lastStudied = Date.now();
  }

  /* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
     ط§ظ„ظ†ظ…ظˆط°ط¬ ظ¢: IRT â€” Item Response Theory
  â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
  function irtProb(theta, b, a=1.0){
    /* P(correct) = 1 / (1 + e^(-a*(خ¸-b))) */
    return 1 / (1 + Math.exp(-a * (theta - b)));
  }
  function updateIRT(correct, model){
    /* طھظ‚ط¯ظٹط± خ¸ ط¨ط®ظˆط§ط±ط²ظ…ظٹط© طھط¯ط±ط¬ ط¨ط³ظٹط·ط© (EAP-like online) */
    if(!aiModelsState.irtN) aiModelsState.irtN = 0;
    const theta = aiModelsState.irtTheta || 0;
    const b = model.irtB || 0;
    const p = irtProb(theta, b);
    const lr_rate = 0.65 / (1 + aiModelsState.irtN * 0.02);
    const delta = correct ? lr_rate * (1 - p) : -lr_rate * p;
    aiModelsState.irtTheta = clamp((theta + delta), -3, 3);
    /* طھط­ط¯ظٹط« طµط¹ظˆط¨ط© ط§ظ„ط³ط¤ط§ظ„ (item difficulty) */
    const itemLR = 0.25 / (1 + (model.attempts || 1) * 0.05);
    model.irtB = clamp(b + (correct ? -itemLR * (1-p) : itemLR * p), -3, 3);
    /* ط®ط·ط£ ظ…ط¹ظٹط§ط±ظٹ â€” ظٹظ‚ظ„ ظ…ط¹ ط²ظٹط§ط¯ط© ط§ظ„ظ…ط­ط§ظˆظ„ط§طھ */
    aiModelsState.irtSE = clamp(1.0 / Math.sqrt(1 + aiModelsState.irtN * 0.5), 0.15, 1.0);
    aiModelsState.irtN += 1;
  }
  function irtThetaLabel(theta){
    var evts = aiModelsState.events || [];
    var att = evts.length;
    var ok = evts.filter(function(e){return e.correct}).length;
    var pct = att > 0 ? ok / att : 0;
    if(pct >= 0.85) return { text:"ظ…طھظ‚ط¯ظ…", color:"#059669" };
    if(pct >= 0.65) return { text:"ط¬ظٹط¯", color:"#0369a1" };
    if(pct >= 0.45) return { text:"ظ…طھظˆط³ط·", color:"#d97706" };
    if(pct >= 0.25) return { text:"ط¯ظˆظ† ط§ظ„ظ…طھظˆط³ط·", color:"#dc2626" };
    if(att === 0) return { text:"ظ„ظ… ظٹظڈظ‚ظٹظ‘ظ… ط¨ط¹ط¯", color:"#94a3b8" };
    return { text:"ظٹط­طھط§ط¬ ط¯ط¹ظ…ط§ظ‹", color:"#dc2626" };
  }

  /* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
     ط§ظ„ظ†ظ…ظˆط°ط¬ ظ£: ظ…ط­ظ„ظ„ ظ†ظ…ط· ط§ظ„ط£ط®ط·ط§ط،
  â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
  const ERROR_TYPES = {
    conceptual:    { label:"ط®ط·ط£ ظ…ظپط§ظ‡ظٹظ…ظٹ",  badge:"conceptual",    advice:"ط±ط§ط¬ط¹ طھط¹ط±ظٹظپ ط§ظ„ط§ط±طھط¨ط§ط· ظˆط§ظ„ظ…ظپط§ظ‡ظٹظ… ط§ظ„ط£ط³ط§ط³ظٹط©" },
    computational: { label:"ط®ط·ط£ ط­ط³ط§ط¨ظٹ",    badge:"computational", advice:"طھط­ظ‚ظ‚ ظ…ظ† ط®ط·ظˆط§طھ ط­ط³ط§ط¨ خ£XY ظˆ Sxx" },
    application:   { label:"ط®ط·ط£ طھط·ط¨ظٹظ‚ظٹ",   badge:"application",   advice:"ط±ط§ط¬ط¹ ظƒظٹظپظٹط© طھط·ط¨ظٹظ‚ ط§ظ„طµظٹط؛ط© ط¹ظ„ظ‰ ط§ظ„ط¨ظٹط§ظ†ط§طھ" },
    none:          { label:"ظ„ط§ ط£ط®ط·ط§ط،",      badge:"none",          advice:"ط£ط¯ط§ط، ظ…ظ…طھط§ط²طŒ ط§ط³طھظ…ط±!" }
  };
  function classifyError(correct, attempts, mastery){
    if(correct) return "none";
    /* طھطµظ†ظٹظپ ظ…ط¨ظ†ظٹ ط¹ظ„ظ‰ ط§ظ„ط¥طھظ‚ط§ظ† ظˆط§ظ„ظ…ط­ط§ظˆظ„ط§طھ */
    if(mastery < 0.35) return "conceptual";    /* ط¥طھظ‚ط§ظ† ظ…ظ†ط®ظپط¶ = ط®ط·ط£ ظ…ظپط§ظ‡ظٹظ…ظٹ */
    if(attempts > 2)   return "computational"; /* ظ…ط­ط§ظˆظ„ط§طھ ط¹ط¯ظٹط¯ط© = ط®ط·ط£ ط­ط³ط§ط¨ظٹ */
    return "application";                       /* ط؛ظٹط± ط°ظ„ظƒ = ط®ط·ط£ طھط·ط¨ظٹظ‚ظٹ */
  }
  function updateErrorPattern(correct, attempts, model){
    const errType = classifyError(correct, attempts, model.mastery);
    model.errorType = errType;
    if(!aiModelsState.errorCounts) aiModelsState.errorCounts = { conceptual:0, computational:0, application:0 };
    if(errType !== "none") aiModelsState.errorCounts[errType] = (aiModelsState.errorCounts[errType] || 0) + 1;
  }
  function dominantErrorType(){
    const ec = aiModelsState.errorCounts || {};
    const sorted = Object.entries(ec).sort((a,b) => b[1]-a[1]);
    if(!sorted.length || sorted[0][1] === 0) return "none";
    return sorted[0][0];
  }

  /* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
     ط§ظ„ظ†ظ…ظˆط°ط¬ ظ¤: ظ…ط¹ط§ظٹط±ط© ط§ظ„ط«ظ‚ط© (Brier Score)
     ظ…ظ„ط§ط­ط¸ط©: ظ†ط³طھط®ط¯ظ… mastery ظƒطھظ‚ط¯ظٹط± ظ„ظ„ط«ظ‚ط© ظ„ط£ظ†
     ط§ظ„ظˆط§ط¬ظ‡ط© ظ„ط§ طھط·ظ„ط¨ ط«ظ‚ط© طµط±ظٹط­ط© ظ…ظ† ط§ظ„ظ…ط³طھط®ط¯ظ…
  â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
  function updateConfidenceCalib(correct, model){
    const evts = aiModelsState.events || []; const confidence = evts.length > 0 ? evts.filter(function(e){return e.correct}).length / evts.length : 0.5;
    if(!aiModelsState.confidenceEvents) aiModelsState.confidenceEvents = [];
    aiModelsState.confidenceEvents.push({ confidence, correct: correct ? 1 : 0 });
    if(aiModelsState.confidenceEvents.length > 60)
      aiModelsState.confidenceEvents = aiModelsState.confidenceEvents.slice(-60);
  }
  function brierScore(){
    const ev = aiModelsState.confidenceEvents || [];
    if(ev.length < 2) return null;
    const bs = ev.reduce((s,e) => s + Math.pow(e.confidence - e.correct, 2), 0) / ev.length;
    return bs;
  }
  function calibDiagnosis(){
    var evts = aiModelsState.events || [];
    var att = evts.length;
    var ok = evts.filter(function(e){return e.correct}).length;
    if(att === 0) return { text:"ظ„ط§ طھظˆط¬ط¯ ط¨ظٹط§ظ†ط§طھ ظƒط§ظپظٹط© ط¨ط¹ط¯.", cls:"" };
    var pct = ok / att;
    if(pct >= 0.85) return { text:"ًںژ¯ ط£ط¯ط§ط، ظ…ظ…طھط§ط² â€” ط§ط³طھظ…ط± ظپظٹ ظ‡ط°ط§ ط§ظ„ظ…ط³طھظˆظ‰!", cls:"good" };
    if(pct >= 0.6) return { text:"âœ“ ط£ط¯ط§ط، ط¬ظٹط¯ ظ…ط¹ ظ…ط¬ط§ظ„ ظ„ظ„طھط­ط³ظٹظ†.", cls:"good" };
    if(pct >= 0.4) return { text:"âڑ ï¸ڈ ط£ط¯ط§ط، ظ…طھظˆط³ط· â€” ط±ظƒظ‘ط² ط¹ظ„ظ‰ ط§ظ„ظ…ظپط§ظ‡ظٹظ… ط§ظ„طھظٹ ط£ط®ط·ط£طھ ظپظٹظ‡ط§.", cls:"warn" };
    return { text:"âڑ ï¸ڈ ط£ط¯ط§ط، ط¶ط¹ظٹظپ â€” ط±ط§ط¬ط¹ ط§ظ„ظ…ط§ط¯ط© ط¨طھظ…ط¹ظ‘ظ† ظˆط£ط¹ط¯ ط§ظ„ظ…ط­ط§ظˆظ„ط©.", cls:"bad" };
  }

  /* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
     ط§ظ„ظ†ظ…ظˆط°ط¬ ظ¥: طھظˆظ‚ط¹ ط§ظ„ط¯ط±ط¬ط©
  â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
  function predictGrade(ensemble, bkt, lr_val, completion){
    const trend = (aiModelsState.events || []).length >= 4
      ? (() => {
          const ev = (aiModelsState.events || []).slice(-6);
          const half1 = ev.slice(0, Math.floor(ev.length/2));
          const half2 = ev.slice(Math.floor(ev.length/2));
          const acc1 = half1.filter(e=>e.correct).length / (half1.length||1);
          const acc2 = half2.filter(e=>e.correct).length / (half2.length||1);
          return acc2 - acc1; /* ظ…ظˆط¬ط¨ = ظٹطھط­ط³ظ† */
        })()
      : 0;
    const raw = clamp(
      bkt * 0.35 + ensemble * 0.30 + lr_val * 0.20 + clamp(completion, 0, 1) * 0.15 + trend * 0.1,
      0, 1
    );
    if(raw >= 0.88) return { grade:"ظ…ظ…طھط§ط²",        range:"90-100", color:"#059669", tip:"ظ…ط³طھظˆظ‰ ط±ط§ط¦ط¹طŒ ط±ط§ط¬ط¹ ط¨ط§ظ†طھط¸ط§ظ… ظ„ظ„ط­ظپط§ط¸ ط¹ظ„ظٹظ‡." };
    if(raw >= 0.75) return { grade:"ط¬ظٹط¯ ط¬ط¯ط§ظ‹",     range:"75-89",  color:"#0369a1", tip:"ظ‚ط±ظٹط¨ ط¬ط¯ط§ظ‹ ظ…ظ† ط§ظ„ط§ظ…طھظٹط§ط²طŒ ط±ظƒظ‘ط² ط¹ظ„ظ‰ ط§ظ„ظ…ظˆط§ط¶ظٹط¹ ط§ظ„ط£ط¶ط¹ظپ." };
    if(raw >= 0.60) return { grade:"ط¬ظٹط¯",           range:"60-74",  color:"#d97706", tip:"ظ…ط±ط§ط¬ط¹ط© ط¥ط¶ط§ظپظٹط© ط³طھط­ط³ظ‘ظ† ظ†طھظٹط¬طھظƒ ط¨ط´ظƒظ„ ظ…ظ„ط­ظˆط¸." };
    return             { grade:"ظٹط­طھط§ط¬ ظ…ط±ط§ط¬ط¹ط©",   range:"< 60",   color:"#dc2626", tip:"ط§ط¨ط¯ط£ ط§ظ„ظ…ط±ط§ط¬ط¹ط© ظ…ظ† ط§ظ„ظ…ظپط§ظ‡ظٹظ… ط§ظ„ط£ط³ط§ط³ظٹط©." };
  }

  function sanitizeAiKey(value){
    return String(value || "topic").toLowerCase().replace(/[^\p{L}\p{N}]+/gu, "_").replace(/^_+|_+$/g, "") || "topic";
  }

  function getTopicMeta(question, branch, branchIndex){
    const title = String((question && question.title) || (branch && (branch.level || branch.name)) || ("ط³ط¤ط§ظ„ " + (branchIndex + 1 || 1))).trim();
    const keyBase = (question && question.id) ? question.id : title;
    return { key: sanitizeAiKey(keyBase), label: title };
  }

  function ensureTopicModel(meta){
    if(!aiModelsState.topics[meta.key]){
      aiModelsState.topics[meta.key] = {
        label: meta.label,
        attempts: 0,
        correct: 0,
        wrong: 0,
        mastery: 0.25,
        bkt: 0.25,
        nbWeak: 0.5,
        nbScore: 0.5,
        lr: 0.5,
        knn: 0.5,
        ensemble: 0.5,
        lastProb: 0.5,
        /* IRT per-topic */
        irtB: 0,        /* طµط¹ظˆط¨ط© ط§ظ„ط³ط¤ط§ظ„ */
        /* Forgetting */
        lastStudied: Date.now(),
        forgettingStab: 1.0,
        /* Error pattern (per topic) */
        errorType: "none"
      };
    }
    return aiModelsState.topics[meta.key];
  }

  function recordAiModelsAttempt(question, branch, branchIndex, correct, attempts){
    const meta = getTopicMeta(question, branch, branchIndex);
    const model = ensureTopicModel(meta);
    model.attempts += 1;
    if(correct) model.correct += 1;
    else model.wrong += 1;
    model.mastery = bktUpdate(model.mastery, correct);
    model.bkt = model.mastery;
    model.lr = computeLR(model.mastery);
    model.nbWeak = computeNB(model);
    model.nbScore = clamp(1 - model.nbWeak, 0.05, 0.98);
    model.knn = computeKNN(model.mastery);
    model.ensemble = clamp(0.20 * model.nbScore + 0.50 * model.lr + 0.30 * model.knn, 0.05, 0.98);
    model.lastProb = model.ensemble;
    aiModelsState.lastTopic = meta.label;
    /* â”€â”€ ط§ظ„ظ†ظ…ط§ط°ط¬ ط§ظ„ط®ظ…ط³ط© ط§ظ„ط¬ط¯ظٹط¯ط© â”€â”€ */
    updateForgetting(model, correct);
    updateIRT(correct, model);
    updateErrorPattern(correct, attempts || 1, model);
    updateConfidenceCalib(correct, model);
    /* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
    aiModelsState.events.push({
      topicKey: meta.key,
      topicLabel: meta.label,
      correct: !!correct,
      attempts: attempts || 1,
      time: Date.now()
    });
    if(aiModelsState.events.length > 120){
      aiModelsState.events = aiModelsState.events.slice(-120);
    }
    saveAiModelsState();
  }

  function averageMetric(selector, fallback){
    const models = Object.values(aiModelsState.topics || {});
    if(!models.length) return fallback;
    return models.reduce((sum, item) => sum + selector(item), 0) / models.length;
  }

  function weakestTopic(){
    const models = Object.values(aiModelsState.topics || {});
    if(!models.length) return null;
    return models.slice().sort((a, b) => (a.ensemble - b.ensemble) || (a.mastery - b.mastery))[0];
  }

  function strongestTopic(){
    const models = Object.values(aiModelsState.topics || {});
    if(!models.length) return null;
    return models.slice().sort((a, b) => (b.ensemble - a.ensemble) || (b.mastery - a.mastery))[0];
  }

  function aiInferenceText(){
    const weak = weakestTopic();
    const strong = strongestTopic();
    const ensemble = averageMetric((item) => item.ensemble, 0.5);
    if(!weak){
      return "طھط¸ظ‡ط± ظ‡ظ†ط§ ظ‚ط±ط§ط،ط© ط§ظ„ط£ط¯ط§ط، ط¨ط¹ط¯ ط¨ط¯ط، ط§ظ„ط¥ط¬ط§ط¨ط§طھ ط§ظ„ظ…ط­ظپظˆط¸ط©.";
    }
    const statusText = ensemble < 0.45
      ? "ظ‡ظ†ط§ظƒ ط­ط§ط¬ط© ط¥ظ„ظ‰ ط¯ط¹ظ… ط¥ط¶ط§ظپظٹ ظ‚ط¨ظ„ ط§ظ„ط³ط¤ط§ظ„ ط§ظ„طھط§ظ„ظٹ."
      : (ensemble < 0.7
        ? "ط§ظ„ظˆط¶ط¹ ظ…طھظˆط³ط· ظˆظٹط­طھط§ط¬ ط¥ظ„ظ‰ طھط«ط¨ظٹطھ ط£ظƒط«ط±."
        : "ط§ظ„ط£ط¯ط§ط، ط§ظ„ط­ط§ظ„ظٹ ظٹظˆط­ظٹ ط¨ط¬ط§ظ‡ط²ظٹط© ط¬ظٹط¯ط© ظ„ظ„ط³ط¤ط§ظ„ ط§ظ„طھط§ظ„ظٹ.");
    return `ط§ظ„ظ…ظˆط¶ظˆط¹ ط§ظ„ط£ظ‚ظˆظ‰ ط­ط§ظ„ظٹظ‹ط§: آ«${strong ? strong.label : "â€”"}آ»طŒ ظˆط§ظ„ظ…ظˆط¶ظˆط¹ ط§ظ„ط°ظٹ ظٹط­طھط§ط¬ ط¥ظ„ظ‰ ظ…ط±ط§ط¬ط¹ط©: آ«${weak.label}آ». ${statusText}`;
  }

  function ensureAiModelsPanelMount(){
    const rail = document.querySelector(".aiResultsRail");
    if(!rail) return null;
    let panel = document.getElementById("aiModelsPanel");
    if(panel) return panel;
    panel = document.createElement("div");
    panel.id = "aiModelsPanel";
    panel.className = "aiModelsPanel";
    rail.appendChild(panel);
    return panel;
  }

  function renderAiModelsPanel(){
    const panel = ensureAiModelsPanelMount();
    if(!panel) return;

    const bkt      = averageMetric((item) => item.bkt, 0.25);
    const nb       = averageMetric((item) => item.nbScore, 0.5);
    const lr_avg   = averageMetric((item) => item.lr, 0.5);
    const knn      = averageMetric((item) => item.knn, 0.5);
    const ensemble = averageMetric((item) => item.ensemble, 0.5);
    const topics   = Object.values(aiModelsState.topics || {});
    const strong   = strongestTopic();
    const weak     = weakestTopic();

    /* â”€â”€ ط¨ظٹط§ظ†ط§طھ ط§ظ„ظ†ظ…ط§ط°ط¬ ط§ظ„ط¬ط¯ظٹط¯ط© â”€â”€ */
    const theta    = aiModelsState.irtTheta || 0;
    const se       = aiModelsState.irtSE || 1.0;
    const thetaLbl = irtThetaLabel(theta);
    const thetaPct = clamp((theta + 3) / 6, 0, 1) * 100; /* 0% = -3, 100% = +3 */

    const domErr   = dominantErrorType();
    const errInfo  = ERROR_TYPES[domErr] || ERROR_TYPES.none;
    const ec       = aiModelsState.errorCounts || {};
    const errTotal = (ec.conceptual||0) + (ec.computational||0) + (ec.application||0);

    const bs       = brierScore();
    const calibDx  = calibDiagnosis();
    const totalAtt = (aiModelsState.events||[]).length;
    const totalOk  = (aiModelsState.events||[]).filter(e=>e.correct).length;
    const completion = topics.length
      ? clamp(topics.filter(t=>t.attempts>0).length / Math.max(1, topics.length), 0, 1)
      : 0;
    const grade    = predictGrade(ensemble, bkt, lr_avg, completion);

    /* â”€â”€ ط¨ظ†ط§ط، HTML ظ„ظˆط­ط© ظ…ظ†ط­ظ†ظ‰ ط§ظ„ظ†ط³ظٹط§ظ† â”€â”€ */
    const forgettingRows = topics.map(t => {
      const daysSince = ((Date.now() - (t.lastStudied || Date.now())) / 86400000);
      const ret       = forgettingRetention(daysSince, t.forgettingStab || 1.0);
      const rvw       = forgettingReviewLabel(ret);
      const fillColor = ret > 0.74 ? "linear-gradient(90deg,#059669,#34d399)"
                      : ret > 0.49 ? "linear-gradient(90deg,#d97706,#fbbf24)"
                      : "linear-gradient(90deg,#dc2626,#f87171)";
      return `
        <div class="forgettingTopicRow">
          <div class="forgettingTopicName">${escapeHtml(t.label)}</div>
          <div class="forgettingBar"><div class="forgettingFill" style="width:${Math.round(ret*100)}%;background:${fillColor}"></div></div>
          <div class="forgettingPct" style="color:${ret>0.74?'#059669':ret>0.49?'#d97706':'#dc2626'}">${Math.round(ret*100)}%</div>
          <span class="forgettingReview ${rvw.cls}">${rvw.text}</span>
        </div>`;
    }).join("");

    /* â”€â”€ ط¨ظ†ط§ط، HTML ظ…ط­ظ„ظ„ ط§ظ„ط£ط®ط·ط§ط، â”€â”€ */
    const errBarTotal = Math.max(1, errTotal);
    const errBars = ["conceptual","computational","application"].map(k => {
      const cnt = ec[k]||0;
      const pct = cnt/errBarTotal*100;
      const col = k==="conceptual"?"#dc2626":k==="computational"?"#d97706":"#7c3aed";
      return `<div class="errorBarSeg" style="width:${pct}%;background:${col}"></div>`;
    }).join("");

    panel.innerHTML = `
      <!-- â•گâ•گâ•گ Hero â•گâ•گâ•گ -->
      <div class="aiModelsHero">
        <div class="aiModelsHeroTop">
          <div class="aiModelsCopy">
            
            <div class="aiModelsTitle">ظ…ط¤ط´ط±ط§طھ ط£ط¯ط§ط، ط§ظ„ط·ط§ظ„ط¨</div>
          </div>
          <div class="aiModelsOrb"><span></span></div>
        </div>
        <div class="aiModelsChips">
          <span class="aiModelsChip">ط§ظ„ط¥طھظ‚ط§ظ†</span>
          <span class="aiModelsChip">ط§ظ„ط¯ظ‚ط©</span>
          <span class="aiModelsChip">ط§ظ„ط¬ط§ظ‡ط²ظٹط©</span>
          <span class="aiModelsChip">ط§ظ„ط«ط¨ط§طھ</span>
          <span class="aiModelsChip">ط§ظ„ظ‚ط¯ط±ط©</span>
          <span class="aiModelsChip">ط§ظ„ط°ط§ظƒط±ط©</span>
          <span class="aiModelsChip">ط§ظ„ط£ط®ط·ط§ط،</span>
          <span class="aiModelsChip">ط§ظ„ط«ظ‚ط©</span>
          <span class="aiModelsChip">ط§ظ„طھظˆظ‚ط¹</span>
        </div>
      </div>

      <!-- â•گâ•گâ•گ ط§ظ„ظ†ظ…ط§ط°ط¬ ط§ظ„ط£طµظ„ظٹط© ط§ظ„ط£ط±ط¨ط¹ط© â•گâ•گâ•گ -->
      <div class="aiModelsGrid">
        <div class="aiModelCard">
          <div class="aiModelHead"><div class="aiModelIcon">ط¥طھ</div><div class="aiModelName">ط§ظ„ط¥طھظ‚ط§ظ†</div></div>
          <div class="aiModelValue">${Math.round(bkt*100)}%</div>
          <div class="aiModelMeta">ظٹط¹ظƒط³ ظ…ط³طھظˆظ‰ ط§ظ„ط¥طھظ‚ط§ظ† ط§ظ„ط­ط§ظ„ظٹ ط¨ظ†ط§ط،ظ‹ ط¹ظ„ظ‰ طھط³ظ„ط³ظ„ ط§ظ„ط¥ط¬ط§ط¨ط§طھ.</div>
        </div>
        <div class="aiModelCard">
          <div class="aiModelHead"><div class="aiModelIcon">ط¯ظ‚</div><div class="aiModelName">ط§ظ„ط¯ظ‚ط©</div></div>
          <div class="aiModelValue">${Math.round(nb*100)}%</div>
          <div class="aiModelMeta">ظٹط¹ظƒط³ ط¬ظˆط¯ط© ط§ظ„ط¥ط¬ط§ط¨ط§طھ ط§ظ„ظ…ط­ظپظˆط¸ط©.</div>
        </div>
        <div class="aiModelCard">
          <div class="aiModelHead"><div class="aiModelIcon">ط¬ظ‡</div><div class="aiModelName">ط§ظ„ط¬ط§ظ‡ط²ظٹط©</div></div>
          <div class="aiModelValue">${Math.round(lr_avg*100)}%</div>
          <div class="aiModelMeta">ط§ظ„ط§ط³طھط¹ط¯ط§ط¯ ظ„ظ„ط§ظ†طھظ‚ط§ظ„ ظ„ظ„ظ…ط³طھظˆظ‰ ط§ظ„طھط§ظ„ظٹ.</div>
        </div>
        <div class="aiModelCard">
          <div class="aiModelHead"><div class="aiModelIcon">ط«ط¨</div><div class="aiModelName">ط§ظ„ط«ط¨ط§طھ</div></div>
          <div class="aiModelValue">${Math.round(knn*100)}%</div>
          <div class="aiModelMeta">ط§طھط³ط§ظ‚ ط§ظ„ط£ط¯ط§ط، ط¨ظٹظ† ط§ظ„ظ…ط­ط§ظˆظ„ط§طھ.</div>
        </div>
        <div class="aiModelCard full">
          <div class="aiModelHead"><div class="aiModelIcon">ط¹ط§</div><div class="aiModelName">ط§ظ„ط£ط¯ط§ط، ط§ظ„ط¹ط§ظ…</div></div>
          <div class="aiModelValue">${Math.round(ensemble*100)}%</div>
          <div class="aiModelMeta">ظ…ظ„ط®طµ ط§ظ„ط£ط¯ط§ط، ط§ظ„ط­ط§ظ„ظٹ. ط¢ط®ط± ظ…ظˆط¶ظˆط¹: ${escapeHtml(aiModelsState.lastTopic||"â€”")}</div>
        </div>
      </div>

      <!-- â•گâ•گâ•گ ظ„ظˆط­ط© ط§ظ„ط¥طھظ‚ط§ظ† â•گâ•گâ•گ -->
      <div class="aiTopicBoard">
        <div class="aiSectionTitle">ظ„ظˆط­ط© ط§ظ„ط¥طھظ‚ط§ظ† ط­ط³ط¨ ط§ظ„ظ…ظˆط¶ظˆط¹</div>
        <div class="aiTopicList">
          ${topics.length ? topics.map(topic=>`
            <div class="aiTopicRow">
              <div class="aiTopicName">${escapeHtml(topic.label)}</div>
              <div class="aiTopicBar"><div class="aiTopicFill" style="width:${Math.round(topic.mastery*100)}%"></div></div>
              <div class="aiTopicPct">${Math.round(topic.mastery*100)}%</div>
            </div>`).join("") :
            `<div class="aiModelMeta">ظ„ط§ طھظˆط¬ط¯ ط¨ظٹط§ظ†ط§طھ ط¨ط¹ط¯. ط§ط¨ط¯ط£ ط¨ط­ظپط¸ ط¥ط¬ط§ط¨ط© ظ„ظٹط¨ط¯ط£ ط§ظ„طھط­ظ„ظٹظ„.</div>`}
        </div>
      </div>

      <!-- â•گâ•گâ•گ ط§ظ„ظ†ظ…ظˆط°ط¬ ظ،: ظ…ظ†ط­ظ†ظ‰ ط§ظ„ظ†ط³ظٹط§ظ† â•گâ•گâ•گ -->
      <div class="aiExtSection">
        <div class="aiExtSectionTitle">
          ظ…ظ†ط­ظ†ظ‰ ط§ظ„ظ†ط³ظٹط§ظ† â€” ط§ط­طھظپط§ط¸ظƒ ط¨ط§ظ„ظ…ط§ط¯ط©
        </div>
        <div class="forgettingCard">
          ${topics.length ? forgettingRows :
            `<div class="aiModelMeta">ط§ط¨ط¯ط£ ط¨ط­ظپط¸ ط¥ط¬ط§ط¨ط© ظ„طھظپط¹ظٹظ„ ظ‡ط°ط§ ط§ظ„ظ…ط¤ط´ط±.</div>`}
        </div>
        <div class="aiModelMeta" style="margin-top:4px">
          ظٹظ‚ظٹط³ ظ†ط³ط¨ط© ط§ط­طھظپط§ط¸ظƒ ط¨ظƒظ„ ظ…ظˆط¶ظˆط¹ ظ…ط¹ ظ…ط±ظˆط± ط§ظ„ظˆظ‚طھ â€” ظٹط±طھظپط¹ ط¨ط§ظ„ظ…ط±ط§ط¬ط¹ط© ط§ظ„ظ…ظ†طھط¸ظ…ط©.
        </div>
      </div>

      <!-- â•گâ•گâ•گ ط§ظ„ظ†ظ…ظˆط°ط¬ ظ¢: ط§ظ„ظ‚ط¯ط±ط© ط§ظ„ظ…ط¹ط±ظپظٹط© â•گâ•گâ•گ -->
      <div class="aiExtSection">
        <div class="aiExtSectionTitle">
          ط§ظ„ظ‚ط¯ط±ط© ط§ظ„ظ…ط¹ط±ظپظٹط© â€” ظ…ط³طھظˆط§ظƒ ط§ظ„طھظ‚ط¯ظٹط±ظٹ
        </div>
        <div class="irtCard">
          <div class="irtTheta">
            <div>
              <div class="irtThetaNum" style="color:${thetaLbl.color}">
                ط§ظ„ظ…ط³طھظˆظ‰: ${thetaLbl.text}
              </div>
              <div class="irtThetaSub">ظ†ط³ط¨ط© ط§ظ„ط¥ط¬ط§ط¨ط§طھ ط§ظ„طµط­ظٹط­ط©: ${totalAtt > 0 ? Math.round((totalOk/totalAtt)*100) : 0}%</div>
            </div>
          </div>
          <div>
            <div class="irtScale">
              <div class="irtPointer" style="left:${totalAtt > 0 ? Math.min(100,Math.round((totalOk/totalAtt)*100)) : 50}%"></div>
            </div>
            <div class="irtLabels">
              <span>ط¶ط¹ظٹظپ</span><span></span><span>ظ…طھظˆط³ط·</span><span></span><span>ظ…طھظ‚ط¯ظ…</span>
            </div>
          </div>
          <div class="irtSE">
            ط¨ظ†ط§ط،ظ‹ ط¹ظ„ظ‰ ${totalOk} ط¥ط¬ط§ط¨ط© طµط­ظٹط­ط© ظ…ظ† ط£طµظ„ ${totalAtt} ظ…ط­ط§ظˆظ„ط©
          </div>
        </div>
      </div>

      <!-- â•گâ•گâ•گ ط§ظ„ظ†ظ…ظˆط°ط¬ ظ£: ظ…ط­ظ„ظ„ ط§ظ„ط£ط®ط·ط§ط، â•گâ•گâ•گ -->
      <div class="aiExtSection">
        <div class="aiExtSectionTitle">
          طھط´ط®ظٹطµ ظ†ظ…ط· ط£ط®ط·ط§ط¦ظƒ
        </div>
        <div class="errorPatternCard">
          ${errTotal > 0 ? `
          <div class="errorBarWrap">${errBars}</div>
          <div class="errorTypeRow">
            <span class="errorTypeBadge ${errInfo.badge}">${errInfo.label}</span>
            <div class="errorTypeDetail">
              <div class="errorTypeName">ط§ظ„ظ†ظ…ط· ط§ظ„ط£ظƒط«ط± طھظƒط±ط§ط±ط§ظ‹</div>
              <div class="errorTypeAdvice">${escapeHtml(errInfo.advice)}</div>
            </div>
            <div class="errorTypeCount">${errTotal}</div>
          </div>
          <div class="aiModelMeta" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;text-align:center">
            <span>ظ…ظپط§ظ‡ظٹظ…ظٹ: ${ec.conceptual||0}</span>
            <span>ط­ط³ط§ط¨ظٹ: ${ec.computational||0}</span>
            <span>طھط·ط¨ظٹظ‚ظٹ: ${ec.application||0}</span>
          </div>` :
          `<div class="errorTypeRow">
            <span class="errorTypeBadge none">ظ„ط§ ط£ط®ط·ط§ط،</span>
            <div class="errorTypeDetail">
              <div class="errorTypeName">ط£ط¯ط§ط، ظ…ط«ط§ظ„ظٹ ط­طھظ‰ ط§ظ„ط¢ظ†</div>
              <div class="errorTypeAdvice">ظ„ظ… طھظڈط³ط¬ظژظ‘ظ„ ط£ط®ط·ط§ط، â€” ط§ط³طھظ…ط± ظپظٹ ظ‡ط°ط§ ط§ظ„ظ…ط³طھظˆظ‰!</div>
            </div>
          </div>`}
        </div>
      </div>

      <!-- â•گâ•گâ•گ ط§ظ„ظ†ظ…ظˆط°ط¬ ظ¤: ظ…ط¯ظ‰ ط¯ظ‚ط© طھظ‚ظٹظٹظ…ظƒ ظ„ظ†ظپط³ظƒ â•گâ•گâ•گ -->
      <div class="aiExtSection">
        <div class="aiExtSectionTitle">
          ظ…ط¯ظ‰ ط¯ظ‚ط© طھظ‚ظٹظٹظ…ظƒ ظ„ظ†ظپط³ظƒ
        </div>
        <div class="calibCard">
          <div class="calibMatrix">
            <div class="calibCell">
              <div class="calibCellVal">${totalAtt}</div>
              <div class="calibCellLabel">ط¥ط¬ظ…ط§ظ„ظٹ ط§ظ„ظ…ط­ط§ظˆظ„ط§طھ</div>
            </div>
            <div class="calibCell">
              <div class="calibCellVal" style="color:#059669">${totalOk}</div>
              <div class="calibCellLabel">ط¥ط¬ط§ط¨ط§طھ طµط­ظٹط­ط©</div>
            </div>
            <div class="calibCell">
              <div class="calibCellVal" style="color:${totalAtt>0?(totalOk/totalAtt>=0.7?'#059669':totalOk/totalAtt>=0.4?'#d97706':'#dc2626'):'var(--muted)'}">
                ${totalAtt > 0 ? Math.round((totalOk/totalAtt)*100)+"%" : "â€”"}
              </div>
              <div class="calibCellLabel">ظ†ط³ط¨ط© ط§ظ„ظ†ط¬ط§ط­</div>
            </div>
          </div>
          ${calibDx.cls ? `<div class="calibScore ${calibDx.cls}">${escapeHtml(calibDx.text)}</div>` :
            `<div class="calibDiag">${escapeHtml(calibDx.text)}</div>`}
        </div>
      </div>

      <!-- â•گâ•گâ•گ ط§ظ„ظ†ظ…ظˆط°ط¬ ظ¥: طھظˆظ‚ط¹ ط§ظ„ط¯ط±ط¬ط© â•گâ•گâ•گ -->
      <div class="aiExtSection">
        <div class="aiExtSectionTitle">
          ط§ظ„طھظˆظ‚ط¹ ط§ظ„ظ…ط¨ط¯ط¦ظٹ ظ„ظ„ط¯ط±ط¬ط©
        </div>
        <div class="gradeCard">
          <div class="gradeBig" style="border-color:${grade.color}20;background:${grade.color}08">
            <div>
              <div class="gradeLabel" style="color:${grade.color}">${grade.grade}</div>
              <div class="gradeRange">ط§ظ„ظ†ط·ط§ظ‚ ط§ظ„ظ…طھظˆظ‚ط¹: ${grade.range}%</div>
            </div>
          </div>
          <div class="gradeTrajectory">
            <div class="gradeTrajectoryRow">
              <span style="font-size:10px;color:var(--muted)">ط§ظ„ط¥طھظ‚ط§ظ†</span>
              <div class="gradeTrajectoryBar"><div class="gradeTrajectoryFill" style="width:${Math.round(bkt*100)}%;background:linear-gradient(90deg,var(--brand),#38bdf8)"></div></div>
              <span style="color:var(--brand2)">${Math.round(bkt*100)}%</span>
            </div>
            <div class="gradeTrajectoryRow">
              <span style="font-size:10px;color:var(--muted)">ط§ظ„ط£ط¯ط§ط، ط§ظ„ط¹ط§ظ…</span>
              <div class="gradeTrajectoryBar"><div class="gradeTrajectoryFill" style="width:${Math.round(ensemble*100)}%;background:linear-gradient(90deg,#7c3aed,#a78bfa)"></div></div>
              <span style="color:#7c3aed">${Math.round(ensemble*100)}%</span>
            </div>
            <div class="gradeTrajectoryRow">
              <span style="font-size:10px;color:var(--muted)">ط§ظ„ط¥ظ†ط¬ط§ط²</span>
              <div class="gradeTrajectoryBar"><div class="gradeTrajectoryFill" style="width:${Math.round(completion*100)}%;background:linear-gradient(90deg,#059669,#34d399)"></div></div>
              <span style="color:#059669">${Math.round(completion*100)}%</span>
            </div>
          </div>
          <div class="gradeTip">${escapeHtml(grade.tip)}</div>
        </div>
      </div>

      <!-- â•گâ•گâ•گ ظ‚ط±ط§ط،ط© ط³ط±ظٹط¹ط© â•گâ•گâ•گ -->
      <div class="aiInferenceCard">
        <div class="aiSectionTitle">ظ‚ط±ط§ط،ط© ط³ط±ظٹط¹ط©</div>
        <div class="aiInferenceText">${escapeHtml(aiInferenceText())}</div>
        <div class="aiInferenceHint">
          ${weak ? ("ط£ط¶ط¹ظپ ظ…ظˆط¶ظˆط¹: " + escapeHtml(weak.label)) : "ط³ظٹط¸ظ‡ط± ط£ط¶ط¹ظپ ظ…ظˆط¶ظˆط¹ ط¨ط¹ط¯ ط£ظˆظ„ ظ…ط­ط§ظˆظ„ط© ظ…ط­ظپظˆط¸ط©."}
          ${strong ? (" | ط£ظ‚ظˆظ‰ ظ…ظˆط¶ظˆط¹: " + escapeHtml(strong.label)) : ""}
        </div>
      </div>
    `;
  }

  function wrapHandleSaveBranch(){
    if(typeof handleSaveBranch !== "function" || handleSaveBranch.__aiModelsWrapped) return;
    const original = handleSaveBranch;
    handleSaveBranch = function(q, branch, bi){
      const before = (typeof ensureBranchRec === "function") ? { attempts: ensureBranchRec(q.id, bi).attempts || 0 } : { attempts: 0 };
      const result = original.apply(this, arguments);
      try{
        if(typeof ensureBranchRec === "function"){
          const afterRec = ensureBranchRec(q.id, bi);
          if((afterRec.attempts || 0) > before.attempts){
            recordAiModelsAttempt(q, branch, bi, afterRec.status === "correct", afterRec.attempts || 1);
            renderAiModelsPanel();
          }
        }
      }catch(e){}
      return result;
    };
    handleSaveBranch.__aiModelsWrapped = true;
  }

  function wrapSaveBranchAnswer(){
    if(typeof saveBranchAnswer !== "function" || saveBranchAnswer.__aiModelsWrapped) return;
    const original = saveBranchAnswer;
    saveBranchAnswer = function(q, branch, bi, branchCard, saveBtn){
      const beforeAttempts = (typeof _getSaveAttempt === "function") ? _getSaveAttempt(q.id, bi) : 0;
      const beforeOutcome = (typeof _getOutcome === "function") ? _getOutcome(q.id, bi) : null;
      const result = original.apply(this, arguments);
      try{
        const afterAttempts = (typeof _getSaveAttempt === "function") ? _getSaveAttempt(q.id, bi) : beforeAttempts;
        const afterOutcome = (typeof _getOutcome === "function") ? _getOutcome(q.id, bi) : beforeOutcome;
        if(afterAttempts !== beforeAttempts || afterOutcome !== beforeOutcome){
          recordAiModelsAttempt(q, branch, bi, afterOutcome === "correct", Math.max(1, afterAttempts || beforeAttempts || 1));
          renderAiModelsPanel();
        }
      }catch(e){}
      return result;
    };
    saveBranchAnswer.__aiModelsWrapped = true;
  }

  function wrapRenderAll(){
    if(typeof renderAll !== "function" || renderAll.__aiModelsWrapped) return;
    const original = renderAll;
    renderAll = function(){
      const result = original.apply(this, arguments);
      renderAiModelsPanel();
      return result;
    };
    renderAll.__aiModelsWrapped = true;
  }

  wrapHandleSaveBranch();
  wrapSaveBranchAnswer();
  wrapRenderAll();
  renderAiModelsPanel();

  /* â”€â”€ Scroll-linked topbar shadow â”€â”€ */
  (function(){
    const tb = document.querySelector('.topbar');
    if(!tb) return;
    window.addEventListener('scroll', function(){
      tb.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  })();
})();
/* Codex AI Models Logic End */
/* Codex Universal Adaptive Flow Start */
(function(){
  if(typeof TEMPLATES === "undefined" || !Array.isArray(TEMPLATES) || !TEMPLATES.length || typeof state === "undefined") return;

  const ADAPTIVE_SOURCE = (typeof ADAPTIVE_TEMPLATES_12 !== "undefined" && Array.isArray(ADAPTIVE_TEMPLATES_12) && ADAPTIVE_TEMPLATES_12.length) ? ADAPTIVE_TEMPLATES_12 : TEMPLATES;
  const MASTERY_VERSION_UNIFIED = "stat102_1_2_index_html_universal_mastery_v1";
  const MASTERY_CORE_UNIFIED = ["q1_circle", "q2_tf", "q3_method", "q4_param_stat"];
  const MASTERY_PROFILES_UNIFIED = {"q1_circle": {"supports": ["q2_tf", "q3_method", "q4_param_stat", "q5_nominal_ordinal"]}, "q2_tf": {"supports": ["q3_method", "q4_param_stat", "q5_nominal_ordinal", "q6_interval_ratio"]}, "q3_method": {"supports": ["q4_param_stat", "q5_nominal_ordinal", "q6_interval_ratio", "q7_codes_vs_values"]}, "q4_param_stat": {"supports": ["q5_nominal_ordinal", "q6_interval_ratio", "q7_codes_vs_values", "q8_advanced_tf"]}, "q5_nominal_ordinal": {"supports": ["q6_interval_ratio", "q7_codes_vs_values", "q8_advanced_tf", "q1_circle"]}, "q6_interval_ratio": {"supports": ["q7_codes_vs_values", "q8_advanced_tf", "q1_circle", "q2_tf"]}, "q7_codes_vs_values": {"supports": ["q8_advanced_tf", "q1_circle", "q2_tf", "q3_method"]}, "q8_advanced_tf": {"supports": ["q1_circle", "q2_tf", "q3_method", "q4_param_stat"]}};

  function adaptiveSaveState(){
    try{ if(typeof saveState === "function") saveState(); }catch(e){}
  }

  function adaptiveIds(){
    const seen = new Set();
    return ADAPTIVE_SOURCE.map(t=>t && t.id).filter(id=>{
      if(!id || seen.has(id)) return false;
      seen.add(id);
      return true;
    });
  }

  function adaptiveTemplateById(id){
    return ADAPTIVE_SOURCE.find(t=>t && t.id === id) || TEMPLATES.find(t=>t && t.id === id) || null;
  }

  function adaptiveNormalizeOrder(order){
    const ids = adaptiveIds();
    const seen = new Set();
    return (Array.isArray(order) ? order : []).filter(id=>{
      if(!ids.includes(id) || seen.has(id)) return false;
      seen.add(id);
      return true;
    });
  }

  function adaptiveRng(seed){
    if(typeof seededRand === "function"){
      try{ return seededRand(seed); }catch(e){}
    }
    return Math.random;
  }

  function adaptiveShuffle(arr, seed){
    const r = adaptiveRng(seed);
    const copy = arr.slice();
    if(typeof shuffleInPlace === "function"){
      try{ return shuffleInPlace(copy, r); }catch(e){}
    }
    for(let i=copy.length-1;i>0;i--){
      const j = Math.floor(r() * (i + 1));
      const temp = copy[i];
      copy[i] = copy[j];
      copy[j] = temp;
    }
    return copy;
  }

  function adaptiveCore(ids){
    const core = MASTERY_CORE_UNIFIED.filter(id=>ids.includes(id));
    return core.length ? core : ids.slice(0, Math.min(3, ids.length));
  }

  function adaptiveBuildQuestionById(id){
    const t = adaptiveTemplateById(id);
    if(!t || typeof t.gen !== "function") return null;
    const v = (typeof getVariant === "function") ? getVariant(t.id) : 0;
    const g = t.gen(v) || {};
    const obj = { id:t.id, title:t.title, icon:t.icon, branches:g.branches || [] };
    if(g.sharedGraph != null) obj.sharedGraph = g.sharedGraph;
    return obj;
  }

  function adaptiveEnsureState(){
    const ids = adaptiveIds();
    if(!ids.length) return [];
    const core = adaptiveCore(ids);
    let active = adaptiveNormalizeOrder(state.activeOrder);
    if(state.masteryVersion !== MASTERY_VERSION_UNIFIED || !active.length){
      active = adaptiveShuffle(core, "mastery-core|" + MASTERY_VERSION_UNIFIED + "|" + Date.now() + "|" + Math.random());
      state.masteryVersion = MASTERY_VERSION_UNIFIED;
      state.masterySupportCount = 0;
      state.masterySupportLog = [];
      state.masterySupportSources = {};
    }
    state.masterySupportLog = Array.isArray(state.masterySupportLog) ? state.masterySupportLog : [];
    state.masterySupportSources = state.masterySupportSources && typeof state.masterySupportSources === "object" ? state.masterySupportSources : {};
    state.activeOrder = active;
    state.order = active.slice();
    if(state.currentIndex == null || state.currentIndex < 0) state.currentIndex = 0;
    if(state.currentIndex >= active.length) state.currentIndex = Math.max(0, active.length - 1);
    adaptiveSaveState();
    return active;
  }

  function adaptiveBuildBank(){
    const order = adaptiveEnsureState();
    const bank = order.map(adaptiveBuildQuestionById).filter(Boolean);
    if(bank.length) return bank;
    const ids = adaptiveIds();
    state.activeOrder = ids.slice(0, Math.min(3, ids.length));
    state.order = state.activeOrder.slice();
    adaptiveSaveState();
    return state.activeOrder.map(adaptiveBuildQuestionById).filter(Boolean);
  }

  function adaptiveStatus(q){
    if(!q) return "not_started";
    if(typeof getQuestionStatus === "function"){
      try{ return getQuestionStatus(q); }catch(e){}
    }
    if(typeof isQuestionComplete === "function"){
      try{
        if(!isQuestionComplete(q)) return "not_started";
        if(typeof isQuestionCorrect === "function" && isQuestionCorrect(q)) return "completed_correct";
        return "completed_wrong";
      }catch(e){}
    }
    return "not_started";
  }

  function adaptiveComplete(q){
    if(typeof isQuestionComplete === "function"){ try{ return !!isQuestionComplete(q); }catch(e){} }
    if(typeof isQuestionDone === "function"){ try{ return !!isQuestionDone(q); }catch(e){} }
    const st = adaptiveStatus(q);
    return st === "completed_correct" || st === "completed_wrong";
  }

  function adaptiveCorrect(q){
    if(typeof isQuestionCorrect === "function"){ try{ return !!isQuestionCorrect(q); }catch(e){} }
    return adaptiveStatus(q) === "completed_correct";
  }

  function adaptiveWrong(q){
    if(typeof isQuestionWrong === "function"){ try{ return !!isQuestionWrong(q); }catch(e){} }
    return adaptiveStatus(q) === "completed_wrong";
  }

  function adaptiveChooseSupportId(sourceId){
    const active = adaptiveEnsureState();
    const ids = adaptiveIds();
    const pools = [];
    if(sourceId && MASTERY_PROFILES_UNIFIED[sourceId]) pools.push(MASTERY_PROFILES_UNIFIED[sourceId].supports || []);
    pools.push(MASTERY_CORE_UNIFIED.filter(id=>id !== sourceId));
    pools.push(ids);
    for(const pool of pools){
      for(const id of pool){
        if(ids.includes(id) && !active.includes(id)) return id;
      }
    }
    return null;
  }

  function adaptiveAddSupport(sourceId, reason){
    const active = adaptiveEnsureState();
    const key = sourceId || "general";
    state.masterySupportSources = state.masterySupportSources || {};
    if((state.masterySupportSources[key] || 0) >= 1) return null;
    const nextId = adaptiveChooseSupportId(sourceId);
    if(!nextId) return null;
    /* طھط¨ط¯ظٹظ„ ط§ظ„ط³ط¤ط§ظ„ طھظ„ظ‚ط§ط¦ظٹط§ظ‹ (variant ط¬ط¯ظٹط¯ + ظ…ط³ط­ ظƒط§ظ…ظ„) */
    if(typeof bumpVariant === "function") try{ bumpVariant(nextId); }catch(e){}
    if(typeof clearAnswersForQuestion === "function") try{ clearAnswersForQuestion(nextId); }catch(e){}
    active.push(nextId);
    state.activeOrder = active;
    state.order = active.slice();
    state.masterySupportSources[key] = (state.masterySupportSources[key] || 0) + 1;
    state.masterySupportCount = (state.masterySupportCount || 0) + 1;
    state.masterySupportLog = state.masterySupportLog || [];
    state.masterySupportLog.push({ source:key, support:nextId, reason:reason || "mastery", at:Date.now() });
    adaptiveSaveState();
    return nextId;
  }

  function adaptiveActiveQuestions(){
    const active = new Set(adaptiveEnsureState());
    return (Array.isArray(BANK) ? BANK : []).filter(q=>active.has(q.id));
  }

  function adaptiveEnsureSupportForWeakQuestions(){
    if(!window.__examRunning) return false;
    if(!Array.isArray(BANK) || !BANK.length) BANK = adaptiveBuildBank();
    const activeQuestions = adaptiveActiveQuestions();
    const done = activeQuestions.filter(adaptiveComplete);
    const wrong = done.filter(adaptiveWrong);
    let added = false;
    wrong.forEach(q=>{ if(adaptiveAddSupport(q.id, "wrong")) added = true; });
    if(!added && done.length > 0 && done.length === activeQuestions.length && adaptiveEnsureState().length < adaptiveIds().length){
      const correctCount = done.filter(adaptiveCorrect).length;
      if((correctCount / done.length) < 0.85){
        const anchor = wrong[0] || done.find(q=>!adaptiveCorrect(q)) || done[done.length - 1];
        if(adaptiveAddSupport(anchor && anchor.id, "mastery-threshold")) added = true;
      }
    }
    if(added) BANK = adaptiveBuildBank();
    return added;
  }

  function adaptiveAfterSave(q){
    if(!q || !window.__examRunning) return;
    if(adaptiveWrong(q)){
      const added = adaptiveAddSupport(q.id, "wrong");
      if(added){
        BANK = adaptiveBuildBank();
        try{ if(typeof setProgress === "function") setProgress(); }catch(e){}
        try{ if(typeof renderSidebar === "function") renderSidebar(); }catch(e){}
      }
    }
  }

  function adaptiveWrapSavers(){
    if(typeof handleSaveBranch === "function" && !handleSaveBranch.__codexUniversalAdaptiveWrapped){
      const original = handleSaveBranch;
      handleSaveBranch = function(q, branch, bi){
        const result = original.apply(this, arguments);
        try{ adaptiveAfterSave(q); }catch(e){}
        return result;
      };
      handleSaveBranch.__codexUniversalAdaptiveWrapped = true;
    }
    if(typeof saveBranchAnswer === "function" && !saveBranchAnswer.__codexUniversalAdaptiveWrapped){
      const original = saveBranchAnswer;
      saveBranchAnswer = function(q, branch, bi, branchCard, saveBtn){
        const result = original.apply(this, arguments);
        try{ adaptiveAfterSave(q); }catch(e){}
        return result;
      };
      saveBranchAnswer.__codexUniversalAdaptiveWrapped = true;
    }
  }

  try{ buildBank = adaptiveBuildBank; }catch(e){}
  try{ window.ensureAdaptiveState = adaptiveEnsureState; }catch(e){}
  try{ window.ensureSupportForWeakQuestions = adaptiveEnsureSupportForWeakQuestions; }catch(e){}
  try{ window.maybeQueueAdaptiveSupport = function(q){ if(!q) return null; return adaptiveWrong(q) ? adaptiveAddSupport(q.id, "wrong") : null; }; }catch(e){}

  const originalNext = (typeof next === "function") ? next : null;
  next = function(){
    if(!Array.isArray(BANK) || !BANK.length) BANK = adaptiveBuildBank();
    if(adaptiveEnsureSupportForWeakQuestions()){
      try{ if(typeof renderAll === "function") renderAll(); }catch(e){}
    }
    const start = Math.min((state.currentIndex || 0) + 1, BANK.length);
    for(let i=start;i<BANK.length;i++){
      if(!adaptiveComplete(BANK[i])){ state.currentIndex = i; adaptiveSaveState(); renderAll(); return; }
    }
    for(let i=0;i<BANK.length;i++){
      if(!adaptiveComplete(BANK[i])){ state.currentIndex = i; adaptiveSaveState(); renderAll(); return; }
    }
    if(typeof tryShowResults === "function") return tryShowResults();
    if(originalNext) return originalNext.apply(this, arguments);
  };

  prev = function(){
    if(!Array.isArray(BANK) || !BANK.length) BANK = adaptiveBuildBank();
    for(let i=(state.currentIndex || 0)-1;i>=0;i--){
      if(BANK[i]){ state.currentIndex = i; adaptiveSaveState(); renderAll(); return; }
    }
  };

  tryShowResults = function(){
    try{ if(typeof syncAllInputs === "function") syncAllInputs(); }catch(e){}
    let p = null;
    try{ if(typeof setProgress === "function") p = setProgress(); }catch(e){}
    if(p && !p.doneAll){
      if(!confirm("ظ‡ظ†ط§ظƒ ط£ط³ط¦ظ„ط© ظ„ظ… طھظڈط¬ط¨ ط¹ظ†ظ‡ط§. ظ‡ظ„ طھط±ظٹط¯ ط§ظ„ظ…طھط§ط¨ط¹ط©طں")) return;
    }
    if(typeof showResultsModal === "function") return showResultsModal();
    if(typeof showResults === "function") return showResults();
  };

  adaptiveWrapSavers();
  if(typeof setProgress === "function" && !setProgress.__codexUniversalMasteryWrapped){
    const originalSetProgress = setProgress;
    setProgress = function(){
      const result = originalSetProgress.apply(this, arguments);
      const qCountEl = document.getElementById("qCount");
      if(qCountEl) qCountEl.textContent = "\u2014";
      return result;
    };
    setProgress.__codexUniversalMasteryWrapped = true;
  }
  BANK = adaptiveBuildBank();
  if(state.currentIndex >= BANK.length) state.currentIndex = Math.max(0, BANK.length - 1);
  adaptiveSaveState();
  try{ if(typeof renderAll === "function") renderAll(); }catch(e){}
})();
/* Codex Universal Adaptive Flow End */
</script>


<!-- â•گâ•گâ•گ ظ†ط¸ط§ظ… ط§ظ„ط²ط± ط§ظ„ط¹ط§ط¦ظ… ط§ظ„ط¯ط§ط¦ط±ظٹ â•گâ•گâ•گ -->
<style>
/* â”€â”€ Overlay â”€â”€ */
.fab-overlay{
  position:fixed;inset:0;
  background:rgba(15,23,42,.25);
  z-index:490;
  opacity:0;pointer-events:none;
  transition:opacity .3s ease;
}
.fab-overlay.show{opacity:1;pointer-events:all}

/* â”€â”€ Drawer panels â”€â”€ */
.fab-drawer{
  position:fixed;top:0;left:0;bottom:0;
  width:min(360px,92vw);
  background:#fff;
  border-left:1px solid var(--line);
  box-shadow:-8px 0 40px rgba(15,23,42,.18);
  z-index:500;
  display:flex;flex-direction:column;
  transform:translateX(-100%);
  transition:transform .34s cubic-bezier(.4,0,.2,1);
  border-radius:0 22px 22px 0;
  overflow:hidden;
}
.fab-drawer.show{transform:translateX(0)}
.fab-drawer-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 20px 14px;
  background:linear-gradient(135deg,var(--brand2),var(--brand));
  color:#fff;
  flex:0 0 auto;
}
.fab-drawer-head h2{margin:0;font-size:18px;font-weight:900;display:flex;align-items:center;gap:10px}
.fab-drawer-close{
  width:36px;height:36px;border-radius:12px;
  border:1.5px solid rgba(255,255,255,.35);
  background:rgba(255,255,255,.15);color:#fff;
  font-size:18px;cursor:pointer;display:grid;place-items:center;
  transition:background .2s;
}
.fab-drawer-close:hover{background:rgba(255,255,255,.28)}
.fab-drawer-body{flex:1;overflow-y:auto;padding:16px 18px 24px}
.fab-drawer-footer{
  flex:0 0 auto;
  padding:14px 18px;
  border-top:1px solid var(--line);
  display:flex;gap:10px;
  background:var(--line-soft);
}
.fab-drawer-body .side{display:block !important;padding:0 !important;}
.fab-drawer-body .aiResultsRail{display:block !important;padding:0 !important;}

/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   ط§ظ„ط²ط± ط§ظ„ط¹ط§ط¦ظ… ط§ظ„ط¯ط§ط¦ط±ظٹ ط§ظ„ط±ط¦ظٹط³ظٹ
   â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
.fab-root{
  position:fixed;
  bottom:28px;
  right:20px;
  z-index:495;  /* ظپظˆظ‚ ط§ظ„ظ€ overlay (490) ظˆطھط­طھ ط§ظ„ظ€ drawers (500) */
}

/* ط§ظ„ط²ط± ط§ظ„ظ…ط´ط؛ظ‘ظ„ ط§ظ„ط±ط¦ظٹط³ظٹ */
.fab-trigger{
  width:62px;height:62px;
  border-radius:50%;
  border:none;
  cursor:pointer;
  display:grid;place-items:center;
  background:linear-gradient(135deg,var(--brand2) 0%,var(--brand) 60%,#0ea5e9 100%);
  box-shadow:0 8px 28px rgba(3,105,161,.45), 0 0 0 0 rgba(3,105,161,.3);
  transition:transform .25s ease, box-shadow .25s ease;
  position:relative;
  z-index:2;
  animation:fabMainPulse 3s ease-in-out infinite;
}
.fab-trigger:hover{transform:scale(1.08);box-shadow:0 12px 36px rgba(3,105,161,.55)}
.fab-trigger:active{transform:scale(.94)}
@keyframes fabMainPulse{
  0%,100%{box-shadow:0 8px 28px rgba(3,105,161,.45),0 0 0 0 rgba(3,105,161,.3)}
  50%{box-shadow:0 8px 28px rgba(3,105,161,.45),0 0 0 12px rgba(3,105,161,0)}
}

/* ط£ظٹظ‚ظˆظ†ط© ط§ظ„ط²ط± */
/* ط£ظٹظ‚ظˆظ†ط§طھ ط§ظ„ط²ط± ط§ظ„ظ…ط´ط؛ظ‘ظ„ */
.fab-icon-default, .fab-icon-close{
  position:absolute;
  width:26px;height:26px;
  transition:opacity .3s ease, transform .35s cubic-bezier(.4,0,.2,1);
}
.fab-icon-default{
  opacity:1;
  transform:rotate(0deg) scale(1);
}
.fab-icon-close{
  opacity:0;
  transform:rotate(-90deg) scale(.7);
}
/* ط­ط§ظ„ط© ط§ظ„ظپطھط­ */
.fab-root.open .fab-icon-default{
  opacity:0;
  transform:rotate(90deg) scale(.7);
}
.fab-root.open .fab-icon-close{
  opacity:1;
  transform:rotate(0deg) scale(1);
}
.fab-root.open .fab-trigger{animation:none;box-shadow:0 8px 28px rgba(220,38,38,.5)}
.fab-root.open .fab-trigger{background:linear-gradient(135deg,#b91c1c,#dc2626)}

/* ط­ظ„ظ‚ط© ط§ظ„طھظ‚ط¯ظ… */
.fab-progress-ring{
  position:absolute;inset:-5px;
  border-radius:50%;
  background:conic-gradient(rgba(255,255,255,.75) var(--pct,0%), transparent 0%);
  -webkit-mask:radial-gradient(circle at center, transparent 28px, black 29px);
  mask:radial-gradient(circle at center, transparent 28px, black 29px);
  pointer-events:none;
  z-index:0;
}

/* ط´ط§ط±ط© */
.fab-badge{
  position:absolute;top:-3px;right:-3px;
  background:#dc2626;color:#fff;
  font-size:10px;font-weight:900;
  min-width:18px;height:18px;
  border-radius:999px;
  display:grid;place-items:center;
  padding:0 4px;
  border:2px solid #fff;
  z-index:3;
  transition:transform .2s;
}
.fab-root.open .fab-badge{transform:scale(0)}

/* â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
   ط£ط²ط±ط§ط± ط§ظ„ط¯ط§ط¦ط±ط© ط§ظ„ط£ط±ط¨ط¹ط©
   â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ */
.fab-radial{
  position:absolute;
  /* ظ…ط±ظƒط²ظ‡ط§ ط¹ظ„ظ‰ ظ…ط±ظƒط² ط§ظ„ط²ط± ط§ظ„ط±ط¦ظٹط³ظٹ */
  bottom:0;right:0;
  width:52px;height:52px;
  border-radius:50%;
  border:none;cursor:pointer;
  display:grid;place-items:center;
  box-shadow:0 6px 20px rgba(15,23,42,.28);
  transform:translate(0,0) scale(0);
  opacity:0;
  transition:
    transform .35s cubic-bezier(.34,1.56,.64,1),
    opacity .25s ease;
  z-index:1;
  /* ظ†ظ‚ظ„ ط§ظ„ظ…ط±ظƒط² ظ„ظ…ط±ظƒط² ط§ظ„ط²ط± ط§ظ„ط±ط¦ظٹط³ظٹ */
  margin-bottom:5px;
  margin-right:5px;
}
.fab-radial::after{
  content:"";
  position:absolute;inset:0;
  border-radius:50%;
  background:linear-gradient(135deg,rgba(255,255,255,.3) 0%,transparent 60%);
  pointer-events:none;
}

/* ط­ط§ظ„ط© ط§ظ„ظ…ظپطھظˆط­ â€” طھط­ط±ظٹظƒ ظƒظ„ ط²ط± ط¥ظ„ظ‰ ظ…ظˆط¶ط¹ظ‡ */
/* ط§ظ„ط²ط± 1: ظ…ط¨ط§ط´ط±ط© ظ„ظ„ط£ط¹ظ„ظ‰ (90آ°) */
.fab-root.open .fab-radial.r1{
  transform:translate(5px, -90px) scale(1);
  opacity:1;
  transition-delay:.04s;
}
/* ط§ظ„ط²ط± 2: ط£ط¹ظ„ظ‰ ظٹط³ط§ط± (135آ°) */
.fab-root.open .fab-radial.r2{
  transform:translate(-63px, -64px) scale(1);
  opacity:1;
  transition-delay:.08s;
}
/* ط§ظ„ط²ط± 3: ظٹط³ط§ط± (180آ°) */
.fab-root.open .fab-radial.r3{
  transform:translate(-90px, 5px) scale(1);
  opacity:1;
  transition-delay:.12s;
}
/* ط§ظ„ط²ط± 4: ط£ط¹ظ„ظ‰ ظٹظ…ظٹظ† (45آ°) â€” ظ„ظƒظ† ظ‚ط±ظٹط¨ ظ…ظ† ط§ظ„ط­ط§ظپط© ط§ظ„ظٹظ…ظ†ظ‰طŒ ظ†ظˆط¬ظ‘ظ‡ظ‡ ظ„ظ„ط£ط¹ظ„ظ‰ */
.fab-root.open .fab-radial.r4{
  transform:translate(5px, -160px) scale(1);
  opacity:1;
  transition-delay:.0s;
}

/* ط£ظ„ظˆط§ظ† ط§ظ„ط£ط²ط±ط§ط± */
.fab-radial.r1{background:linear-gradient(135deg,#0369a1,#0ea5e9)} /* ط£ط³ط¦ظ„ط© - ط£ط²ط±ظ‚ */
.fab-radial.r2{background:linear-gradient(135deg,#7c3aed,#a78bfa)} /* AI - ط¨ظ†ظپط³ط¬ظٹ */
.fab-radial.r3{background:linear-gradient(135deg,#059669,#34d399)} /* ظ†طھط§ط¦ط¬ - ط£ط®ط¶ط± */
.fab-radial.r4{background:linear-gradient(135deg,#b45309,#f59e0b)} /* ط¥ط¹ط§ط¯ط© - ط°ظ‡ط¨ظٹ */

/* طھط³ظ…ظٹط© tooltip */
.fab-radial-label{
  position:absolute;
  right:calc(100% + 10px);
  top:50%;transform:translateY(-50%);
  white-space:nowrap;
  font-family:var(--font);font-size:12px;font-weight:800;
  background:rgba(15,23,42,.9);color:#fff;
  padding:5px 10px;border-radius:8px;
  pointer-events:none;
  opacity:0;
  transform:translateY(-50%) translateX(8px);
  transition:opacity .15s, transform .15s;
  backdrop-filter:blur(4px);
}
.fab-radial-label::after{
  content:"";position:absolute;
  left:100%;top:50%;transform:translateY(-50%);
  border:5px solid transparent;
  border-left-color:rgba(15,23,42,.9);
}
.fab-root.open .fab-radial:hover .fab-radial-label{
  opacity:1;
  transform:translateY(-50%) translateX(0);
}

/* ظ„ظ€ r4 (ط£ط¹ظ„ظ‰ ظ…ط¨ط§ط´ط±ط© ط¹ظ…ظˆط¯ظٹط§ظ‹) â€” طھط³ظ…ظٹط© ظپظٹ ط§ظ„ظٹظ…ظٹظ† */
.fab-radial.r4 .fab-radial-label{
  right:calc(100% + 10px);top:50%;
}
/* ظ„ظ€ r1 (ط£ط¹ظ„ظ‰) â€” طھط³ظ…ظٹط© ظپظٹ ط§ظ„ظٹظ…ظٹظ† ط£ظٹط¶ط§ظ‹ */
.fab-radial.r1 .fab-radial-label{
  right:calc(100% + 10px);
}

/* ط£ظٹظ‚ظˆظ†ط© SVG ط¯ط§ط®ظ„ ط§ظ„ط£ط²ط±ط§ط± */
.fab-radial svg{
  width:24px;height:24px;
  transition:transform .2s;
}
.fab-radial:hover svg{transform:scale(1.15)}
.fab-radial:active{transform-origin:center center;filter:brightness(.9)}
</style>

<!-- Overlay ظ…ط´طھط±ظƒ -->
<div class="fab-overlay" id="fabOverlay" onclick="closeFabSystem()"></div>

<!-- Drawer: ط¨ظ†ظƒ ط§ظ„ط£ط³ط¦ظ„ط© -->
<div class="fab-drawer" id="drawerQuestions">
  <div class="fab-drawer-head">
    <h2>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="5" rx="2.5" fill="rgba(255,255,255,.25)" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/><rect x="2" y="10" width="20" height="5" rx="2.5" fill="rgba(255,255,255,.25)" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/><rect x="2" y="17" width="20" height="4" rx="2" fill="rgba(255,255,255,.25)" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/></svg>
      ط¨ظ†ظƒ ط§ظ„ط£ط³ط¦ظ„ط©
    </h2>
    <button class="fab-drawer-close" onclick="closeFabSystem()">âœ•</button>
  </div>
  <div class="fab-drawer-body">
    <div id="drawerQuestionsInner"></div>
  </div>
  <div class="fab-drawer-footer">
    <button class="btn" id="showResultsBtnDrawer" style="flex:1">ًں“ٹ ط§ظ„ظ†طھظٹط¬ط©</button>
    <button class="btn primary" id="nextBtnDrawer" style="flex:1">ط§ظ„طھط§ظ„ظٹ â†گ</button>
  </div>
</div>

<!-- Drawer: ط§ظ„طھط­ظ„ظٹظ„ ط§ظ„ط°ظƒظٹ -->
<div class="fab-drawer" id="drawerAI">
  <div class="fab-drawer-head" style="background:linear-gradient(135deg,#4c1d95,#7c3aed)">
    <h2>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="rgba(255,255,255,.7)" stroke-width="1.5"/><path d="M8 12c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4" stroke="rgba(255,255,255,.7)" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="2" fill="rgba(255,255,255,.8)"/></svg>
      ط§ظ„طھط­ظ„ظٹظ„ ط§ظ„ط°ظƒظٹ | AI Analysis
    </h2>
    <button class="fab-drawer-close" onclick="closeFabSystem()">âœ•</button>
  </div>
  <div class="fab-drawer-body" id="drawerAIBody">
    <div id="drawerAIInner"></div>
  </div>
</div>

<!-- â•گâ•گâ•گ ط§ظ„ط²ط± ط§ظ„ط¹ط§ط¦ظ… ط§ظ„ط±ط¦ظٹط³ظٹ â•گâ•گâ•گ -->
<div class="fab-root" id="fabRoot">
  <!-- ط­ظ„ظ‚ط© ط§ظ„طھظ‚ط¯ظ… -->
  <div class="fab-progress-ring" id="fabProgressRing"></div>
  <!-- ط´ط§ط±ط© ط§ظ„ط£ط³ط¦ظ„ط© ط§ظ„ظ…طھط¨ظ‚ظٹط© -->
  <span class="fab-badge" id="fabQBadge" style="display:none">0</span>

  <!-- ط§ظ„ط²ط± 4: ط£ط¹ظ„ظ‰ (ط¥ط¹ط§ط¯ط© طھط¹ظٹظٹظ†) -->
  <button class="fab-radial r4" onclick="handleFabAction('reset')" title="ط¥ط¹ط§ط¯ط© طھط¹ظٹظٹظ†">
    <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
      <path d="M3 3v5h5"/>
    </svg>
    <span class="fab-radial-label">ط¥ط¹ط§ط¯ط© ط§ظ„طھط¹ظٹظٹظ†</span>
  </button>

  <!-- ط§ظ„ط²ط± 1: ط£ط¹ظ„ظ‰ ظٹظ…ظٹظ† (ط£ط³ط¦ظ„ط©) -->
  <button class="fab-radial r1" onclick="handleFabAction('questions')" title="ط¨ظ†ظƒ ط§ظ„ط£ط³ط¦ظ„ط©">
    <div class="fab-progress-ring" id="fabProgressRing2" style="inset:-3px;border-radius:50%;position:absolute;pointer-events:none;z-index:0;"></div>
    <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round" style="position:relative;z-index:1">
      <rect x="3" y="4" width="18" height="4" rx="2"/>
      <rect x="3" y="10" width="18" height="4" rx="2"/>
      <rect x="3" y="16" width="11" height="4" rx="2"/>
    </svg>
    <span class="fab-radial-label">ط¨ظ†ظƒ ط§ظ„ط£ط³ط¦ظ„ط©</span>
  </button>

  <!-- ط§ظ„ط²ط± 2: ط£ط¹ظ„ظ‰ ظٹط³ط§ط± (AI) -->
  <button class="fab-radial r2" onclick="handleFabAction('ai')" title="ط§ظ„طھط­ظ„ظٹظ„ ط§ظ„ط°ظƒظٹ">
    <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round">
      <circle cx="12" cy="12" r="3"/>
      <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/>
    </svg>
    <span class="fab-radial-label">ط§ظ„طھط­ظ„ظٹظ„ ط§ظ„ط°ظƒظٹ</span>
  </button>

  <!-- ط§ظ„ط²ط± 3: ظٹط³ط§ط± (ط§ظ„ظ†طھظٹط¬ط©) -->
  <button class="fab-radial r3" onclick="handleFabAction('results')" title="ط§ظ„ظ†طھظٹط¬ط©">
    <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.95)" stroke-width="2" stroke-linecap="round">
      <path d="M9 11l3 3L22 4"/>
      <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
    </svg>
    <span class="fab-radial-label">ط§ظ„ظ†طھظٹط¬ط©</span>
  </button>

  <!-- ط§ظ„ط²ط± ط§ظ„ط±ط¦ظٹط³ظٹ ط§ظ„ظ…ط´ط؛ظ‘ظ„ -->
  <button class="fab-trigger" id="fabTrigger" onclick="toggleFabMenu()" aria-label="ط§ظ„ظ‚ط§ط¦ظ…ط©">
    <!-- ط£ظٹظ‚ظˆظ†ط© "ط°ظƒظٹ" - طھط¸ظ‡ط± ط¹ظ†ط¯ ط§ظ„ط¥ط؛ظ„ط§ظ‚ -->
    <svg class="fab-icon-default" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- ظ†ط¬ظ…ط© ط°ظƒط§ط، ط§طµط·ظ†ط§ط¹ظٹ -->
      <path d="M14 4 L15.5 10.5 L22 12 L15.5 13.5 L14 20 L12.5 13.5 L6 12 L12.5 10.5 Z" fill="white" fill-opacity="0.95"/>
      <circle cx="22" cy="6" r="1.8" fill="white" fill-opacity="0.7"/>
      <circle cx="6" cy="22" r="1.4" fill="white" fill-opacity="0.6"/>
      <circle cx="22" cy="22" r="1" fill="white" fill-opacity="0.5"/>
    </svg>
    <!-- X ط¹ظ†ط¯ ط§ظ„ظپطھط­ -->
    <svg class="fab-icon-close" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</div>

<script>
/* â•گâ•گâ•گ ظ…ظ†ط·ظ‚ ط§ظ„ط²ط± ط§ظ„ط¹ط§ط¦ظ… ط§ظ„ط¯ط§ط¦ط±ظٹ â•گâ•گâ•گ */
(function(){
  var fabOpen = false;

  window.toggleFabMenu = function(){
    fabOpen = !fabOpen;
    var root = document.getElementById("fabRoot");
    var overlay = document.getElementById("fabOverlay");
    if(fabOpen){
      root.classList.add("open");
      // ظ„ط§ ظ†ظڈط¸ظ‡ط± ط§ظ„ظ€ overlay ط¹ظ†ط¯ ط§ظ„ط£ط²ط±ط§ط± ط§ظ„ط¯ط§ط¦ط±ظٹط© â€” ظپظ‚ط· ط®ظ„ظپظٹط© ط´ظپظٹظپط© ط¬ط¯ط§ظ‹
      overlay.style.background = "rgba(15,23,42,.08)";
      overlay.classList.add("show");
    } else {
      root.classList.remove("open");
      overlay.style.background = "";
      overlay.classList.remove("show");
      document.body.style.overflow = "";
    }
  };

  window.closeFabSystem = function(){
    fabOpen = false;
    document.getElementById("fabRoot").classList.remove("open");
    document.getElementById("fabOverlay").classList.remove("show");
    document.body.style.overflow = "";
    // ط£ط؛ظ„ظ‚ ط£ظٹ ط¯ط±ط¬ ظ…ظپطھظˆط­
    document.querySelectorAll(".fab-drawer").forEach(function(d){ d.classList.remove("show"); });
  };

  window.handleFabAction = function(action){
    // ط£ط؛ظ„ظ‚ ط§ظ„ظ‚ط§ط¦ظ…ط© ط£ظˆظ„ط§ظ‹
    document.getElementById("fabRoot").classList.remove("open");
    fabOpen = false;

    if(action === "questions"){
      syncQuestionsDrawer();
      openDrawer("drawerQuestions");
    } else if(action === "ai"){
      syncAIDrawer();
      openDrawer("drawerAI");
    } else if(action === "results"){
      closeFabSystem();
      if(typeof tryShowResults === "function") tryShowResults();
    } else if(action === "reset"){
      closeFabSystem();
      if(confirm("ظ‡ظ„ طھط±ظٹط¯ ط¥ط¹ط§ط¯ط© طھط¹ظٹظٹظ† ط§ظ„ط§ط®طھط¨ط§ط±طں ط³ظٹطھظ… ط­ط°ظپ ط¬ظ…ظٹط¹ ط§ظ„ط¥ط¬ط§ط¨ط§طھ.")) {
        if(typeof resetAll === "function") resetAll();
      }
    }
  };

  function openDrawer(id){
    var overlay = document.getElementById("fabOverlay");
    var drawer = document.getElementById(id);
    overlay.classList.add("show");
    drawer.classList.add("show");
    document.body.style.overflow = "hidden";
  }

  function syncQuestionsDrawer(){
    var inner = document.getElementById("drawerQuestionsInner");
    if(!inner) return;
    var progressText = document.getElementById("progressText");
    var progressBar = document.getElementById("progressBar");
    inner.innerHTML = "";
    if(progressText && progressBar){
      var prog = document.createElement("div");
      prog.style.cssText = "display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:14px;";
      var ptClone = document.createElement("div");
      ptClone.style.cssText = "font-weight:900;color:#0f2a3b;font-size:15px";
      ptClone.textContent = progressText.textContent;
      var pbWrap = document.createElement("div");
      pbWrap.style.flex = "1";
      pbWrap.className = "progress";
      var pbFill = document.createElement("div");
      pbFill.style.width = progressBar.style.width || "0%";
      pbWrap.appendChild(pbFill);
      prog.appendChild(ptClone);
      prog.appendChild(pbWrap);
      inner.appendChild(prog);
    }
    var bank = (typeof BANK !== "undefined" && Array.isArray(BANK)) ? BANK : [];
    if(!bank.length) return;
    var list = document.createElement("div");
    list.style.cssText = "display:flex;flex-direction:column;gap:10px;margin-top:6px;";
    bank.forEach(function(q, idx){
      var done = false, correct = false;
      try{
        if(typeof isQuestionDone === "function") done = isQuestionDone(q);
        if(done && typeof isQuestionCorrect === "function") correct = isQuestionCorrect(q);
      }catch(e){}
      var isCurrent = (typeof state !== "undefined" && state.currentIndex === idx);
      var item = document.createElement("div");
      item.style.cssText = "display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:14px;cursor:pointer;transition:all .2s;border:2px solid " + (isCurrent ? "#0369a1" : "#e2e8f0") + ";background:" + (isCurrent ? "#e0f2fe" : "#fff") + ";";
      item.onmouseenter = function(){ if(!isCurrent) this.style.borderColor="#0369a1"; this.style.transform="translateX(-2px)"; };
      item.onmouseleave = function(){ if(!isCurrent) this.style.borderColor="#e2e8f0"; this.style.transform="none"; };
      var dot = document.createElement("div");
      dot.style.cssText = "width:10px;height:10px;border-radius:50%;flex-shrink:0;background:" + (done ? (correct ? "#059669" : "#dc2626") : "#94a3b8") + ";";
      if(done) dot.style.boxShadow = "0 0 0 3px " + (correct ? "rgba(5,150,105,.2)" : "rgba(220,38,38,.15)");
      var title = document.createElement("div");
      title.style.cssText = "font-weight:800;font-size:13px;color:#0f172a;line-height:1.4;min-width:0;";
      title.textContent = q.title || "";
      item.appendChild(dot);
      item.appendChild(title);
      item.onclick = (function(i){
        return function(){
          if(typeof state !== "undefined"){ state.currentIndex = i; }
          try{ if(typeof saveState === "function") saveState(); }catch(e){}
          try{ if(typeof renderAll === "function") renderAll(); }catch(e){}
          closeFabSystem();
        };
      })(idx);
      list.appendChild(item);
    });
    inner.appendChild(list);
  }

  function syncAIDrawer(){
    var inner = document.getElementById("drawerAIInner");
    if(!inner) return;
    var rail = document.querySelector(".aiResultsRail");
    if(!rail) return;
    inner.innerHTML = rail.innerHTML;
  }

  /* ط£ط²ط±ط§ط± ط§ظ„ط¯ط±ط¬ ط§ظ„ط³ظپظ„ظٹط© */
  var nextDrawer = document.getElementById("nextBtnDrawer");
  var resultsDrawer = document.getElementById("showResultsBtnDrawer");
  if(nextDrawer) nextDrawer.onclick = function(){ closeFabSystem(); if(typeof next==="function") next(); };
  if(resultsDrawer) resultsDrawer.onclick = function(){ closeFabSystem(); if(typeof tryShowResults==="function") tryShowResults(); };

  /* ظ…ط²ط§ظ…ظ†ط© ط§ظ„طھظ‚ط¯ظ… */
  function updateFabProgress(){
    var progressBar = document.getElementById("progressBar");
    var ring = document.getElementById("fabProgressRing");
    var ring2 = document.getElementById("fabProgressRing2");
    var badge = document.getElementById("fabQBadge");
    var pct = "0%";
    if(progressBar){ pct = progressBar.style.width || "0%"; }
    if(ring){ ring.style.background = "conic-gradient(rgba(255,255,255,.75) "+pct+", transparent 0%)"; }
    if(ring2){ ring2.style.background = "conic-gradient(rgba(255,255,255,.75) "+pct+", transparent 0%)"; ring2.style["-webkit-mask"] = "radial-gradient(circle at center, transparent 22px, black 23px)"; ring2.style.mask = "radial-gradient(circle at center, transparent 22px, black 23px)"; }
    if(badge){
      var allItems = document.querySelectorAll("#qList .qItem").length;
      var doneItems = document.querySelectorAll("#qList .qItem .dot.done, #qList .qItem .dot.bad").length;
      var remaining = allItems - doneItems;
      if(remaining > 0){ badge.textContent = remaining; badge.style.display = "grid"; }
      else { badge.style.display = "none"; }
    }
  }

  var origRenderAll = window.renderAll;
  if(typeof origRenderAll === "function"){
    window.renderAll = function(){
      var r = origRenderAll.apply(this, arguments);
      setTimeout(updateFabProgress, 100);
      return r;
    };
  }
  var sideEl = document.querySelector(".side");
  if(sideEl){ new MutationObserver(function(){ updateFabProgress(); }).observe(sideEl, {childList:true,subtree:true,attributes:true}); }

  setTimeout(updateFabProgress, 800);

  /* ط¥ط؛ظ„ط§ظ‚ ط¨ظ€ Escape */
  document.addEventListener("keydown", function(e){ if(e.key==="Escape") closeFabSystem(); });

})();
</script>


<script>
(function(){
  if(!window.AdaptiveLearning){
    var candidates = ["assets/js/adaptive_learning.js","../assets/js/adaptive_learning.js","../../assets/js/adaptive_learning.js"];
    (function load(i){
      if(i>=candidates.length) return;
      var s=document.createElement("script");
      s.src=candidates[i];
      s.onload=function(){ bootstrap(); };
      s.onerror=function(){ load(i+1); };
      document.head.appendChild(s);
    })(0);
  }else{ bootstrap(); }

  function bootstrap(){
    if(!window.AdaptiveLearning) return;
    var aiState = { helpUsage:{}, startedAt:{} };
    function key(qid, bi){ return String(qid)+"::"+String(bi); }
    function touchStart(qid, bi){ var k=key(qid,bi); if(!aiState.startedAt[k]) aiState.startedAt[k]=Date.now(); }
    function spent(qid, bi){ var k=key(qid,bi); var st=aiState.startedAt[k]||Date.now(); var sec=Math.max(1, Math.round((Date.now()-st)/1000)); aiState.startedAt[k]=Date.now(); return sec; }
    function runInference(payload, branchCard){
      var bkt = window.AdaptiveLearning.updateBKT(payload.skill_id, payload.is_correct);
      var pred = window.AdaptiveLearning.predictMastery({
        difficulty: payload.difficulty,
        attempts_count: payload.attempts_count,
        used_help: payload.used_help,
        time_spent_sec: payload.time_spent_sec,
        showed_solution: payload.showed_solution,
        bkt_mastery: bkt.mastery
      });
      if(!branchCard) return;
      var panel = branchCard.querySelector(".aiInferencePanel");
      if(!panel){
        panel = document.createElement("div");
        panel.className = "aiInferencePanel";
        panel.style.cssText = "margin-top:10px;padding:10px 12px;border:1px solid #e2e8f0;border-radius:12px;background:#f8fafc;color:#0f172a;font-weight:800";
        branchCard.appendChild(panel);
      }
      panel.innerHTML = "<div style='font-weight:900;margin-bottom:4px'>تحليل تعلم داخلي</div>" +
        "<div style='font-size:13px;color:#334155'>mastery probability: " + Math.round((pred.probability_mastered||0)*100) + "%</div>" +
        "<div style='font-size:13px;color:#334155'>current skill mastery: " + Math.round((bkt.mastery||0)*100) + "%</div>" +
        "<div style='font-size:13px;color:#334155'>recommended support: " + pred.recommended_support + "</div>";
    }

    var origRenderMain = window.renderMain;
    if(typeof origRenderMain === "function"){
      window.renderMain = function(){
        var out = origRenderMain.apply(this, arguments);
        try{
          if(Array.isArray(window.BANK)){
            window.BANK.forEach(function(q){ (q.branches||[]).forEach(function(_b,bi){ touchStart(q.id, bi); }); });
          }
        }catch(_e){}
        return out;
      };
    }

    var origShowHelp = window.showHelp;
    if(typeof origShowHelp === "function"){
      window.showHelp = function(q, b){
        try{ var bi=(q&&q.branches)?q.branches.indexOf(b):-1; if(q&&bi>=0) aiState.helpUsage[key(q.id,bi)] = true; }catch(_e){}
        return origShowHelp.apply(this, arguments);
      };
    }

    var origSaveBranchAnswer = window.saveBranchAnswer;
    if(typeof origSaveBranchAnswer === "function"){
      window.saveBranchAnswer = function(q, b, bi, branchCard, saveBtn){
        var qid = q && q.id ? q.id : "unknown_question";
        var attemptBefore = 0;
        var wasLocked = false;
        try{
          wasLocked = (typeof window._isBranchLocked === "function") ? !!window._isBranchLocked(qid, bi) : false;
          attemptBefore = (typeof window._getSaveAttempt === "function") ? Number(window._getSaveAttempt(qid, bi) || 0) : 0;
        }catch(_e){}

        var out = origSaveBranchAnswer.apply(this, arguments);

        try{
          if(wasLocked) return out;
          var outcome = (typeof window._getOutcome === "function") ? window._getOutcome(qid, bi) : null;
          var attemptsNow = (typeof window._getSaveAttempt === "function") ? Number(window._getSaveAttempt(qid, bi) || 0) : attemptBefore;
          var attemptsCount = Math.max(1, attemptsNow || (attemptBefore + 1));
          var usedHelp = !!aiState.helpUsage[key(qid, bi)];
          var showedSolution = outcome === "wrong";
          var isCorrect = outcome === "correct";
          if(!isCorrect && !showedSolution && attemptsNow === attemptBefore) return out;

          var payload = {
            question_id: qid,
            skill_id: qid,
            topic_id: qid,
            difficulty: (b && (b.difficulty || b.level || b.name)) || "medium",
            is_correct: isCorrect,
            attempts_count: attemptsCount,
            used_help: usedHelp,
            time_spent_sec: spent(qid, bi),
            showed_solution: showedSolution,
            timestamp: new Date().toISOString()
          };
          window.AdaptiveLearning.collectStudentEvent(payload);
          runInference(payload, branchCard);
        }catch(_e){}
        return out;
      };
    }

    window.exportTrainingData = function(){ return window.AdaptiveLearning.exportTrainingData(); };

    if(!window.__autoExportHooked){
      window.__autoExportHooked = true;
      var _tr = window.tryShowResults;
      if(typeof _tr === "function"){
        window.tryShowResults = function(){
          var r = _tr.apply(this, arguments);
          try{ setTimeout(function(){ window.AdaptiveLearning.exportTrainingData(); }, 800); }catch(_e){}
          return r;
        };
      }
    }

    var modelCandidates = [
      {bktPath:"models/bkt_model.json", lrPath:"models/lr_model.json"},
      {bktPath:"../models/bkt_model.json", lrPath:"../models/lr_model.json"},
      {bktPath:"../../models/bkt_model.json", lrPath:"../../models/lr_model.json"}
    ];
    (function tryModels(i){
      if(i>=modelCandidates.length) return;
      window.AdaptiveLearning.loadModelWeights(modelCandidates[i]).then(function(){}, function(){ tryModels(i+1); });
    })(0);
  }
})();
</script>
<style>
@media (max-width: 720px){
  .topbar .row{padding:10px 54px !important; gap:8px !important; min-height:48px !important;}
  .logoWrap{padding:6px 8px !important; border-radius:10px !important; left:8px !important;}
  .logoWrap img{height:34px !important;}
  .topbar .row .brandblock{max-width:62% !important;}
  .qtitleRow{gap:8px !important;}
  .qmeta{display:flex !important; flex-wrap:nowrap !important; gap:6px !important; width:100% !important; overflow-x:auto !important; -webkit-overflow-scrolling:touch;}
  .qmeta .btn{flex:1 1 auto !important; min-width:78px !important; padding:7px 9px !important; font-size:12px !important; white-space:nowrap !important;}
}
@media (max-width: 560px){
  .topbar .row{padding:8px 48px !important;}
  .logoWrap{padding:5px 7px !important; left:6px !important;}
  .logoWrap img{height:30px !important;}
  .topbar .row .brandblock{max-width:58% !important;}
  .qmeta .btn{min-width:70px !important; font-size:11.5px !important; padding:6px 8px !important;}
}
</style>
</body>
</html>








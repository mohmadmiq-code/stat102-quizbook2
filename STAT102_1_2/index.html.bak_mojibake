        </div>
        <div class="ai-help-section">
          <div class="ai-help-section-head">
            <span class="ai-help-chip-icon">?</span>
            <span>?? ??????? ?? ???????</span>
          </div>
          <div class="ai-help-body">${formulaHtml}</div>
        </div>
      </div>
    </div>
  `);
}

function openCorrectAnswer(q, branch, bi){
  const steps = (branch.solutionSteps && branch.solutionSteps.length)
    ? `<div style="font-weight:900;margin:10px 0 6px">????? ????</div>
       <ol style="margin:0;padding-right:18px">${branch.solutionSteps.map(s=>`<li style="margin:8px 0">${escapeHtml(latexFix(s))}</li>`).join("")}</ol>`
    : "";

  // List correct values for parts
  const correctList = [];
  (branch.parts||[]).forEach(p=>{
    const val = (p.type==="mcq") ? branch.answers[p.key] : formatNumber(branch.answers[p.key]);
    correctList.push(`<li><b>${escapeHtml(p.label)}:</b> ${escapeHtml(String(val))}</li>`);
  });
  if(branch.customUI==="freqTable" && branch.table && branch.table.rows){
    branch.table.rows.forEach(r=>{
      (r.inputs||[]).forEach(k=>{
        correctList.push(`<li><b>????</b>: ${escapeHtml(String(formatNumber(branch.answers[k])))}</li>`);
      });
    });
  }
  const correctHtml = correctList.length
    ? `<div style="font-weight:900;margin:12px 0 6px">??????? ???????</div>
       <ul style="margin:0;padding-right:18px">${correctList.join("")}</ul>`
    : "";

  openModal("??????? ???????", `
    <div style="font-weight:900;margin-bottom:6px">${escapeHtml(q.title)} ï؟½ (${escapeHtml(branch.level)})</div>
    ${steps}
    ${correctHtml}
    <div style="margin-top:14px;color:#5b6b7a;font-weight:900">?? ????? ??????? ???????. ?????? ??? ????? ????? ????? ???? ?????.</div>
    <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap"><button class="btn primary" id="regenAfterShowAnswerBtn">????? ???? ????</button><button class="btn small" onclick="closeModal()">??????</button></div>
  `);
  const regenBtn = document.getElementById("regenAfterShowAnswerBtn");
  if(regenBtn) regenBtn.onclick = ()=>{ closeModal(); swapQuestion(q.id); };
}

function promptOpenCorrectAnswer(q, branch, bi){
  openModal("????? ?????????", `
    <div style="font-weight:900;margin-bottom:10px">????? ??????? ??? ??????.</div>
    <div style="color:var(--muted);font-weight:700;margin-bottom:14px">????? ???? ??? ???? ?????? ?????? ??? ???? ??????.</div>
    <button class="btn primary" id="showAnswerAfterAttemptsBtn">????? ???????</button>
  `);
  const btn = document.getElementById("showAnswerAfterAttemptsBtn");
  if(btn) btn.onclick = ()=>openCorrectAnswer(q, branch, bi);
}

function markDirty(qid){ state.dirty = state.dirty || {}; state.dirty[qid]=true; saveState(); renderSidebar(); }

/* ===== ??? ??????? (?????? ?????? ????) ===== */
function handleSaveBranch(q, branch, bi){
  const rec = ensureBranchRec(q.id, bi);

  // ??? ??? ????/???? ??? ???
  if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) return;

  const {saved, okFilled} = readBranchInputs(q.id, bi, branch);
  if(!okFilled){
    openModal("?????", `<div style="font-weight:900">???? ???? ??????? ???????? ?? ???? (??? ???????).</div>`);
    return;
  }

  // ??? ???????? ??????
  rec.attempts = (rec.attempts || 0) + 1;
  rec.saved = saved;
  delete state.dirty[q.id];
  saveState();

  const grade = gradeBranch(q, branch, bi, rec.saved);
  if(grade.okAll){
    rec.status = "correct";
    saveState();
  applyFieldFeedback(q.id, bi, grade);
    disableBranchInputs(q.id, bi);
    setProgress(); renderSidebar();
    return;
  }

  // ???
  if(rec.attempts === 1){
    rec.status = "wrong1";
    saveState();
  applyFieldFeedback(q.id, bi, grade);
    setProgress(); renderSidebar();
    // ???? ???????? ???????? (???? ????? ????)
    openHelp(q, branch);
    return;
  }

  // ???????? ???????: ????? ??????? ??????? ?????? ???????
  rec.status = "locked";
  saveState();
  applyFieldFeedback(q.id, bi, grade);
  disableBranchInputs(q.id, bi);
  setProgress(); renderSidebar();
  promptOpenCorrectAnswer(q, branch, bi);
}

/* ===== ??? ?????? ???????? ===== */
function renderMain(){
  BANK = buildBank();
  const i = state.currentIndex;
  const q = BANK[i];
  const wrap = document.getElementById("mainContent");
  wrap.innerHTML = "";

  const p = setProgress();

  const titleRow = el("div",{class:"qtitleRow"},[
    el("div",{class:"qtitle"},[
      el("div",{class:"qnum"},[String(i+1)]),
      el("div",{},[q.title])
    ]),
    el("div",{class:"qmeta"},[
      el("button",{class:"btn small", disabled: !window.__examRunning, onclick:()=>swapQuestion(q.id)},["????? ??????"]),
      el("button",{class:"btn small", disabled: !p.doneAll || !window.__examRunning, onclick:()=>tryShowResults()},["????? ???????"]),
      el("button",{class:"btn small", disabled: !window.__examRunning, onclick:()=>prev()},["??????"]),
      el("button",{class:"btn primary small", disabled: !window.__examRunning, onclick:()=>next()},["??????"])
    ])
  ]);

  const branches = el("div",{class:"branches"},[]);
  q.branches.forEach((branch, bi)=>{
    const tagClass=(branch.level==="???")?"easy":(branch.level==="?????"?"med":"hard");
    const rec = ensureBranchRec(q.id, bi);

    const branchCard = el("div",{class:"branch"},[]);
    const statusTag = (rec.status==="correct" || rec.status==="locked" || !window.__examRunning)
      ? el("span",{class:"btag", style:`border-color:${rec.status==="correct"?"#0b7a43":"#b42318"};background:${rec.status==="correct"?"#eafff4":"#ffecec"};color:${rec.status==="correct"?"#0b7a43":"#b42318"}`},
        [rec.status==="correct" ? "????" : "???"])
      : null;

    const head = el("div",{class:"branchHead"},[
      el("span",{class:`btag ${tagClass}`},[branch.level]),
      statusTag
    ]);
const body = el("div",{class:"branchBody"},[]);
    body.innerHTML = latexFix(branch.prompt).replace(/\n/g,"<br/>");
    typesetMath(body);

    if(branch.customUI==="stemleaf"){ body.appendChild(renderStemLeaf(branch)); }
    if(branch.customUI==="freqTable"){ body.appendChild(renderFreqTable(q, branch, bi)); }
    if(branch.customUI==="charts"){
      const ch = renderChartsInteractive(branch);
      body.appendChild(ch);
    }

    const parts = el("div",{class:"parts"},[]);
    (branch.parts||[]).forEach(p=>{
      const row = el("div",{class:"part"},[]);
      if(p.type==="mcq") row.classList.add("mcqPart");
      const label = el("div",{class:"label"},[p.label]);
      const inputWrap = el("div",{class:"inputWrap"},[]);
      const savedVal = (rec.saved && rec.saved[p.key]!=null) ? rec.saved[p.key] : "";

      if(p.type==="mcq"){
        const group = el("div",{class:"mcqGroup"},[]);
        (p.options||[]).forEach((op,idx)=>{
          const id = `${q.id}_${bi}_${p.key}_${idx}`;
          const radio = el("input",{type:"radio", id, name:`${q.id}_${bi}_${p.key}`, value:op},[]);
          radio.setAttribute("data-qid", q.id);
          radio.setAttribute("data-bi", String(bi));
          radio.setAttribute("data-key", p.key);
          if(String(savedVal)===String(op)) radio.checked = true;
          radio.onchange = ()=>{ markDirty(q.id); };
          if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) radio.disabled = true;

          const lab = el("label",{class:"choice", for:id},[
            radio,
            el("span",{},[op])
          ]);
          group.appendChild(lab);
        });
        inputWrap.appendChild(group);
      }else if(p.type==="text"){
        const ta = el("textarea",{placeholder:p.placeholder||""},[]);
        ta.setAttribute("data-qid", q.id);
        ta.setAttribute("data-bi", String(bi));
        ta.setAttribute("data-key", p.key);
        ta.value = savedVal;
        ta.oninput = ()=>{ ta.classList.remove("badField","goodField"); markDirty(q.id); };
        if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) ta.disabled = true;
        inputWrap.appendChild(ta);
      }else{
        const inp = el("input",{type:"text", inputmode:"decimal", placeholder:p.placeholder||""},[]);
        inp.setAttribute("data-qid", q.id);
        inp.setAttribute("data-bi", String(bi));
        inp.setAttribute("data-key", p.key);
        inp.value = savedVal;
        inp.oninput = ()=>{ inp.classList.remove("badField","goodField"); markDirty(q.id); };
        if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning) inp.disabled = true;
        inputWrap.appendChild(inp);
      }

      row.appendChild(label);
      row.appendChild(inputWrap);
      parts.appendChild(row);
    });

    const btns = el("div",{class:"branchBtns"},[
      el("button",{class:"btn small primary", "data-save-btn":`${q.id}::${bi}`, disabled: !window.__examRunning, onclick:()=>handleSaveBranch(q, branch, bi)},["??? ???????"]),
      el("button",{class:"btn small ai-help-btn", disabled: !window.__examRunning, onclick:()=>openHelp(q, branch), title:"????? ???? ???????"},[
        el("span",{class:"ai-help-glyph","aria-hidden":"true"},["?"]),
        "?????? ????"
      ])
    ]);
    if(rec.status==="correct" || rec.status==="locked" || !window.__examRunning){
      const sb = btns.querySelector(`[data-save-btn="${q.id}::${bi}"]`);
      if(sb) sb.disabled = true;
    }

    const container = el("div",{"data-branch-container":`${q.id}::${bi}`},[]);
    container.appendChild(head);
    container.appendChild(body);
    if((branch.parts||[]).length>0){ typesetMath(parts); container.appendChild(parts);}
    container.appendChild(btns);

    branchCard.appendChild(container);
    branches.appendChild(branchCard);

    // Apply feedback if already saved
    if(rec.saved && (rec.status==="wrong1")){
      const grade = gradeBranch(q, branch, bi, rec.saved);
    }
  });

  wrap.appendChild(titleRow);
  wrap.appendChild(branches);
  typesetMath(wrap);
}

/* ===== ????? ?????? ===== */
function swapQuestion(qid){
  bumpVariant(qid);
  clearQuestionState(qid);
  const t = TEMPLATES.find(x=>x.id===qid);
  if(t){
    const v = getVariant(t.id);
    const g = t.gen(v);
    const ni = BANK.findIndex(q=>q.id===qid);
    const obj = { id:t.id, title:t.title, icon:t.icon, branches:g.branches };
    if(ni>=0) BANK[ni]=obj;
  }
  saveState();
  renderAll();
}

/* ===== ?????? ===== */
function next(){
  if(state.currentIndex < BANK.length-1){
    state.currentIndex++;
    saveState();
    renderAll();
  }else{
    tryShowResults();
  }
}
function prev(){
  if(state.currentIndex>0){
    state.currentIndex--;
    saveState();
    renderAll();
  }
}

/* ===== ??????? (????? ??????) ===== */
function listIncomplete(){
  const arr=[];
  BANK.forEach((q,i)=>{
    if(!isQuestionComplete(q)) arr.push({i:i+1, title:q.title});
  });
  return arr;
}

function tryShowResults(){
  const p = setProgress();
  if(!p.doneAll){
    if(!confirm("???? ????? ?? ???? ????. ?? ???? ?????????")) return;
  }
  showResultsModal();
}

function computeScore(){
  let total=0, correct=0;
  BANK.forEach(q=>{
    q.branches.forEach((branch,bi)=>{
      const rec = ensureBranchRec(q.id,bi);
      const keys = collectPartKeys(branch);
      const grade = gradeBranch(q, branch, bi, rec.saved||{});
      keys.forEach(k=>{
        total++;
        if(grade.byKey[k]) correct++;
      });
    });
  });
  const pct = total? (correct/total)*100 : 0;
  return {correct,total,pct:Math.round(pct*10)/10};
}

function showResultsModal(){
  BANK = buildBank();
  const s = computeScore();

  const cards = BANK.map((q,qi)=>{
    const complete = isQuestionComplete(q);
    const correctQ = complete && isQuestionCorrect(q);

    let inner = `
      <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
        <div style="font-weight:900">???? ${qi+1}: ${escapeHtml(q.title)}</div>
        <span class="tag ${correctQ?"good":"bad"}">${correctQ?"? ????":"ï؟½ ??? ????"}</span>
      </div>
    `;

    q.branches.forEach((branch,bi)=>{
      const rec = ensureBranchRec(q.id,bi);
      const grade = gradeBranch(q, branch, bi, rec.saved||{});
      const keys = collectPartKeys(branch);

      inner += `<div style="margin-top:10px;font-weight:900;color:#0f2a3b">(${escapeHtml(branch.level)})</div>`;
      keys.forEach(k=>{
        const student = (rec.saved && rec.saved[k]!=null) ? rec.saved[k] : "ï؟½";
        const correctVal = branch.answers[k];
        const ok = grade.byKey[k];
        const correctText = (typeof correctVal === "string") ? correctVal : formatNumber(correctVal);

        inner += `
          <div class="partRow">
            <div><b>?????:</b> ${escapeHtml(k)}</div>
            <div><b>??????:</b> ${escapeHtml(String(student))}</div>
            <div><b>??????:</b> ${escapeHtml(String(correctText))} <span class="tag ${ok?"good":"bad"}" style="margin-right:8px">${ok?"?":"ï؟½"}</span></div>
          </div>`;
      });
    });

    return `<div class="resultCard">${inner}</div>`;
  }).join("");

  const correctPct = s.total ? (s.correct/s.total)*100 : 0;
  const wrongPct = s.total ? ((s.total-s.correct)/s.total)*100 : 0;
  openModal("???????", `
    <div class="scoreCard" style="margin-bottom:14px">
      <div>
        <div class="scoreBig">??????: ${s.correct} ?? ${s.total} ï؟½ ${s.pct}%</div>
        <div class="score-bar-wrap" style="margin:10px 0"><div class="score-bar-correct" style="width:${correctPct}%"></div><div class="score-bar-wrong" style="width:${wrongPct}%"></div></div>
        <div class="scoreSub">?? ????? ?? ??? ???? ?????.</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn primary" onclick="window.print()">????? ???????</button>
        <button class="btn primary" onclick="window.__resetAll(); closeModal();">????? ????????</button>
      </div>
    </div>
    ${cards}
  `);
}
